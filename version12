def save_report(df_report: pd.DataFrame, target_col: str,
                matched_indices: list[int], added_indices: list[int],
                not_found_indices: list[int],
                table3_path: str, month: str) -> tuple[str, pd.DataFrame]:
    if ask_yes_no("Сохранение", "Сохранить изменения в том же файле?"):
        save_path = table3_path
    else:
        default = f"отчет_эффект_{month}_{datetime.now().strftime('%Y%m%d_%H%M%S')}.xlsx"
        save_path = select_save_file("Сохранить отчёт как", default)
        if not save_path:
            print(" ✗ Сохранение отменено.")
            return table3_path, df_report

    try:
        _wait_save = WaitingWindow("⏳ Идёт сохранение...",
                                   "Файл сохраняется, пожалуйста, подождите.")
        t = datetime.now()

        print("  📝 Нормализация данных...")
        # Нормализуем значения колонок перед сохранением
        real_svc = find_col_name(df_report, RPT_COL_SERVICE)
        real_mrf = find_col_name(df_report, RPT_COL_MRF)
        real_rf = find_col_name(df_report, RPT_COL_RF)
        real_date = find_col_name(df_report, RPT_COL_DATE)
        real_pct = find_col_name(df_report, RPT_COL_PCT)

        print(f"  Колонки отчёта: Услуга={real_svc!r}, МРФ={real_mrf!r}, РФ={real_rf!r}")

        if real_svc:
            df_report[real_svc] = df_report[real_svc].apply(
                lambda x: fmt_service(x) if pd.notna(x) and str(x).strip() != "" else x)

        if real_mrf:
            df_report[real_mrf] = df_report[real_mrf].apply(
                lambda x: fmt_mrf(x) if pd.notna(x) and str(x).strip() != "" else x)

        if real_rf:
            df_report[real_rf] = df_report[real_rf].apply(
                lambda x: fmt_title(x) if pd.notna(x) and str(x).strip() != "" else x)

        real_seg = find_col_name(df_report, RPT_COL_SEGMENT)
        real_sub = find_col_name(df_report, RPT_COL_SUBSEG)
        real_tgt = find_col_name(df_report, target_col)

        print(f"  Колонки отчёта: Сегмент={real_seg!r}, Подсегмент={real_sub!r}")

        if real_seg:
            df_report[real_seg] = df_report[real_seg].apply(
                lambda x: fmt_seg(x) if pd.notna(x) and str(x).strip() != "" else x)

        if real_sub:
            df_report[real_sub] = df_report[real_sub].apply(
                lambda x: fmt_seg(x) if pd.notna(x) and str(x).strip() != "" else x)

        real_seg1 = find_col_name(df_report, RPT_COL_SEGMENT1)
        if real_seg1:
            df_report[real_seg1] = df_report[real_seg1].apply(
                lambda x: fmt_seg(x) if pd.notna(x) and str(x).strip() != "" else x)

        if real_date:
            df_report[real_date] = df_report[real_date].apply(
                lambda x: pd.to_datetime(x, dayfirst=True, errors="coerce").date()
                if pd.notna(x) and str(x).strip() != "" else x)

        if real_pct:
            df_report[real_pct] = df_report[real_pct].apply(
                lambda x: fmt_pct(x) if pd.notna(x) and str(x).strip() != "" else x)

        if real_tgt:
            df_report[real_tgt] = df_report[real_tgt].apply(
                lambda x: fmt_num3(x) if pd.notna(x) and str(x).strip() != "" else x)

        print("  💾 Запись данных в Excel файл...")
        with pd.ExcelWriter(save_path, engine='openpyxl', mode='w') as writer:
            df_report.to_excel(writer, sheet_name=SHEET_TABLE3, index=False)

        print("  🎨 Применяем форматы ячеек и заливку...")
        wb = load_workbook(save_path)
        ws = wb[SHEET_TABLE3]

        grn = PatternFill(start_color=FILL_UPDATED, end_color=FILL_UPDATED, fill_type='solid')
        blue = PatternFill(start_color=FILL_ADDED, end_color=FILL_ADDED, fill_type='solid')
        yel = PatternFill(start_color=FILL_NOT_FOUND, end_color=FILL_NOT_FOUND, fill_type='solid')

        cols_list = list(df_report.columns)

        def col_idx(name):
            return cols_list.index(name) + 1 if name in cols_list else None

        ci_target = col_idx(target_col)
        ci_service = col_idx(RPT_COL_SERVICE)
        ci_date = col_idx(RPT_COL_DATE)
        ci_pct = col_idx(RPT_COL_PCT)
        ci_mrf = col_idx(RPT_COL_MRF)
        ci_rf = col_idx(RPT_COL_RF)
        ci_seg = col_idx(RPT_COL_SEGMENT)
        ci_sub = col_idx(RPT_COL_SUBSEG)

        FMT_DATE = "DD.MM.YYYY"
        FMT_PCT = "0.00%"
        FMT_NUM3 = "#,##0.000"
        FMT_TEXT = "@"

        max_row = ws.max_row
        for row_num in range(2, max_row + 1):
            if ci_service:
                ws.cell(row=row_num, column=ci_service).number_format = FMT_TEXT
            if ci_date:
                ws.cell(row=row_num, column=ci_date).number_format = FMT_DATE
            if ci_pct:
                ws.cell(row=row_num, column=ci_pct).number_format = FMT_PCT
            if ci_mrf:
                ws.cell(row=row_num, column=ci_mrf).number_format = FMT_TEXT
            if ci_rf:
                ws.cell(row=row_num, column=ci_rf).number_format = FMT_TEXT
            if ci_seg:
                ws.cell(row=row_num, column=ci_seg).number_format = FMT_TEXT
            if ci_sub:
                ws.cell(row=row_num, column=ci_sub).number_format = FMT_TEXT
            if ci_target:
                ws.cell(row=row_num, column=ci_target).number_format = FMT_NUM3

        ci = ci_target if ci_target else 1
        for ridx in matched_indices:
            ws.cell(row=ridx + 2, column=ci).fill = grn
        for ridx in added_indices:
            for c in range(1, len(cols_list) + 1):
                ws.cell(row=ridx + 2, column=c).fill = blue
        for ridx in not_found_indices:
            ws.cell(row=ridx + 2, column=ci).fill = yel

        wb.save(save_path)
        _wait_save.close()
        save_sec = (datetime.now() - t).total_seconds()
        print(f"  ✅ Сохранено: {os.path.basename(save_path)} ({save_sec:.1f} сек)")
        print(f"  🔄 Обновлено: {len(matched_indices)} ячеек")
        print(f"  ➕ Добавлено: {len(added_indices)} строк")
        if not_found_indices:
            print(f"  ⚠ Не найдено в базе: {len(not_found_indices)} строк")

        return save_path, df_report

    except Exception as e:
        try:
            _wait_save.close()
        except tk.TclError:
            pass
        print(f" ✗ Ошибка сохранения: {e}")
        messagebox.showerror("Ошибка сохранения",
                             f"Не удалось сохранить файл:\n{e}",
                             parent=_get_file_root())
        return table3_path, df_report


def process_mrf(mrf_name: str, df_report: pd.DataFrame, table3_path: str,
                month: str, amount_col: str, target_col: str,
                session_counts: dict) -> tuple:
    """Обрабатывает один МРФ."""
    print(f"\n{'#'*60}\n МРФ: {mrf_name.upper()}\n{'#'*60}")

    base_num = 0
    mrf_upd = 0
    mrf_add = 0
    mrf_eff = 0.0

    df_amount_cache = None

    while True:
        base_num += 1
        print(f"\n📂 Загрузите БАЗУ ИНДЕКСАЦИИ #{base_num} для МРФ {mrf_name}...")
        base_path = select_file(f"БАЗА ИНДЕКСАЦИИ #{base_num} — МРФ {mrf_name}")
        if not base_path:
            print(f"  ✗ Файл не выбран — завершаем МРФ {mrf_name}.")
            break

        base_name = os.path.basename(base_path)
        session_log.add(f"  📂 База #{base_num}", base_path)

        print("  📖 Загружаем базу индексации, пожалуйста подождите...")
        t = datetime.now()
        try:
            df_base = pd.read_excel(base_path, sheet_name=SHEET_TABLE2)
        except (FileNotFoundError, ValueError, KeyError, Exception) as e:
            print(f"  ✗ Ошибка загрузки базы: {e}")
            if not ask_yes_no("Ошибка", f"Попробовать другую базу для МРФ {mrf_name}?"):
                break
            base_num -= 1
            continue

        print(f"  ✅ {len(df_base):,} строк ({(datetime.now()-t).total_seconds():.1f} сек)")

        charges_mode = ask_charges_mode(base_name, mrf_name)
        if not charges_mode:
            print("  ✗ Режим не выбран — пропускаем базу.")
            if not ask_yes_no("Пропустить?", f"Загрузить следующую базу для {mrf_name}?"):
                break
            base_num -= 1
            continue

        print(f"  Режим: {'📂 внешний файл начислений' if charges_mode == MODE_EXTERNAL else '📊 начисления в базе'}")

        # Колонка «до индексации»
        base_col = select_column(df_base.columns,
                                 f"МРФ {mrf_name} — база #{base_num}: начисление ДО индексации",
                                 "Выберите колонку с НАЧИСЛЕНИЕМ ДО ИНДЕКСАЦИИ:")
        if not base_col:
            if not ask_yes_no("Пропустить?", f"Загрузить следующую базу для {mrf_name}?"):
                break
            base_num -= 1
            continue

        id_col = None
        current_col = None
        df_amount = None

        if charges_mode == MODE_EXTERNAL:
            possible_ids = ["MSISDN",
                            "Уникальный идентификационный номер услуги (ШПД, VPN - логин порта)",
                            "Уникальный идентификационный номер услуги",
                            "MSISDN/Логин"]
            id_col = next((c for c in possible_ids if c in df_base.columns), None)
            if not id_col:
                id_col = select_column(df_base.columns,
                                       f"МРФ {mrf_name}: идентификатор абонента",
                                       "Выберите колонку с УНИКАЛЬНЫМ ИДЕНТИФИКАТОРОМ (MSISDN/логин):")
                if not id_col:
                    if not ask_yes_no("Пропустить?", f"Загрузить следующую базу для {mrf_name}?"):
                        break
                    base_num -= 1
                    continue

            if df_amount_cache is None:
                print(f"\n📂 Загрузите файл НАЧИСЛЕНИЙ для МРФ {mrf_name}...")
                charges_path = select_file(f"НАЧИСЛЕНИЯ — МРФ {mrf_name}")
                if not charges_path:
                    print("  ✗ Файл не выбран — пропускаем базу.")
                    if not ask_yes_no("Пропустить?", f"Загрузить следующую базу для {mrf_name}?"):
                        break
                    base_num -= 1
                    continue

                print(f"  📖 Загрузка начислений [{mrf_name}]... (может занять несколько минут)")
                t = datetime.now()
                try:
                    df_amount_cache = pd.read_excel(charges_path, sheet_name=SHEET_TABLE1)
                except (FileNotFoundError, ValueError, KeyError, Exception) as e:
                    print(f"  ✗ Ошибка загрузки начислений: {e}")
                    if not ask_yes_no("Пропустить?", f"Загрузить следующую базу для {mrf_name}?"):
                        break
                    base_num -= 1
                    continue

                print(f"  ✅ {len(df_amount_cache):,} строк ({(datetime.now()-t).total_seconds():.1f} сек)")
                session_log.add("  📂 Начисления", charges_path)

                if amount_col not in df_amount_cache.columns:
                    print(f"  ✗ Нет колонки '{amount_col}' в файле начислений")
                    df_amount_cache = None
                    if not ask_yes_no("Пропустить?", f"Загрузить следующую базу для {mrf_name}?"):
                        break
                    base_num -= 1
                    continue

                if "MSISDN" not in df_amount_cache.columns:
                    print("  ✗ Нет колонки 'MSISDN' в файле начислений")
                    df_amount_cache = None
                    if not ask_yes_no("Пропустить?", f"Загрузить следующую базу для {mrf_name}?"):
                        break
                    base_num -= 1
                    continue

            if df_amount_cache is None:
                print("  ⚠ Файл начислений не загружен — пропускаем базу.")
                base_num -= 1
                continue
            df_amount = df_amount_cache

        else:  # MODE_INBASE
            current_col = select_column(df_base.columns,
                                        f"МРФ {mrf_name} — база #{base_num}: ТЕКУЩЕЕ начисление (после индексации)",
                                        "Выберите колонку с ТЕКУЩИМ (фактическим) НАЧИСЛЕНИЕМ в этой базе:")
            if not current_col:
                if not ask_yes_no("Пропустить?", f"Загрузить следующую базу для {mrf_name}?"):
                    break
                base_num -= 1
                continue

        gcols = [c for c in [BASE_COL_MRF, BASE_COL_RF, BASE_COL_SEGMENT,
                             BASE_COL_SUBSEG, BASE_COL_SEGMENT1]
                 if c in df_base.columns]
        if not gcols:
            print("  ⚠ Нет колонок группировки.")
            if not ask_yes_no("Пропустить?", f"Загрузить следующую базу для {mrf_name}?"):
                break
            base_num -= 1
            continue

        if base_col:
            session_log.add_text(f"  📌 Колонка ДО: {base_col}")
        if charges_mode == MODE_INBASE and current_col:
            session_log.add_text(f"  📌 Колонка ТЕКУЩЕЕ: {current_col}")

        res = process_one_base(
            df_base, df_amount, df_report,
            base_col, id_col, amount_col, current_col,
            charges_mode, gcols, target_col,
            base_name, mrf_name, base_num
        )

        if res:
            upd, add, m_idx, a_idx, nf_idx, eff, df_report = res

            session_counts["matched"] += upd
            session_counts["added"] += add
            session_counts["not_found"] += len(nf_idx)
            mrf_upd += upd
            mrf_add += add
            mrf_eff += eff

            cur_matched = m_idx
            cur_added = a_idx
            cur_not_found = nf_idx

            table3_path, df_report = save_report(
                df_report, target_col,
                cur_matched, cur_added,
                cur_not_found, table3_path, month
            )

            del cur_matched, cur_added, cur_not_found
        else:
            print(f"  ✗ База #{base_num} ({base_name}): пропущена")

        if not ask_yes_no("Ещё одна база?",
                          f"МРФ {mrf_name}, база #{base_num} обработана.\n"
                          f"Загрузить ещё одну базу для МРФ {mrf_name}?"):
            break

    return table3_path, df_report, [
        f"\n📊 МРФ {mrf_name}:",
        f"  • Обновлено строк: {mrf_upd}",
        f"  • Добавлено строк: {mrf_add}",
        f"  • Эффект: {mrf_eff:,.3f} тыс. руб."
    ]


