def calc_pivot_external(df_base: pd.DataFrame, df_amount: pd.DataFrame,
                        base_col: str, id_col: str, amount_col: str,
                        group_cols: list[str]) -> pd.DataFrame:
    """
    РЕЖИМ А: начисления в отдельном файле.
    Джоин по MSISDN, эффект = amount_col - base_col.
    """
    df_base = df_base.copy()
    df_amount = df_amount.copy()

    df_base[base_col] = pd.to_numeric(df_base[base_col], errors='coerce')
    df_amount[amount_col] = pd.to_numeric(df_amount[amount_col], errors='coerce')

    # ИСПРАВЛЕНО: удаляем только ВЕДУЩИЕ нули, а не все!
    df_base[id_col] = df_base[id_col].astype(str).str.strip().str.lstrip('0')
    df_amount["MSISDN"] = df_amount["MSISDN"].astype(str).str.strip().str.lstrip('0')

    print("  📂 Соединение баз данных по MSISDN, пожалуйста подождите...")
    t = datetime.now()
    merged = df_base.merge(df_amount[["MSISDN", amount_col]],
                           left_on=id_col, right_on="MSISDN", how='left')
    print(f"  ✓ Соединено: {len(merged):,} строк ({(datetime.now()-t).total_seconds():.1f} сек)")

    merged["Эффект_руб"] = merged[amount_col] - merged[base_col]
    merged.loc[merged["Эффект_руб"] < 0, "Эффект_руб"] = 0
    print(f"  ✓ С положительным эффектом: {(merged['Эффект_руб'] > 0).sum():,}")


    # ============================================================
    # РАСШИРЕННАЯ ДИАГНОСТИКА ДЛЯ ЧЕЛЯБИНСКОГО ФИЛИАЛА
    # ============================================================
    print("\n" + "="*80)
    print("🔍 РАСШИРЕННАЯ ДИАГНОСТИКА ДЛЯ ЧЕЛЯБИНСКОГО ФИЛИАЛА")
    print("="*80)

    # Маска для Челябинского филиала
    mask_rf = merged[BASE_COL_RF].astype(str).str.contains("Челябинск", case=False, na=False)
    mask_seg = merged[BASE_COL_SEGMENT].astype(str).str.contains("B2B 3K|B2B 3К", case=False, na=False)
    mask_sub = merged[BASE_COL_SUBSEG].astype(str).str.contains("ТОП|TOP", case=False, na=False)

    data = merged[mask_rf & mask_seg & mask_sub]

    if not data.empty:
        print(f"\n📊 Всего строк в выборке: {len(data)}")

        # 1. Проверка дубликатов MSISDN
        dup_counts = data[id_col].value_counts()
        dup_counts = dup_counts[dup_counts > 1]
        if not dup_counts.empty:
            print(f"\n⚠️ ЕСТЬ ДУБЛИКАТЫ MSISDN: {len(dup_counts)} шт.")
            for msisdn, cnt in dup_counts.head(10).items():
                print(f"  MSISDN {msisdn}: {cnt} раз")
        else:
            print("\n✅ Дубликатов MSISDN нет")

        # 2. Проверка NULL в amount_col
        null_count = data[amount_col].isna().sum()
        if null_count > 0:
            print(f"\n⚠️ NULL в {amount_col}: {null_count} строк")
            null_data = data[data[amount_col].isna()]
            print(f"  Сумма base_col у NULL-строк: {null_data[base_col].sum():.2f}")
            print(f"  Их эффект был бы отрицательным и обнулён")
        else:
            print("\n✅ NULL в amount_col нет")

        # 3. Сравнение сумм
        sum_base = data[base_col].sum()
        sum_amount = data[amount_col].sum()
        sum_eff = data["Эффект_руб"].sum()

        print(f"\n📊 Сумма ДО индексации: {sum_base:,.2f} руб.")
        print(f"📊 Сумма ПОСЛЕ индексации: {sum_amount:,.2f} руб.")
        print(f"📊 Сумма Эффект_руб: {sum_eff:,.2f} руб.")
        print(f"📊 Сумма Эффект_тыс: {sum_eff/1000:,.3f} тыс. руб.")
        print(f"📊 Разница (должно быть 653,833): {sum_eff/1000:,.3f} тыс. руб.")
        print(f"📊 Отклонение: {653.833 - sum_eff/1000:,.3f} тыс. руб.")

        # 4. Детально по абонентам
        print(f"\n📋 ДЕТАЛЬНО ПО АБОНЕНТАМ (все {len(data)}):")
        print(f"{'MSISDN':<20} {'ДО':<15} {'ПОСЛЕ':<15} {'ЭФФЕКТ':<15} {'Статус'}")
        print("-" * 80)

        sorted_data = data.sort_values(base_col, ascending=False)
        for idx, row in sorted_data.iterrows():
            msisdn = str(row[id_col])[:18]
            base = row[base_col]
            amount = row[amount_col] if pd.notna(row[amount_col]) else 0
            eff = row["Эффект_руб"]
            if amount == 0 and base > 0:
                status = "⛔ НЕ НАЙДЕН в начислениях"
            elif eff > 0:
                status = "✅"
            elif eff == 0 and amount > 0:
                status = "⚠️ эффект = 0 (amount == base)"
            else:
                status = "⚠️ отрицательный (обнулён)"
            print(f"{msisdn:<20} {base:<15.2f} {amount:<15.2f} {eff:<15.2f} {status}")

        # 5. Проверка: если amount == base, то эффект 0
        zero_eff = data[data["Эффект_руб"] == 0]
        if not zero_eff.empty:
            print(f"\n⚠️ Строк с нулевым эффектом: {len(zero_eff)}")
            if len(zero_eff) > 0:
                same = (zero_eff[amount_col] == zero_eff[base_col]).sum() if amount_col in zero_eff else 0
                zero_amount = (zero_eff[amount_col] == 0).sum() if amount_col in zero_eff else 0
                print(f"  Из них amount == base: {same}")
                print(f"  Из них amount == 0: {zero_amount}")

        # 6. Проверка группировки
        print(f"\n📊 Группировка по МРФ+РФ+Сегмент+Подсегмент:")
        grouped = data.groupby([BASE_COL_MRF, BASE_COL_RF, BASE_COL_SEGMENT, BASE_COL_SUBSEG])["Эффект_руб"].sum()
        for (mrf, rf, seg, sub), val in grouped.items():
            print(f"  {mrf} | {rf} | {seg} | {sub}: {val/1000:.3f} тыс. руб.")

        # 7. Проверка - все ли абоненты нашлись в файле начислений
        total_in_base = len(data)
        found_in_amount = data[amount_col].notna().sum()
        not_found = total_in_base - found_in_amount
        print(f"\n📊 Абонентов в базе: {total_in_base}")
        print(f"📊 Найдено в начислениях: {found_in_amount}")
        print(f"📊 НЕ найдено в начислениях: {not_found}")
        if not_found > 0:
            print(f"⚠️ {not_found} абонентов не найдены в файле начислений!")
            print(f"   Их эффект обнулён (был бы отрицательным)")

    else:
        print("❌ НЕТ ДАННЫХ для Челябинского B2B 3K / ТОП")
        print("\nПроверьте написание в данных:")
        print(f"  - РФ содержит 'Челябинск': {[x for x in merged[BASE_COL_RF].unique()[:10] if 'Челябинск' in str(x)]}")
        print(f"  - Сегмент содержит 'B2B 3K': {[x for x in merged[BASE_COL_SEGMENT].unique()[:10] if 'B2B' in str(x)]}")
        print(f"  - Подсегмент содержит 'ТОП': {[x for x in merged[BASE_COL_SUBSEG].unique()[:10] if 'ТОП' in str(x)]}")

    print("="*80)
    print()

    # ============================================================
    # КОНЕЦ ДИАГНОСТИКИ
    # ============================================================

    print("  📊 Группировка данных...")
    # Доп. колонки которые хотим сохранить в pivot (берём первое значение группы)
    extra_cols = [c for c in [BASE_COL_PCT, BASE_COL_SEGMENT1]
                  if c in merged.columns]
    agg_dict = {'Эффект_руб': 'sum'}
    for c in extra_cols:
        agg_dict[c] = 'first'

    pivot = merged.groupby(group_cols, as_index=False).agg(agg_dict)
    pivot['Эффект_тыс'] = (pivot['Эффект_руб'] / 1000).round(3)

    return pivot


def calc_pivot_inbase(df_base: pd.DataFrame, base_col: str,
                      current_col: str, group_cols: list[str]) -> pd.DataFrame:
    """
    РЕЖИМ В: начисления в той же базе.
    Эффект = current_col - base_col, без джоина.
    """
    df = df_base.copy()
    df[base_col] = pd.to_numeric(df[base_col], errors='coerce')
    df[current_col] = pd.to_numeric(df[current_col], errors='coerce')

    print("  📊 Расчёт эффекта из колонок базы...")
    df['Эффект_руб'] = df[current_col] - df[base_col]
    df.loc[df['Эффект_руб'] < 0, 'Эффект_руб'] = 0
    print(f"  ✓ Строк в базе: {len(df):,}")
    print(f"  ✓ С положительным эффектом: {(df['Эффект_руб'] > 0).sum():,}")

    print("  📊 Группировка данных...")
    extra_cols = [c for c in [BASE_COL_PCT, BASE_COL_SEGMENT1]
                  if c in df.columns]
    agg_dict = {'Эффект_руб': 'sum'}
    for c in extra_cols:
        agg_dict[c] = 'first'

    pivot = df.groupby(group_cols, as_index=False).agg(agg_dict)
    pivot['Эффект_тыс'] = (pivot['Эффект_руб'] / 1000).round(3)

    return pivot


# ОБРАБОТКА ОДНОЙ БАЗЫ

def process_one_base(df_base: pd.DataFrame,
                     df_amount: Optional[pd.DataFrame],  # None при MODE_INBASE
                     df_report,
                     base_col,        # колонка «до индексации»
                     id_col,          # None при MODE_INBASE
                     amount_col,      # колонка в файле начислений (MODE_A)
                     current_col,     # колонка «текущее» в базе (MODE_B)
                     charges_mode,    # MODE_EXTERNAL или MODE_INBASE
                     available_group_cols,
                     target_col,
                     base_name, mrf_name, iteration_num):
    print(f"\n{'='*55}")
    print(f" БАЗА #{iteration_num} [{mrf_name}]: {base_name}")
    mode_label = "📂 отдельный файл начислений" if charges_mode == MODE_EXTERNAL else "📊 начисления в базе"
    print(f" Режим: {mode_label}")
    print(f"{'='*55}")

    _wait_calc = WaitingWindow("⏳ Идёт расчёт...",
                               "Вычисляется эффект индексации.\nПожалуйста, подождите.")
    t_calc = datetime.now()
    try:
        if charges_mode == MODE_EXTERNAL:
            pivot = calc_pivot_external(df_base, df_amount, base_col,
                                        id_col, amount_col, available_group_cols)
        else:  # MODE_INBASE
            pivot = calc_pivot_inbase(df_base, base_col, current_col, available_group_cols)
    finally:
        _wait_calc.close()

    calc_sec = (datetime.now() - t_calc).total_seconds()
    print(f"  ✓ Групп: {len(pivot)}, эффект: {pivot['Эффект_тыс'].sum():,.3f} тыс. руб. "
          f"(расчёт: {calc_sec:.1f} сек)")

    if len(pivot) == 0:
        print("  ⚠ Пустой pivot — нет данных.")
        return None

    sel = filter_window(df_report, mrf_name=mrf_name)
    if not sel or not sel.get("date") or sel.get("selected") is None:
        print("  ✗ Фильтры не выбраны — база пропущена.")
        return None

    selected_date = sel["date"]
    selected_segments = sel.get("selected") or {}

    svc_col_report = RPT_COL_SERVICE if RPT_COL_SERVICE in df_report.columns else None
    if svc_col_report is None:
        print(f"  ⚠ В отчёте нет колонки '{RPT_COL_SERVICE}' — фильтр по услуге не применяется")
        selected_services = set()
    else:
        selected_services = set()
        for fc, fv in selected_segments.items():
            if fc == "Услуга":
                selected_services = set(fv)
                break

    # Строим report_dict
    report_dict = defaultdict(list)
    for idx, row in df_report.iterrows():
        rd = norm_date(row[RPT_COL_DATE]) if RPT_COL_DATE in df_report.columns else ""
        if rd != norm_date(selected_date):
            continue
        svc = norm_text(row[svc_col_report]) if svc_col_report else ""
        if selected_services and svc not in selected_services:
            continue
        mrf_ = norm_text(row[RPT_COL_MRF]) if RPT_COL_MRF in df_report.columns else ""
        rf_ = map_rf(row[RPT_COL_RF]) if RPT_COL_RF in df_report.columns else ""
        seg_ = norm_text(row[RPT_COL_SEGMENT]) if RPT_COL_SEGMENT in df_report.columns else ""
        sub_ = norm_text(row[RPT_COL_SUBSEG]) if RPT_COL_SUBSEG in df_report.columns else ""
        report_dict[(svc, mrf_, rf_, seg_, sub_)].append(idx)

    total_rpt = sum(len(v) for v in report_dict.values())
    print(f"  Строк в отчёте по дате/фильтрам: {total_rpt}")
    if total_rpt == 0:
        print("  ℹ Строк с такой датой нет — все группы будут ДОБАВЛЕНЫ.")

    # Отладка несовпадений
    pivot_ks = set()
    for _, r in pivot.iterrows():
        pivot_ks.add((
            norm_text(r[BASE_COL_MRF]) if BASE_COL_MRF in r.index else "",
            map_rf(r[BASE_COL_RF]) if BASE_COL_RF in r.index else "",
            norm_text(r[BASE_COL_SEGMENT]) if BASE_COL_SEGMENT in r.index else "",
            norm_text(r[BASE_COL_SUBSEG]) if BASE_COL_SUBSEG in r.index else ""
        ))

    report_ks = {(k[1], k[2], k[3], k[4]) for k in report_dict}
    missing = pivot_ks - report_ks

    if missing and total_rpt > 0:
        print(f"  ⚠ Ключей PIVOT без строки в отчёте: {len(missing)} → будут ДОБАВЛЕНЫ")
        for k in list(missing)[:3]:
            print(f"    МРФ='{k[0]}' РФ='{k[1]}' Сег='{k[2]}' Под='{k[3]}'")
    elif not missing and total_rpt > 0:
        print("  ✅ Все ключи PIVOT найдены — только обновление.")

    # Строки отчёта у которых НЕТ совпадения в pivot → информируем пользователя
    not_found_indices = []
    not_found_details = []

    # Строим pct_lookup: (мрф_norm, рф_norm) → процент индексации из отчёта
    pct_col_report = find_col_name(df_report, RPT_COL_PCT)
    pct_lookup = {}
    if pct_col_report and total_rpt > 0:
        for key_full, ridxs in report_dict.items():
            mrf_k = key_full[1]
            rf_k = key_full[2]
            for ridx in ridxs:
                val = df_report.loc[ridx, pct_col_report]
                if pd.notna(val) and str(val).strip() not in ("", "0", "0.0"):
                    pct_lookup[(mrf_k, rf_k)] = fmt_pct(val)
                    break

    # Получаем выбранные МРФ и РФ из фильтров для проверки границы
    filter_mrfs = set(selected_segments.get("МРФ", []))
    filter_rfs = set(selected_segments.get("РФ", []))

    if total_rpt > 0:
        for key_full, ridxs in report_dict.items():
            key_no_svc = (key_full[1], key_full[2], key_full[3], key_full[4])
            row_mrf = key_full[1]  # уже нормализованный norm_text
            row_rf = key_full[2]   # уже нормализованный map_rf

            # Пропускаем строки которые не входят в выбранные МРФ/РФ фильтра
            if filter_mrfs and row_mrf not in filter_mrfs:
                continue
            if filter_rfs and row_rf not in filter_rfs:
                continue

            if key_no_svc not in pivot_ks:
                # Эта позиция входит в выбранный МРФ/РФ, но не найдена в базе
                for ridx in ridxs:
                    try:
                        cur = df_report.loc[ridx, target_col]
                        if pd.isna(cur):
                            df_report.loc[ridx, target_col] = 0
                    except (TypeError, KeyError, IndexError):
                        pass
                not_found_indices.extend(ridxs)
                svc_val = key_full[0]
                seg_val = key_full[3]
                sub_val = key_full[4]
                not_found_details.append(
                    f"  Услуга='{svc_val}' МРФ='{row_mrf}' РФ='{row_rf}' "
                    f"Сег='{seg_val}' Под='{sub_val}'"
                )

        if not_found_details:
            print(f"\n⚠ Позиции из ОТЧЁТА (МРФ {mrf_name}), не найденные в базе индексации: {len(not_found_details)}")
            print("  (строки выделены жёлтым, значение эффекта не изменено):")
            for d in not_found_details[:15]:
                print(d)
            if len(not_found_details) > 15:
                print(f"  ... и ещё {len(not_found_details) - 15} позиций")

        messagebox.showinfo(
            "Информация о несовпадениях",
            f"Строк в отчёте по дате/фильтрам: {total_rpt}\n" +
            (f"Ключей PIVOT без строки в отчёте: {len(missing)} → будут ДОБАВЛЕНЫ\n" if missing and total_rpt > 0 else "") +
            (f"Позиций не найдено в базе: {len(not_found_details)}" if not_found_details else "Все позиции найдены в базе."),
            parent=_get_file_root()
        )

    t_match = datetime.now()
    _wait_match = WaitingWindow("⏳ Идёт сопоставление...",
                                "Сопоставляются данные с отчётом.\nПожалуйста, подождите.")
    print("  ⏳ Сопоставление с отчётом, пожалуйста подождите...")
    try:
        print("\n  --- Активные фильтры из окна ---")
        for fc, fv in selected_segments.items():
            print(f"    {fc}: {fv}")
        if not selected_segments:
            print("  (фильтры не заданы — обрабатываются все группы)")
        print()

        updated_count = 0
        added_count = 0
        matched_indices = []
        added_indices = []
        skipped_by_filter = []

        svcs_check = selected_services if selected_services else {k[0] for k in report_dict}
        if total_rpt == 0:
            svcs_check = None

        for _, pr in pivot.iterrows():
            mrf_ = norm_text(pr[BASE_COL_MRF]) if BASE_COL_MRF in pr.index else ""
            rf_ = map_rf(pr[BASE_COL_RF]) if BASE_COL_RF in pr.index else ""
            seg_ = norm_text(pr[BASE_COL_SEGMENT]) if BASE_COL_SEGMENT in pr.index else ""
            sub_ = norm_text(pr[BASE_COL_SUBSEG]) if BASE_COL_SUBSEG in pr.index else ""

            ok = True
            skip_reason = ""
            for fc, fv in selected_segments.items():
                if fc == "Услуга":
                    continue
                elif fc == "МРФ" and mrf_ not in fv:
                    ok = False
                    skip_reason = f"МРФ '{mrf_}' не в {fv}"
                    break
                elif fc == "РФ" and rf_ not in fv:
                    ok = False
                    skip_reason = f"РФ '{rf_}' не в фильтре РФ"
                    break
                elif fc == "Краткий Сегмент" and seg_ not in fv:
                    ok = False
                    skip_reason = f"Сегмент '{seg_}' не в {fv}"
                    break
                elif fc == "Подсегмент" and sub_ not in fv:
                    ok = False
                    skip_reason = f"Подсегмент '{sub_}' не в {fv}"
                    break
            if not ok:
                skipped_by_filter.append(
                    f"  ✗ ПРОПУЩЕНО ({skip_reason}): МРФ='{mrf_}' РФ='{rf_}' Сег='{seg_}' Под='{sub_}' Эфф={pr['Эффект_тыс']:.3f}"
                )
                continue

            eff = pr['Эффект_тыс']

            if total_rpt > 0:
                sc_list = list(svcs_check) if svcs_check else [None]
                found_any = False
                for svc in sc_list:
                    key = (svc, mrf_, rf_, seg_, sub_)
                    if key in report_dict:
                        for ridx in report_dict[key]:
                            df_report.loc[ridx, target_col] = eff
                            matched_indices.append(ridx)
                            updated_count += 1
                        found_any = True

                if not found_any:
                    key_no_svc = (mrf_, rf_, seg_, sub_)
                    existing_no_svc = {(k[1], k[2], k[3], k[4]) for k in report_dict}
                    if key_no_svc in existing_no_svc:
                        for key_full, ridxs in report_dict.items():
                            if (key_full[1], key_full[2], key_full[3], key_full[4]) == key_no_svc:
                                for ridx in ridxs:
                                    df_report.loc[ridx, target_col] = eff
                                    matched_indices.append(ridx)
                                    updated_count += 1
                                found_any = True
                                break

                    if not found_any:
                        svc_val = list(svcs_check)[0] if svcs_check else ""
                        new_row = _build_new_row(df_report, pr, svc_val, selected_date,
                                                  target_col, eff, pct_lookup)
                        df_report = pd.concat([df_report, pd.DataFrame([new_row])], ignore_index=True)
                        added_indices.append(len(df_report) - 1)
                        added_count += 1
            else:
                if BASE_COL_SERVICE in pr.index and pd.notna(pr[BASE_COL_SERVICE]):
                    svc_val = str(pr[BASE_COL_SERVICE]).strip()
                else:
                    svc_val = list(selected_services)[0] if selected_services else ""
                new_row = _build_new_row(df_report, pr, svc_val, selected_date,
                                          target_col, eff, pct_lookup)
                df_report = pd.concat([df_report, pd.DataFrame([new_row])], ignore_index=True)
                added_indices.append(len(df_report) - 1)
                added_count += 1

        if skipped_by_filter:
            print(f"  ⚠ Пропущено фильтрами: {len(skipped_by_filter)} групп")
            for s in skipped_by_filter[:10]:
                print(s)
            if len(skipped_by_filter) > 10:
                print(f"  ... и ещё {len(skipped_by_filter)-10} групп")

    finally:
        _wait_match.close()

    match_sec = (datetime.now() - t_match).total_seconds()
    print(f"  ✅ Записано строк: {updated_count}")
    print(f"  ✅ Добавлено новых строк: {added_count}")
    print(f"  ⏱ Сопоставление заняло: {match_sec:.1f} сек")

    return updated_count, added_count, matched_indices, added_indices, \
           not_found_indices, pivot['Эффект_тыс'].sum(), df_report


def _build_new_row(df_report: pd.DataFrame, pivot_row: pd.Series,
                   svc_val: str, selected_date: str, target_col: str,
                   eff_value: float,
                   pct_lookup: Optional[dict] = None) -> dict:
    """Строит словарь новой строки с нормализованными форматами."""
    new_row = {col: None for col in df_report.columns}

    # Услуга — UPPERCASE для спецуслуг, иначе первое с заглавной
    if RPT_COL_SERVICE in new_row:
        new_row[RPT_COL_SERVICE] = fmt_service(svc_val)

    # Дата — datetime-объект
    if RPT_COL_DATE in new_row:
        try:
            new_row[RPT_COL_DATE] = pd.to_datetime(selected_date, dayfirst=True).date()
        except (ValueError, TypeError, OverflowError):
            new_row[RPT_COL_DATE] = selected_date

    # % индексации
    if RPT_COL_PCT in new_row:
        pct_val = None
        if pct_lookup:
            mrf_key = norm_text(pivot_row[BASE_COL_MRF]) if BASE_COL_MRF in pivot_row.index else ""
            rf_key = map_rf(pivot_row[BASE_COL_RF]) if BASE_COL_RF in pivot_row.index else ""
            pct_val = pct_lookup.get((mrf_key, rf_key))
        if pct_val is None and BASE_COL_PCT in pivot_row.index:
            pct_val = fmt_pct(pivot_row[BASE_COL_PCT])
        if pct_val is not None:
            new_row[RPT_COL_PCT] = pct_val

    # МРФ
    if RPT_COL_MRF in new_row and BASE_COL_MRF in pivot_row.index:
        new_row[RPT_COL_MRF] = fmt_mrf(pivot_row[BASE_COL_MRF])

    # РФ
    if RPT_COL_RF in new_row and BASE_COL_RF in pivot_row.index:
        new_row[RPT_COL_RF] = unmap_rf(map_rf(pivot_row[BASE_COL_RF]))

    # Краткий Сегмент
    if RPT_COL_SEGMENT in new_row and BASE_COL_SEGMENT in pivot_row.index:
        new_row[RPT_COL_SEGMENT] = fmt_seg(pivot_row[BASE_COL_SEGMENT])

    # Сегмент1 из базы → Сегмент в отчёте
    if RPT_COL_SEGMENT1 in new_row and BASE_COL_SEGMENT1 in pivot_row.index:
        new_row[RPT_COL_SEGMENT1] = fmt_seg(pivot_row[BASE_COL_SEGMENT1])

    # Подсегмент
    if RPT_COL_SUBSEG in new_row and BASE_COL_SUBSEG in pivot_row.index:
        new_row[RPT_COL_SUBSEG] = fmt_seg(pivot_row[BASE_COL_SUBSEG])

    # Эффект
    if target_col in new_row:
        new_row[target_col] = fmt_num3(eff_value)

    return new_row


