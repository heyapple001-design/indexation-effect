def filter_window(df_report: pd.DataFrame, mrf_name: str = "") -> Optional[dict]:
    cols = [c for c in [RPT_COL_SERVICE, RPT_COL_MRF, RPT_COL_RF,
                        RPT_COL_SEGMENT, RPT_COL_SUBSEG]
            if c in df_report.columns]
    if not cols:
        return None

    result = {"selected": None, "date": None}
    win_title = f"Фильтры — МРФ {mrf_name}" if mrf_name else "Фильтры"
    win = make_window(win_title, 1060, 860, resizable=True)

    # Закрытие через [X] = отмена фильтров
    def _on_filter_close() -> None:
        result["selected"] = None
        result["date"] = None
        win.destroy()
    win.protocol("WM_DELETE_WINDOW", _on_filter_close)

    header_bar(win, win_title)
    hint_bar = tk.Frame(win, bg=C_BG_PANEL)
    hint_bar.pack(fill=tk.X)
    tk.Label(hint_bar,
             text="Выберите параметры фильтрации. Обязательно выберите УСЛУГУ!",
             bg=C_BG_PANEL, fg=C_TEXT_HINT, font=FONT_SMALL).pack(anchor="w", pady=6, padx=12)

    separator(win)
    scroll_area = tk.Frame(win, bg=C_BG)
    scroll_area.pack(fill=tk.BOTH, expand=True)
    cv, sf = scroll_canvas(scroll_area)

    # — Выбор даты —
    date_vals = []
    if RPT_COL_DATE in df_report.columns:
        date_vals = sorted(df_report[RPT_COL_DATE].dropna().unique())
    date_var = tk.StringVar(value="(выберите дату)")

    date_card = tk.LabelFrame(sf, text="📅 Дата индексации", bg=C_BG, fg=C_ACCENT,
                              font=("Segoe UI", 9, "bold"), relief="solid", bd=1)
    date_card.pack(fill=tk.X, padx=12, pady=4)
    date_inner = tk.Frame(date_card, bg=C_BG)
    date_inner.pack(fill=tk.X, padx=8, pady=6)

    if date_vals:
        date_cb = ttk.Combobox(date_inner, textvariable=date_var,
                               values=[norm_date(d) for d in date_vals],
                               state="readonly", font=FONT_LABEL, width=20)
        date_cb.pack(side=tk.LEFT, padx=(0,8))
        date_cb.set(norm_date(date_vals[-1]) if date_vals else "")
    else:
        tk.Label(date_card, text=f"⚠ В отчёте нет колонки «{RPT_COL_DATE}»",
                 bg=C_BG, fg="#C42B1C", font=FONT_LABEL).pack(padx=12, pady=8)

    # — Вычисляем канонические РФ текущего МРФ для авто-преселекта —
    mrf_rf_canonical = set()
    if mrf_name and mrf_name in MRF_TO_RF:
        for rf_raw in MRF_TO_RF[mrf_name]:
            mrf_rf_canonical.add(norm_text(map_rf(rf_raw)))

    mrf_norm = norm_text(mrf_name) if mrf_name else ""

    def make_values(col):
        """Возвращает список значений для колонки в нормализованном виде."""
        s = df_report[col].dropna()
        if col == RPT_COL_RF:
            # РФ: полное официальное название через unmap_rf, только РФ текущего МРФ
            all_vals = sorted(dict.fromkeys(
                unmap_rf(map_rf(x)) for x in s if str(x).strip()
            ))
            if mrf_rf_canonical:
                # Фильтруем по каноническим ключам МРФ
                filtered = [v for v in all_vals
                            if norm_text(map_rf(v)) in mrf_rf_canonical]
                return filtered if filtered else all_vals
            return all_vals
        elif col == RPT_COL_MRF:
            # МРФ: эталонное написание, по алфавиту
            return sorted(dict.fromkeys(
                fmt_mrf(v) for v in s if str(v).strip()
            ))
        elif col == RPT_COL_SERVICE:
            # Услуга: нормализованное написание через fmt_service
            return sorted(dict.fromkeys(
                fmt_service(str(v).strip()) for v in s if str(v).strip()
            ))
        elif col in (RPT_COL_SEGMENT, RPT_COL_SUBSEG):
            # Сегмент/Подсегмент: fmt_seg, по алфавиту
            return sorted(dict.fromkeys(
                fmt_seg(norm_text(v)) for v in s if str(v).strip()
            ))
        else:
            vals = [norm_text(v) for v in s]
            return sorted(dict.fromkeys([v for v in vals if v]))

    def auto_check(col, val):
        """Нужно ли автоматически поставить галочку для этого значения?"""
        if col == RPT_COL_RF:
            # val — полное название вида "Екатеринбургский филиал" (после unmap_rf)
            # нормализуем через map_rf чтобы сравнить с mrf_rf_canonical
            return norm_text(map_rf(val)) in mrf_rf_canonical
        if col == RPT_COL_MRF:
            # Сравниваем через fmt_mrf т.к. значения теперь в эталонном виде
            return fmt_mrf(val).lower() == mrf_norm or val == fmt_mrf(mrf_name)
        return False

    checkbox_vars = {}
    for col in cols:
        dn = col.replace(".1", "")
        is_service = (dn == "Услуга")
        title_lbl = f"⚠ {dn} — выберите обязательно!" if is_service else f"  {dn}"
        title_fg = "#C42B1C" if is_service else C_ACCENT
        card = tk.LabelFrame(sf, text=title_lbl, bg=C_BG, fg=title_fg,
                             font=("Segoe UI", 9, "bold"), relief="solid", bd=1)
        card.pack(fill=tk.X, padx=12, pady=4)

        btn_row = tk.Frame(card, bg=C_BG)
        btn_row.pack(fill=tk.X, padx=8, pady=(6,2))
        values = make_values(col)
        checkbox_vars[col] = {}

        def _sel(c=col):
            for v in checkbox_vars[c].values():
                v.set(True)

        def _des(c=col):
            for v in checkbox_vars[c].values():
                v.set(False)

        flat_button(btn_row, "✓ Выбрать все", _sel, style="Secondary.TButton", width=14).pack(side=tk.LEFT, padx=(0,4))
        flat_button(btn_row, "✗ Снять все", _des, style="Secondary.TButton", width=14).pack(side=tk.LEFT)

        # Подсказка об авто-преселекте для РФ и МРФ
        if col == RPT_COL_RF and mrf_rf_canonical:
            tk.Label(card,
                     text=f"✓ Автоматически выбраны РФ МРФ {mrf_name}",
                     bg=C_BG, fg="#107C10", font=FONT_SMALL).pack(anchor="w", padx=8, pady=(0,2))
        if col == RPT_COL_MRF and mrf_norm:
            tk.Label(card,
                     text=f"✓ Автоматически выбран МРФ {mrf_name}",
                     bg=C_BG, fg="#107C10", font=FONT_SMALL).pack(anchor="w", padx=8, pady=(0,2))

        if len(values) > 12:
            inner_cv = tk.Canvas(card, height=160, bg=C_BG, highlightthickness=0)
            inner_sb = ttk.Scrollbar(card, orient="vertical", command=inner_cv.yview)
            inner_fr = tk.Frame(inner_cv, bg=C_BG)
            inner_fr.bind("<Configure>", lambda e, c=inner_cv: c.configure(scrollregion=c.bbox("all")))
            inner_cv.create_window((0,0), window=inner_fr, anchor="nw")
            inner_cv.configure(yscrollcommand=inner_sb.set)
            inner_cv.pack(side=tk.LEFT, fill=tk.BOTH, expand=True, padx=8, pady=6)
            inner_sb.pack(side=tk.RIGHT, fill=tk.Y, pady=6)
            container = inner_fr
        else:
            container = tk.Frame(card, bg=C_BG)
            container.pack(fill=tk.BOTH, expand=True, padx=8, pady=6)

        max_c = 3
        rpc = max(1, (len(values) + max_c - 1) // max_c)
        for idx, val in enumerate(values):
            r, cn = idx % rpc, idx // rpc
            default_checked = auto_check(col, val)
            var = tk.BooleanVar(value=default_checked)
            checkbox_vars[col][val] = var
            tk.Checkbutton(container, text=val, variable=var,
                           bg=C_BG, fg=C_TEXT, activebackground=C_BG,
                           activeforeground=C_ACCENT, selectcolor=C_BG,
                           font=FONT_LABEL, relief="flat", bd=0,
                           anchor="w", cursor="hand2", width=32).grid(row=r, column=cn, sticky="w", padx=6, pady=2)
        for cn in range(max_c):
            container.columnconfigure(cn, weight=1)

    separator(win)
    act_row = tk.Frame(win, bg=C_BG)
    act_row.pack(fill=tk.X, padx=16, pady=10)

    def on_apply():
        if date_var is None or date_var.get() == "(выберите дату)":
            messagebox.showwarning("Внимание", "Выберите дату индексации!", parent=win)
            return
        svc_col = RPT_COL_SERVICE if RPT_COL_SERVICE in checkbox_vars else None
        if svc_col and not any(v.get() for v in checkbox_vars[svc_col].values()):
            messagebox.showwarning("Внимание",
                                   "Выберите хотя бы одну УСЛУГУ!\nБез фильтра данные запишутся во все строки.",
                                   parent=win)
            return
        selected = {}
        for c in cols:
            vals = [val for val, v in checkbox_vars[c].items() if v.get()]
            if c == RPT_COL_MRF:
                # fmt_mrf → norm_text для сравнения с report_dict
                vals = [norm_text(v) for v in vals]
            elif c == RPT_COL_RF:
                # unmap_rf → map_rf → norm_text для сравнения с report_dict
                vals = [norm_text(map_rf(v)) for v in vals]
            elif c == RPT_COL_SERVICE:
                # fmt_service → norm_text для сравнения с report_dict
                vals = [norm_text(v) for v in vals]
            elif c in (RPT_COL_SEGMENT, RPT_COL_SUBSEG):
                # fmt_seg → norm_text для сравнения с report_dict
                vals = [norm_text(v) for v in vals]
            selected[c] = vals
        result["selected"] = {k: v for k, v in selected.items() if v}
        result["date"] = date_var.get()
        win.destroy()

    def on_clear():
        for col in cols:
            for v in checkbox_vars[col].values():
                v.set(False)
        if date_var:
            date_var.set("(выберите дату)")

    flat_button(act_row, "Применить фильтры →", on_apply, width=20).pack(side=tk.LEFT)
    flat_button(act_row, "Сбросить всё", on_clear, style="Secondary.TButton", width=14).pack(side=tk.LEFT, padx=10)
    flat_button(act_row, "Отмена", win.destroy, style="Danger.TButton", width=10).pack(side=tk.LEFT)

    _get_file_root().wait_window(win)
    return result


