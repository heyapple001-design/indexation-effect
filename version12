            target_col = col
            break

    if not target_col:
        print(f"✗ Нет целевой колонки для '{month}'")
        print(f"  Колонка должна содержать: {TARGET_COL_KEYWORDS} и '{month}'")
        for col in df_report.columns:
            if month in str(col).lower():
                print(f"  • {col}")
        messagebox.showerror("Ошибка",
                             f"Нет целевой колонки для '{month}'\n"
                             f"Колонка должна содержать: {TARGET_COL_KEYWORDS}",
                             parent=_get_file_root())
        return

    print(f"  🎯 Целевая колонка: {target_col}")

    session_counts = {"matched": 0, "added": 0, "not_found": 0}
    session_summary = []

    for i, mrf_name in enumerate(chosen_mrf, 1):
        print(f"\n{'='*60}\n [{i}/{len(chosen_mrf)}] МРФ: {mrf_name.upper()}\n{'='*60}")
        table3_path, df_report, mrf_sum = process_mrf(
            mrf_name, df_report, table3_path, month,
            amount_col, target_col, session_counts
        )
        session_summary.extend(mrf_sum)

        if i < len(chosen_mrf):
            if not ask_yes_no("Следующий МРФ",
                              f"МРФ {mrf_name} обработан.\nПерейти к МРФ {chosen_mrf[i]}?"):
                session_summary.append(f"\n△ Остановлено на МРФ {mrf_name}.")
                break

    total_time = (datetime.now() - t0).total_seconds()
    sep = "=" * 60
    print(f"\n{sep}\nИТОГ\n{sep}")
    for line in session_summary:
        print(line)

    print(f"\n  📝 Записано/перезаписано строк: {session_counts['matched']}")
    print(f"  ➕ Добавлено новых строк: {session_counts['added']}")
    if session_counts["not_found"]:
        print(f"  ⚠ Не найдено в базе: {session_counts['not_found']} строк")
    print(f"  ⏱ Время: {total_time:.0f} сек ({total_time/60:.1f} мин)")

    not_found_line = (f"\n⚠ Не найдено в базе: {session_counts['not_found']} строк"
                      if session_counts["not_found"] else "")
    session_log.close()

    show_progress(
        f"✅ Расчёт за {month} 2026 завершён!\n"
        f"📊 МРФ: {', '.join(chosen_mrf)}\n\n"
        + "\n".join(session_summary)
        + f"\n\n📝 Записано строк: {session_counts['matched']}"
        f"\n➕ Добавлено новых строк: {session_counts['added']}"
        + not_found_line +
        f"\n(обновлено ➕ добавлено ⚠ не найдено в базе)\n\n"
        f"⏱ Общее время: {total_time/60:.1f} мин",
        title="Итог расчёта"
    )


if __name__ == "__main__":
    main()