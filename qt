def read_excel_optimized(filepath: str, sheet_name: str = None, chunksize: int = 50000) -> pd.DataFrame:
    """
    Оптимизированное чтение Excel с использованием calamine.
    Поддерживает файлы до 300 000 строк.
    """
    if not os.path.exists(filepath):
        raise FileNotFoundError(f"Файл не найден: {filepath}")
    
    try:
        # Пробуем использовать calamine для больших файлов
        if filepath.lower().endswith('.xlsx'):
            try:
                # Проверяем размер файла
                file_size = os.path.getsize(filepath)
                if file_size > 50 * 1024 * 1024:  # > 50 MB
                    # Используем calamine для больших файлов
                    return pd.read_excel(
                        filepath, 
                        sheet_name=sheet_name,
                        engine='calamine',
                        dtype=str,  # Читаем все как строки для избежания ошибок
                    )
            except Exception as e:
                print(f"Calamine не доступен: {e}, пробуем openpyxl")
        
        # Fallback на openpyxl с оптимизацией
        return pd.read_excel(
            filepath,
            sheet_name=sheet_name,
            engine='openpyxl',
            dtype=str,
        )
    except Exception as e:
        raise Exception(f"Ошибка чтения Excel: {e}\nФайл: {filepath}")

def read_excel_in_chunks(filepath: str, sheet_name: str = None, chunksize: int = 50000) -> pd.DataFrame:
    """
    Чтение Excel по частям для экономии памяти.
    """
    try:
        # Используем calamine для чтения по частям
        if filepath.lower().endswith('.xlsx'):
            try:
                # Загружаем весь файл, но оптимизируем типы
                df = pd.read_excel(
                    filepath,
                    sheet_name=sheet_name,
                    engine='calamine',
                    dtype=str,
                )
                
                # Оптимизация типов для экономии памяти
                for col in df.columns:
                    if df[col].dtype == 'object':
                        # Преобразуем в категории, если мало уникальных значений
                        if df[col].nunique() < len(df) * 0.5:
                            df[col] = df[col].astype('category')
                        else:
                            # Иначе оставляем как строку
                            df[col] = df[col].astype(str)
                
                return df
            except Exception:
                pass
        
        # Fallback
        return pd.read_excel(
            filepath,
            sheet_name=sheet_name,
            engine='openpyxl',
            dtype=str,
        )
    except Exception as e:
        raise Exception(f"Ошибка чтения Excel: {e}")

