def safe_convert_to_numeric(series: pd.Series) -> pd.Series:
    """Безопасное преобразование в числовой тип."""
    try:
        return pd.to_numeric(series, errors='coerce')
    except Exception:
        return pd.Series([0] * len(series), index=series.index)

def safe_str_strip(series: pd.Series) -> pd.Series:
    """Безопасное удаление пробелов из строк."""
    try:
        return series.astype(str).str.strip().str.replace('.0', '', regex=False)
    except Exception:
        return series

def find_col_name(df: pd.DataFrame, name: str) -> Optional[str]:
    """Поиск колонки по имени с игнорированием регистра."""
    if df is None or len(df.columns) == 0:
        return None
    nl = name.strip().lower()
    for c in df.columns:
        if str(c).strip().lower() == nl:
            return c
    return None

def norm_text(x: Any) -> str:
    """Нормализация текста."""
    if pd.isna(x) or x is None:
        return ""
    try:
        return " ".join(str(x).replace("\xa0", " ").strip().lower().split())
    except Exception:
        return ""

def norm_date(x: Any) -> str:
    """Нормализация даты."""
    if x is None:
        return ""
    try:
        if pd.isna(x):
            return ""
    except TypeError:
        pass
    try:
        dt = pd.to_datetime(x, errors="coerce", dayfirst=True)
        if pd.isna(dt):
            return str(x).strip()
        return dt.strftime("%d.%m.%Y")
    except Exception:
        return str(x).strip()

def map_rf(raw_value: Any) -> str:
    """Маппинг РФ."""
    raw_str = str(raw_value).strip()
    if raw_str in RF_MAPPING:
        return norm_text(RF_MAPPING[raw_str])
    if raw_str.lower() in RF_MAPPING:
        return norm_text(RF_MAPPING[raw_str.lower()])
    return norm_text(raw_str)

def unmap_rf(canon: Any) -> str:
    """Обратный маппинг РФ."""
    key = norm_text(canon)
    return RF_REVERSE.get(key, canon)

def fmt_title(x: Any) -> Any:
    """Форматирование заголовка."""
    if pd.isna(x) or str(x).strip() == "":
        return x
    try:
        s = str(x).strip()
        return s[0].upper() + s[1:].lower()
    except Exception:
        return x

def fmt_mrf(x: Any) -> Any:
    """Форматирование МРФ."""
    if pd.isna(x) or str(x).strip() == "":
        return x
    try:
        key = str(x).strip().lower()
        return MRF_EXACT.get(key, fmt_title(x))
    except Exception:
        return x

def fmt_service(x: Any) -> Any:
    """Форматирование услуги."""
    if pd.isna(x) or str(x).strip() == "":
        return x
    try:
        s = str(x).strip()
        key = s.lower()
        if key in SERVICE_EXACT:
            return SERVICE_EXACT[key]
        if key in UPPERCASE_SERVICES:
            return s.upper()
        return fmt_title(s)
    except Exception:
        return x

def fmt_seg(x: Any) -> Any:
    """Форматирование сегмента."""
    import re
    if pd.isna(x) or str(x).strip() == "":
        return x
    try:
        s = str(x).strip()
        ABBREVS = {'мсп','смп','мрф','фэс','днк','ккфу','фу','ру','вп','оп','нк','топ'}
        result = []
        for word in s.split():
            if re.search(r'[a-zA-Z0-9]', word):
                result.append(word.upper())
            elif word.lower() in ABBREVS:
                result.append(word.upper())
            else:
                result.append(word.capitalize())
        return ' '.join(result)
    except Exception:
        return x

def fmt_pct(x: Any) -> Any:
    """Форматирование процента."""
    try:
        v = float(str(x).replace(",", ".").replace("%", "").strip())
        return v / 100 if v > 1 else v
    except (ValueError, TypeError):
        return x

def fmt_num3(x: Any) -> Any:
    """Форматирование числа с 3 знаками."""
    try:
        return round(float(x), 3)
    except (ValueError, TypeError):
        return x

