    lbl.setStyleSheet(
        f"background-color: {ACCENT}; color: white; "
        f"font-size: 13pt; font-weight: bold; "
        f"padding: 12px 20px;"
    )
    lbl.setMinimumHeight(52)
    return lbl

def btn(text: str, style: str = "accent") -> QPushButton:
    b = QPushButton(text)
    if style == "secondary":
        b.setProperty("class", "secondary")
    elif style == "danger":
        b.setProperty("class", "danger")
    b.setStyleSheet(STYLESHEET)
    return b

def sep() -> QFrame:
