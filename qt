def _load_mappings() -> dict:
    """Загрузка справочников с обработкой ошибок."""
    try:
        # Пробуем разные пути
        possible_paths = [
            pathlib.Path(__file__).parent / "data" / "mappings.json",
            pathlib.Path.cwd() / "data" / "mappings.json",
            pathlib.Path(sys.argv[0]).parent / "data" / "mappings.json",
        ]
        
        json_path = None
        for p in possible_paths:
            if p.exists():
                json_path = p
                break
                
        if json_path is None:
            # Создаем дефолтный словарь, если файл не найден
