            subprocess.Popen(
                [python, "-c", wrapper],
                creationflags=subprocess.CREATE_NEW_CONSOLE,
                close_fds=True,
            )
        except Exception as e:
            print(f"Ошибка: {e}")
            print(f"Запустите вручную: python \"{script}\"")
