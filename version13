class FilterDialog(QDialog):
    def __init__(self, df_report: pd.DataFrame, mrf_name: str = "",
                 parent=None) -> None:
        super().__init__(parent)
        self.setWindowTitle(f"Фильтры — МРФ {fmt_mrf(mrf_name)}" if mrf_name else "Фильтры")
        self.resize(1020, 820); self.setStyleSheet(STYLESHEET)
        self.result_date:     Optional[str]  = None
        self.result_selected: Optional[dict] = None
        self._df = df_report; self._mrf_name = mrf_name
        self._checks: dict[str, dict[str, QCheckBox]] = {}

        self._mrf_rf_canonical: set[str] = set()
        if mrf_name and mrf_name in MRF_TO_RF:
            for rf in MRF_TO_RF[mrf_name]:
                self._mrf_rf_canonical.add(norm_text(map_rf(rf)))
        self._mrf_norm = norm_text(mrf_name)

        layout = QVBoxLayout(self); layout.setContentsMargins(0,0,0,0)
        layout.addWidget(make_header(
            f"Фильтры — МРФ {fmt_mrf(mrf_name)}" if mrf_name else "Выбор фильтров"))

        hint = QLabel("  Выберите дату и нужные значения. Фильтр по УСЛУГЕ обязателен.")
        hint.setStyleSheet(f"background:{BG_PANEL};color:{HINT};font-size:9pt;padding:6px 12px;")
        layout.addWidget(hint); layout.addWidget(sep())

        scroll = QScrollArea(); scroll.setWidgetResizable(True); scroll.setFrameShape(QFrame.NoFrame)
        container = QWidget(); cl = QVBoxLayout(container)
        cl.setSpacing(6); cl.setContentsMargins(12,8,12,8)

        # ── Дата ──────────────────────────────────────────────
        date_box = QGroupBox("⚠ Дата индексации — ОБЯЗАТЕЛЬНО выберите!")
        date_box.setStyleSheet(f"QGroupBox{{color:{RED};border:1px solid {RED};}}")
        dl = QVBoxLayout(date_box)
        self._date_combo = QComboBox()
        if RPT_COL_DATE in df_report.columns:
            raw = df_report[RPT_COL_DATE].dropna().unique()
            dates = sorted(set(norm_date(d) for d in raw if norm_date(d)),
                           key=lambda d: pd.to_datetime(d, dayfirst=True, errors="coerce"))
            self._date_combo.addItem("(выберите дату)")
            self._date_combo.addItems(dates)
        dl.addWidget(self._date_combo)
        hint_d = QLabel("Выберите дату — без неё применить фильтры невозможно")
        hint_d.setStyleSheet(f"color:{RED};font-size:9pt;"); dl.addWidget(hint_d)
        cl.addWidget(date_box)

        # ── Остальные колонки ─────────────────────────────────
        cols = [c for c in [RPT_COL_SERVICE, RPT_COL_MRF, RPT_COL_RF,
                             RPT_COL_SEGMENT, RPT_COL_SUBSEG] if c in df_report.columns]
        for col in cols:
            is_svc = (col == RPT_COL_SERVICE)
            title  = f"⚠  {col}  — выберите обязательно!" if is_svc else f"  {col}"
            box = QGroupBox(title)
            if is_svc:
                box.setStyleSheet(f"QGroupBox{{color:{RED};border:1px solid {RED};}}")
            bl2 = QVBoxLayout(box)

            br = QHBoxLayout()
            sel_all = sec_btn("✓ Выбрать все"); sel_all.setFixedHeight(26)
            des_all = sec_btn("✗ Снять все");   des_all.setFixedHeight(26)
            br.addWidget(sel_all); br.addWidget(des_all); br.addStretch()
            bl2.addLayout(br)

            if col == RPT_COL_RF and mrf_name:
                lbl = QLabel(f"  ✅ Автоматически выбраны РФ МРФ {fmt_mrf(mrf_name)}")
                lbl.setStyleSheet(f"color:{GREEN};font-size:9pt;"); bl2.addWidget(lbl)
            if col == RPT_COL_MRF and mrf_name:
                lbl = QLabel(f"  ✅ Автоматически выбран МРФ {fmt_mrf(mrf_name)}")
                lbl.setStyleSheet(f"color:{GREEN};font-size:9pt;"); bl2.addWidget(lbl)

            values = self._make_values(col)
            self._checks[col] = {}
            grid = QWidget(); gl = QGridLayout(grid); gl.setSpacing(2)
            for idx, val in enumerate(values):
                r, c = divmod(idx, 3)
                default = self._auto_check(col, val)
                cb = QCheckBox(val); cb.setChecked(default)
                self._checks[col][val] = cb; gl.addWidget(cb, r, c)
            bl2.addWidget(grid)

            checks_ref = self._checks[col]
            sel_all.clicked.connect(lambda _, d=checks_ref: [cb.setChecked(True)  for cb in d.values()])
            des_all.clicked.connect(lambda _, d=checks_ref: [cb.setChecked(False) for cb in d.values()])
            cl.addWidget(box)

        cl.addStretch(); scroll.setWidget(container); layout.addWidget(scroll)
        layout.addWidget(sep())

        act = QWidget(); al = QHBoxLayout(act); al.setContentsMargins(16,8,16,8)
        apply_btn = QPushButton("Применить фильтры →")
        apply_btn.clicked.connect(self._apply)
        clear_btn = sec_btn("Сбросить всё"); clear_btn.clicked.connect(self._clear)
        cancel_btn = danger_btn("Отмена"); cancel_btn.clicked.connect(self.reject)
        al.addWidget(apply_btn); al.addWidget(clear_btn)
        al.addWidget(cancel_btn); al.addStretch()
        layout.addWidget(act)

        self.setWindowFlag(Qt.WindowCloseButtonHint, True)
        self.rejected.connect(self._on_reject)

    def _on_reject(self) -> None:
        self.result_date = None; self.result_selected = None

    def _make_values(self, col: str) -> list[str]:
        s = self._df[col].dropna()
        if col == RPT_COL_RF:
            all_v = sorted(set(unmap_rf(map_rf(x)) for x in s if str(x).strip()))
            if self._mrf_rf_canonical:
                flt = [v for v in all_v if norm_text(map_rf(v)) in self._mrf_rf_canonical]
                return flt if flt else all_v
            return all_v
        if col == RPT_COL_MRF:
            return sorted(set(fmt_mrf(v) for v in s if str(v).strip()))
        if col == RPT_COL_SERVICE:
            return sorted(set(fmt_service(str(v).strip()) for v in s if str(v).strip()))
        if col in (RPT_COL_SEGMENT, RPT_COL_SUBSEG):
            return sorted(set(fmt_seg(norm_text(v)) for v in s if str(v).strip()))
        return sorted(set(norm_text(v) for v in s if norm_text(v)))

    def _auto_check(self, col: str, val: str) -> bool:
        if col == RPT_COL_RF:
            return norm_text(map_rf(val)) in self._mrf_rf_canonical
        if col == RPT_COL_MRF:
            return fmt_mrf(val).lower() == self._mrf_norm or val == fmt_mrf(self._mrf_name)
        return False

    def _apply(self) -> None:
        if self._date_combo.currentText() == "(выберите дату)":
            QMessageBox.warning(self, "Внимание", "Выберите дату индексации!")
            return
        svc_checks = self._checks.get(RPT_COL_SERVICE, {})
        if svc_checks and not any(cb.isChecked() for cb in svc_checks.values()):
            QMessageBox.warning(self, "Внимание",
                "Выберите хотя бы одну УСЛУГУ!\nБез фильтра данные запишутся во все строки.")
            return
        self.result_date = self._date_combo.currentText()
        selected: dict[str, list[str]] = {}
        for col, checks in self._checks.items():
            vals = [v for v, cb in checks.items() if cb.isChecked()]
            if col == RPT_COL_MRF:      vals = [norm_text(v) for v in vals]
            elif col == RPT_COL_RF:     vals = [norm_text(map_rf(v)) for v in vals]
            elif col == RPT_COL_SERVICE: vals = [norm_text(v) for v in vals]
            elif col in (RPT_COL_SEGMENT, RPT_COL_SUBSEG): vals = [norm_text(v) for v in vals]
            if vals: selected[col] = vals
        self.result_selected = selected
        self.accept()

    def _clear(self) -> None:
        self._date_combo.setCurrentIndex(0)
        for checks in self._checks.values():
            for cb in checks.values(): cb.setChecked(False)


class SessionBuilderDialog(QDialog):
    """
    Мастер настройки сессии — собирает все параметры:
    месяц, МРФ, отчёт, базы + фильтры для каждой базы.
    Результат: dict готовый для CalcWorker.
    """
    def __init__(self, parent=None) -> None:
        super().__init__(parent)
        self.setWindowTitle("Настройка сессии")
        self.resize(500, 200); self.setStyleSheet(STYLESHEET)
        self.result_params: Optional[dict] = None

        layout = QVBoxLayout(self); layout.setContentsMargins(0,0,0,0)
        layout.addWidget(make_header("Настройка сессии расчёта"))
        body = QWidget(); bl = QVBoxLayout(body); bl.setContentsMargins(24,16,24,16)
        bl.addWidget(QLabel("Нажмите «Начать» — программа проведёт вас шаг за шагом."))
        bl.addSpacing(12)
        ok_btn = QPushButton("Начать →"); ok_btn.clicked.connect(self._build)
        bl.addWidget(ok_btn); layout.addWidget(body)

    def _build(self) -> None:
        parent = self.parent()

        # Шаг 1: месяц
        dlg = MonthDialog(parent)
        if dlg.exec_() != QDialog.Accepted: return
        month = dlg.result_month

        # Шаг 2: МРФ
        dlg2 = MRFDialog(parent)
        if dlg2.exec_() != QDialog.Accepted: return
        chosen_mrf = dlg2.chosen

        # Шаг 3: отчёт
        table3_path, _ = QFileDialog.getOpenFileName(
            parent, "Выберите файл отчёта (Таблица 3)",
            os.path.expanduser("~/Desktop"), "Excel files (*.xlsx)")
        if not table3_path: return

        try:
            df_head = pd.read_excel(table3_path, sheet_name=SHEET_TABLE3, nrows=0)
        except Exception as e:
            QMessageBox.critical(parent, "Ошибка", f"Не могу открыть отчёт:\n{e}"); return

        target_col = next(
            (col for col in df_head.columns
             if month in str(col).lower()
             and all(kw in str(col).lower() for kw in TARGET_KEYWORDS)), None)
        if not target_col:
            QMessageBox.critical(parent, "Ошибка",
                f"Нет целевой колонки для '{month}'.\n"
                f"Колонка должна содержать: {TARGET_KEYWORDS}"); return

        # Загружаем df_report для FilterDialog
        # Загружаем только нужные колонки для показа фильтров
        try:
            _filter_cols = [RPT_COL_DATE, RPT_COL_SERVICE, RPT_COL_MRF,
                            RPT_COL_RF, RPT_COL_SEGMENT, RPT_COL_SUBSEG]
            _avail = [c for c in df_head.columns
                      if any(fc.lower() == str(c).lower() for fc in _filter_cols)]
            df_report = pd.read_excel(table3_path, sheet_name=SHEET_TABLE3,
                                      usecols=_avail if _avail else None)
        except Exception as e:
            QMessageBox.critical(parent, "Ошибка", f"Ошибка загрузки отчёта:\n{e}"); return

        # Шаг 4: базы для каждого МРФ
        bases: dict[str, list[dict]] = {}
        filters: dict[str, dict] = {}
        total_bases = 0
        amount_col  = f"Без НДС {month}"

        for mrf in chosen_mrf:
            bases[mrf] = []
            base_num = 0

            while True:
                base_num += 1
                reply = QMessageBox.question(
                    parent, f"МРФ {fmt_mrf(mrf)}",
                    f"Загрузить базу #{base_num} для МРФ {fmt_mrf(mrf)}?",
                    QMessageBox.Yes | QMessageBox.No)
                if reply != QMessageBox.Yes: break

                base_path, _ = QFileDialog.getOpenFileName(
                    parent, f"База #{base_num} — МРФ {fmt_mrf(mrf)}",
                    os.path.expanduser("~/Desktop"), "Excel files (*.xlsx)")
                if not base_path: break

                try:
                    df_tmp = pd.read_excel(base_path, sheet_name=SHEET_TABLE2, nrows=5)
                except Exception as e:
                    QMessageBox.critical(parent, "Ошибка", f"Не могу открыть базу:\n{e}"); continue

                # Режим
                mode_dlg = ChargesModeDialog(os.path.basename(base_path), mrf, parent)
                if mode_dlg.exec_() != QDialog.Accepted: continue
                charges_mode = mode_dlg.mode

                # Колонка ДО
                col_dlg = ColumnDialog(list(df_tmp.columns),
                    f"МРФ {fmt_mrf(mrf)} — база #{base_num}: начисление ДО",
                    "Выберите колонку с НАЧИСЛЕНИЕМ ДО ИНДЕКСАЦИИ:", parent)
                if col_dlg.exec_() != QDialog.Accepted: continue
                base_col = col_dlg.selected

                id_col = current_col = charges_path = None

                if charges_mode == MODE_EXTERNAL:
                    possible = ["MSISDN",
                        "Уникальный идентификационный номер услуги (ШПД, VPN - логин порта)",
                        "Уникальный идентификационный номер услуги", "MSISDN/Логин"]
                    id_col = next((c for c in possible if c in df_tmp.columns), None)
                    if not id_col:
                        id_dlg = ColumnDialog(list(df_tmp.columns),
                            f"МРФ {fmt_mrf(mrf)}: MSISDN",
                            "Выберите колонку с MSISDN/логином:", parent)
                        if id_dlg.exec_() != QDialog.Accepted: continue
                        id_col = id_dlg.selected

                    charges_path, _ = QFileDialog.getOpenFileName(
                        parent, f"Начисления — МРФ {fmt_mrf(mrf)}",
                        os.path.expanduser("~/Desktop"), "Excel files (*.xlsx)")
                    if not charges_path: continue

                    # Проверяем колонку amount_col
                    try:
                        df_chk = pd.read_excel(charges_path, sheet_name=SHEET_TABLE1, nrows=1)
                        if amount_col not in df_chk.columns:
                            QMessageBox.warning(parent, "Внимание",
                                f"В файле начислений нет колонки '{amount_col}'.")
                    except Exception: pass
                else:
                    cur_dlg = ColumnDialog(list(df_tmp.columns),
                        f"МРФ {fmt_mrf(mrf)} — база #{base_num}: ТЕКУЩЕЕ начисление",
                        "Выберите колонку с ТЕКУЩИМ НАЧИСЛЕНИЕМ:", parent)
                    if cur_dlg.exec_() != QDialog.Accepted: continue
                    current_col = cur_dlg.selected

                # Фильтры
                flt_dlg = FilterDialog(df_report, mrf_name=mrf, parent=parent)
                if flt_dlg.exec_() != QDialog.Accepted: continue
                if not flt_dlg.result_date: continue

                fkey = f"{mrf}_{base_num}"
                filters[fkey] = {
                    "date":     flt_dlg.result_date,
                    "segments": flt_dlg.result_selected or {},
                }
                bases[mrf].append({
                    "base_path":    base_path,
                    "charges_mode": charges_mode,
                    "base_col":     base_col,
                    "id_col":       id_col,
                    "current_col":  current_col,
                    "charges_path": charges_path,
                })
                total_bases += 1

                reply2 = QMessageBox.question(
                    parent, "Ещё одна база?",
                    f"МРФ {fmt_mrf(mrf)}, база #{base_num} настроена.\n"
                    "Добавить ещё одну базу для этого МРФ?",
                    QMessageBox.Yes | QMessageBox.No)
                if reply2 != QMessageBox.Yes: break

        if total_bases == 0:
            QMessageBox.warning(parent, "Нет баз", "Не задано ни одной базы.")
            return

        sid = datetime.now().strftime("%Y%m%d_%H%M%S")
        self.result_params = {
            "session_id":  sid,
            "month":       month,
            "chosen_mrf":  chosen_mrf,
            "table3_path": table3_path,
            "target_col":  target_col,
            "bases":       bases,
            "filters":     filters,
            "total_bases": total_bases,
            "completed":   [],
        }
        self.accept()


class ResumeDialog(QDialog):
    """Диалог выбора сессии для восстановления."""
    def __init__(self, sessions: list[tuple], parent=None) -> None:
        super().__init__(parent)
        self.setWindowTitle("Восстановление сессии")
        self.resize(600, 350); self.setStyleSheet(STYLESHEET)
        self.chosen_sid: Optional[str] = None

        layout = QVBoxLayout(self); layout.setContentsMargins(0,0,0,0)
        layout.addWidget(make_header("Выберите сессию для восстановления"))
        body = QWidget(); bl = QVBoxLayout(body); bl.setContentsMargins(16,12,16,12)
        bl.addWidget(QLabel("Доступные сессии (от новых к старым):"))
        self._list = QListWidget()
        db = get_temp_db()
        for sid, month, mrfs, updated_at in sessions:
            ckp = db.load_checkpoint(sid)
            done = len(ckp["completed"]) if ckp else 0
            self._list.addItem(
                f"{updated_at[:16]}  |  {month}  |  "
                f"{', '.join(mrfs)}  |  выполнено: {done} баз")
        self._sessions = sessions
        self._list.itemDoubleClicked.connect(self._pick)
        bl.addWidget(self._list)
        brow = QHBoxLayout()
        ok_btn = QPushButton("Восстановить →"); ok_btn.clicked.connect(self._pick)
        cancel = sec_btn("Отмена"); cancel.clicked.connect(self.reject)
        brow.addWidget(ok_btn); brow.addWidget(cancel); brow.addStretch()
        bl.addLayout(brow); layout.addWidget(body)

    def _pick(self) -> None:
        idx = self._list.currentRow()
        if idx < 0: return
        self.chosen_sid = self._sessions[idx][0]; self.accept()

