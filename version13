def main() -> None:
    try:
        app = QApplication(sys.argv)
        app.setStyle("Fusion")
        app.setStyleSheet(STYLESHEET)
        MainWindow()
        sys.exit(app.exec_())
    except KeyboardInterrupt:
        print("\nПрограмма остановлена.")
        sys.exit(0)
    except Exception as e:
        import traceback
        print("=" * 55)
        print("ОШИБКА ЗАПУСКА ПРОГРАММЫ:")
        print("=" * 55)
        traceback.print_exc()
        print("=" * 55)
        input("Нажмите Enter чтобы закрыть...")


if __name__ == "__main__":
    # ──────────────────────────────────────────────────────────
    # IDLE + PyQt5 конфликтуют — у них разные event loop-ы.
    # Решение: если запущены из IDLE — используем os.startfile()
    # который запускает файл через Windows Shell как отдельный
    # процесс, полностью минуя IDLE. Пользователь видит в IDLE
    # короткое сообщение, а программа открывается в своём окне.
    # ──────────────────────────────────────────────────────────
    if "idlelib" in sys.modules:
        import os
        import subprocess
        import pathlib

        script   = str(pathlib.Path(__file__).resolve())
        python   = r"C:\Program Files\Python312\python.exe"

        # Используем runpy.run_path — он корректно устанавливает __file__
        # и не конфликтует с IDLE event loop
        wrapper = (
            "import sys, traceback, runpy\n"
            f"try:\n"
            f"    runpy.run_path(r'{script}', run_name='__main__')\n"
            f"except SystemExit:\n"
            f"    pass\n"
            f"except Exception:\n"
            f"    traceback.print_exc()\n"
            f"    input('Нажмите Enter...')\n"
        )

        print("=" * 50)
