def calc_pivot_external(df_base: pd.DataFrame, df_amount: pd.DataFrame,
                         base_col: str, id_col: str,
                         amount_col: str, gcols: list[str]) -> pd.DataFrame:
    df_b = df_base.copy();  df_a = df_amount.copy()
    df_b[base_col]     = pd.to_numeric(df_b[base_col],     errors='coerce')
    df_a[amount_col]   = pd.to_numeric(df_a[amount_col],   errors='coerce')
    df_b[id_col]       = df_b[id_col].astype(str).str.strip().str.replace('.0','',regex=False)
    df_a["MSISDN"]     = df_a["MSISDN"].astype(str).str.strip().str.replace('.0','',regex=False)
    merged = df_b.merge(df_a[["MSISDN", amount_col]],
                        left_on=id_col, right_on="MSISDN", how='left')
    del df_b, df_a; gc.collect()
    merged['Эффект_руб'] = (merged[amount_col] - merged[base_col]).clip(lower=0)
    extra = [c for c in [BASE_COL_PCT, BASE_COL_SEGMENT1] if c in merged.columns]
    agg = {'Эффект_руб': 'sum', **{c: 'first' for c in extra}}
    pivot = merged.groupby(gcols, as_index=False).agg(agg)
    pivot['Эффект_тыс'] = (pivot['Эффект_руб'] / 1000).round(3)
    del merged
    return pivot

def calc_pivot_inbase(df_base: pd.DataFrame, base_col: str,
                       current_col: str, gcols: list[str]) -> pd.DataFrame:
    df = df_base.copy()
    df[base_col]    = pd.to_numeric(df[base_col],    errors='coerce')
    df[current_col] = pd.to_numeric(df[current_col], errors='coerce')
    df['Эффект_руб'] = (df[current_col] - df[base_col]).clip(lower=0)
    extra = [c for c in [BASE_COL_PCT, BASE_COL_SEGMENT1] if c in df.columns]
    agg = {'Эффект_руб': 'sum', **{c: 'first' for c in extra}}
    pivot = df.groupby(gcols, as_index=False).agg(agg)
    pivot['Эффект_тыс'] = (pivot['Эффект_руб'] / 1000).round(3)
    del df
    return pivot

def build_new_row(df_report: pd.DataFrame, pivot_row: pd.Series,
                   svc_val: str, selected_date: str, target_col: str,
                   eff: float, pct_lookup: Optional[dict]) -> dict:
    row: dict = {col: None for col in df_report.columns}
    if RPT_COL_SERVICE in row: row[RPT_COL_SERVICE] = fmt_service(svc_val)
    if RPT_COL_DATE in row:
        try:   row[RPT_COL_DATE] = pd.to_datetime(selected_date, dayfirst=True).date()
        except (ValueError, TypeError, OverflowError): row[RPT_COL_DATE] = selected_date
    if RPT_COL_PCT in row:
        pct = None
        if pct_lookup:
            mk = norm_text(pivot_row[BASE_COL_MRF]) if BASE_COL_MRF in pivot_row.index else ""
            rk = map_rf(pivot_row[BASE_COL_RF])     if BASE_COL_RF  in pivot_row.index else ""
            pct = pct_lookup.get((mk, rk))
        if pct is None and BASE_COL_PCT in pivot_row.index:
            pct = fmt_pct(pivot_row[BASE_COL_PCT])
        if pct is not None: row[RPT_COL_PCT] = pct
    if RPT_COL_MRF      in row and BASE_COL_MRF      in pivot_row.index: row[RPT_COL_MRF]      = fmt_mrf(pivot_row[BASE_COL_MRF])
    if RPT_COL_RF       in row and BASE_COL_RF       in pivot_row.index: row[RPT_COL_RF]       = unmap_rf(map_rf(pivot_row[BASE_COL_RF]))
    if RPT_COL_SEGMENT  in row and BASE_COL_SEGMENT  in pivot_row.index: row[RPT_COL_SEGMENT]  = fmt_seg(pivot_row[BASE_COL_SEGMENT])
    if RPT_COL_SEGMENT1 in row and BASE_COL_SEGMENT1 in pivot_row.index: row[RPT_COL_SEGMENT1] = fmt_seg(pivot_row[BASE_COL_SEGMENT1])
    if RPT_COL_SUBSEG   in row and BASE_COL_SUBSEG   in pivot_row.index: row[RPT_COL_SUBSEG]   = fmt_seg(pivot_row[BASE_COL_SUBSEG])
    if target_col in row: row[target_col] = fmt_num3(eff)
    return row

def match_pivot_to_report(pivot: pd.DataFrame, df_report: pd.DataFrame,
                            sel: dict, target_col: str,
                            session_id: str, mrf_name: str, base_num: int,
                            db: TempDB) -> tuple[int, int, int, pd.DataFrame]:
    """Сопоставляет pivot с df_report; все изменения → SQLite."""
    selected_date     = sel.get("date", "")
    selected_segments = sel.get("segments", {})
    selected_services = set(selected_segments.get(RPT_COL_SERVICE, []))

    svc_col = find_col(df_report, RPT_COL_SERVICE)
    if svc_col is None:
        log.warning(f"В отчёте нет колонки '{RPT_COL_SERVICE}'")

    report_dict: dict = defaultdict(list)
    for idx, row in df_report.iterrows():
        rd = norm_date(row[RPT_COL_DATE]) if RPT_COL_DATE in df_report.columns else ""
        if rd != norm_date(selected_date): continue
        svc = norm_text(row[svc_col]) if svc_col else ""
        if selected_services and svc not in selected_services: continue
        mrf_ = norm_text(row[RPT_COL_MRF])    if RPT_COL_MRF    in df_report.columns else ""
        rf_  = map_rf(row[RPT_COL_RF])         if RPT_COL_RF     in df_report.columns else ""
        seg_ = norm_text(row[RPT_COL_SEGMENT]) if RPT_COL_SEGMENT in df_report.columns else ""
        sub_ = norm_text(row[RPT_COL_SUBSEG])  if RPT_COL_SUBSEG in df_report.columns else ""
        report_dict[(svc, mrf_, rf_, seg_, sub_)].append(idx)

    total_rpt = sum(len(v) for v in report_dict.values())

    pivot_ks: set[tuple] = set()
    for _, r in pivot.iterrows():
        pivot_ks.add((
            norm_text(r[BASE_COL_MRF])     if BASE_COL_MRF     in r.index else "",
            map_rf(r[BASE_COL_RF])         if BASE_COL_RF      in r.index else "",
            norm_text(r[BASE_COL_SEGMENT]) if BASE_COL_SEGMENT in r.index else "",
            norm_text(r[BASE_COL_SUBSEG])  if BASE_COL_SUBSEG  in r.index else "",
        ))

    # pct_lookup из отчёта
    pct_col = find_col(df_report, RPT_COL_PCT)
    pct_lookup: dict = {}
    if pct_col and total_rpt > 0:
        for kf, ridxs in report_dict.items():
            mk, rk = kf[1], kf[2]
            for ridx in ridxs:
                v = df_report.loc[ridx, pct_col]
                if pd.notna(v) and str(v).strip() not in ("", "0", "0.0"):
                    pct_lookup[(mk, rk)] = fmt_pct(v); break

    # Строки без совпадения → 0 + жёлтый
    filter_mrfs = set(selected_segments.get(RPT_COL_MRF, []))
    filter_rfs  = set(selected_segments.get(RPT_COL_RF,  []))
    nf_count = 0
    if total_rpt > 0:
        if target_col in df_report.columns:
            df_report[target_col] = df_report[target_col].astype(object)
        for kf, ridxs in report_dict.items():
            rmrf, rrf = kf[1], kf[2]
            if filter_mrfs and rmrf not in filter_mrfs: continue
            if filter_rfs  and rrf  not in filter_rfs:  continue
            if (rmrf, rrf, kf[3], kf[4]) not in pivot_ks:
                for ridx in ridxs:
                    try:
                        cur = df_report.loc[ridx, target_col]
                        if pd.isna(cur):
                            df_report.loc[ridx, target_col] = 0
                    except (TypeError, KeyError, IndexError): pass
                    db.save_update(session_id, mrf_name, base_num,
                                   ridx, target_col, 0, "not_found")
                    nf_count += 1

    updated = added_c = 0
    new_rows: list[dict] = []   # накапливаем новые строки, concat один раз в конце
    svcs_check = selected_services if selected_services else {k[0] for k in report_dict}
    if total_rpt == 0: svcs_check = set()   # type: ignore

    for _, pr in pivot.iterrows():
        mrf_ = norm_text(pr[BASE_COL_MRF])     if BASE_COL_MRF     in pr.index else ""
        rf_  = map_rf(pr[BASE_COL_RF])          if BASE_COL_RF      in pr.index else ""
        seg_ = norm_text(pr[BASE_COL_SEGMENT])  if BASE_COL_SEGMENT in pr.index else ""
        sub_ = norm_text(pr[BASE_COL_SUBSEG])   if BASE_COL_SUBSEG  in pr.index else ""

        ok = True
        for fc, fv in selected_segments.items():
            if   fc == RPT_COL_SERVICE: continue
            elif fc == RPT_COL_MRF     and mrf_ not in fv: ok = False; break
            elif fc == RPT_COL_RF      and rf_  not in fv: ok = False; break
            elif fc == RPT_COL_SEGMENT and seg_ not in fv: ok = False; break
            elif fc == RPT_COL_SUBSEG  and sub_ not in fv: ok = False; break
        if not ok: continue

        eff = pr['Эффект_тыс']

        if total_rpt > 0:
            sc_list = list(svcs_check) if svcs_check else [None]
            found = False
            for svc in sc_list:
                key = (svc, mrf_, rf_, seg_, sub_)
                if key in report_dict:
                    for ridx in report_dict[key]:
                        df_report.loc[ridx, target_col] = eff
                        db.save_update(session_id, mrf_name, base_num,
                                       ridx, target_col, eff, "updated")
                        updated += 1
                    found = True
            if not found:
                kns = (mrf_, rf_, seg_, sub_)
                ex = {(k[1],k[2],k[3],k[4]) for k in report_dict}
                if kns in ex:
                    for kf2, ridxs in report_dict.items():
                        if (kf2[1],kf2[2],kf2[3],kf2[4]) == kns:
                            for ridx in ridxs:
                                df_report.loc[ridx, target_col] = eff
                                db.save_update(session_id, mrf_name, base_num,
                                               ridx, target_col, eff, "updated")
                                updated += 1
                            found = True; break
            if not found:
                svc_v = list(svcs_check)[0] if svcs_check else ""
                new_row = build_new_row(df_report, pr, svc_v, selected_date,
                                         target_col, eff, pct_lookup)
                new_rows.append(new_row)
                added_c += 1
        else:
            svc_v = (str(pr[BASE_COL_SERVICE]).strip()
                     if BASE_COL_SERVICE in pr.index and pd.notna(pr[BASE_COL_SERVICE])
                     else (list(selected_services)[0] if selected_services else ""))
            new_row = build_new_row(df_report, pr, svc_v, selected_date,
                                     target_col, eff, pct_lookup)
            new_rows.append(new_row)
            added_c += 1

    # Один concat в конце — O(n) вместо O(n²)
    if new_rows:
        df_new = pd.DataFrame(new_rows)
        df_report = pd.concat([df_report, df_new], ignore_index=True)
        # Сохраняем индексы новых строк в SQLite
        start_idx = len(df_report) - len(new_rows)
        for i in range(len(new_rows)):
            ridx = start_idx + i
            eff_val = new_rows[i].get(target_col, 0)
            db.save_update(session_id, mrf_name, base_num,
                           ridx, target_col, eff_val, "added")
        del df_new

    db.flush()
    return updated, added_c, nf_count, df_report

# ══════════════════════════════════════════════════════════════
#  WORKER — РАСЧЁТ В ОТДЕЛЬНОМ QThread
# ══════════════════════════════════════════════════════════════

class CalcWorker(QObject):
    """Весь расчёт идёт вне UI-потока."""
    log_msg  = pyqtSignal(str)
    progress = pyqtSignal(int, int, str)
    finished = pyqtSignal(dict)
    error    = pyqtSignal(str)

    def __init__(self, params: dict) -> None:
        super().__init__()
        self.params          = params
        self._stopped        = False
        self._bases_since_gc = 0     # счётчик баз до следующего gc.collect()
        self._start_time: Optional[datetime] = None  # для расчёта оставшегося времени

    def stop(self) -> None:
        self._stopped = True

    def _log(self, msg: str) -> None:
        log.info(msg); self.log_msg.emit(msg)

    def _check_mem(self) -> None:
        mb = memory_mb()
        if mb > MEMORY_WARN_MB:
            self._log(f"  ⚠️  RAM {mb:.0f} МБ — запускаем GC...")
            gc.collect()
            self._log(f"  ✓  RAM после GC: {memory_mb():.0f} МБ")

    def run(self) -> None:
        _ui_log_handler.set_worker(self)   # log.warning → UI
        try:
            self._run_session()
        except Exception as e:
            log.exception("Ошибка CalcWorker")
            self.error.emit(str(e))
        finally:
            _ui_log_handler.set_worker(None)

    def _run_session(self) -> None:
        p           = self.params
        sid         = p["session_id"]
        month       = p["month"]
        chosen_mrf  = p["chosen_mrf"]
        table3_path = p["table3_path"]
        target_col  = p["target_col"]
        amount_col  = f"Без НДС {month}"
        completed: list[tuple[str, int]] = p.get("completed", [])

        db = get_temp_db()
        session_counts = {"matched": 0, "added": 0, "not_found": 0}
        session_summary: list[str] = []

        self._start_time = datetime.now()
        self._log(f"\n{'='*55}\nСЕССИЯ {sid}  |  Месяц: {month}\n{'='*55}")
        self._log(f"МРФ: {', '.join(chosen_mrf)}")
        self._log(f"Уже обработано: {len(completed)} баз")
        self._check_mem()

        # Загружаем отчёт один раз
        self._log("\n⏳ Загрузка отчёта...")
        t0 = datetime.now()
        try:
            df_report = pd.read_excel(table3_path, sheet_name=SHEET_TABLE3)
        except MemoryError:
            self.error.emit("Недостаточно памяти для загрузки отчёта.\n"
                            "Закройте другие приложения и повторите.")
            return
        except Exception as e:
            self.error.emit(f"Ошибка загрузки отчёта: {e}")
            return
        self._log(f"   ✓ {len(df_report):,} строк ({(datetime.now()-t0).total_seconds():.1f} сек)")
        self._check_mem()

        total_bases = p.get("total_bases", 1)
        processed   = 0

        for mrf_name in chosen_mrf:
            if self._stopped: break
            self._log(f"\n{'#'*55}\nМРФ: {fmt_mrf(mrf_name).upper()}\n{'#'*55}")

            df_report, mrf_sum = self._process_mrf(
                db, sid, mrf_name, df_report, month, amount_col, target_col,
                session_counts, completed, processed, total_bases)

            session_summary.extend(mrf_sum)
            processed += 1
            self._check_mem()
            db.save_checkpoint(sid, month, chosen_mrf, table3_path,
                                target_col, completed)

        # Финальная нормализация и сохранение Excel
        self._log("\n⏳ Финальная запись отчёта...")
        self._finalize(db, sid, df_report, target_col, table3_path)

        self.finished.emit({
            "session_id": sid, "month": month,
            "summary":    session_summary,
            "counts":     session_counts,
        })

    def _process_mrf(self, db: TempDB, sid: str, mrf_name: str,
                      df_report: pd.DataFrame, month: str,
                      amount_col: str, target_col: str,
                      session_counts: dict,
                      completed: list, processed: int,
                      total_bases: int) -> tuple[pd.DataFrame, list[str]]:
        summary: list[str] = []
        mrf_upd = mrf_add = 0; mrf_eff = 0.0
        bases_cfg = self.params.get("bases", {}).get(mrf_name, [])

        for base_num_0, base_cfg in enumerate(bases_cfg, 1):
            if self._stopped: break
            if (mrf_name, base_num_0) in completed:
                self._log(f"  ⏭️  База #{base_num_0} уже выполнена — пропускаем")
                continue

            base_path    = base_cfg["base_path"]
            charges_mode = base_cfg["charges_mode"]
            base_col     = base_cfg["base_col"]
            id_col       = base_cfg.get("id_col")
            current_col  = base_cfg.get("current_col")
            charges_path = base_cfg.get("charges_path")
            sel          = self.params.get("filters", {}).get(
                               f"{mrf_name}_{base_num_0}", {})

            base_name = os.path.basename(base_path)
            self._log(f"\n  БАЗА #{base_num_0}: {base_name}")
            self._log(f"  Режим: {'📂 внешний файл' if charges_mode==MODE_EXTERNAL else '📊 в базе'}")
            # Расчёт оставшегося времени
            cur_idx   = processed * 100 + base_num_0
            total_idx = total_bases * 100
            elapsed   = (datetime.now() - self._start_time).total_seconds() if self._start_time else 0
            rate      = cur_idx / elapsed if elapsed > 0 and cur_idx > 0 else 0
            remaining = int((total_idx - cur_idx) / rate) if rate > 0 else 0
            if remaining > 3600:
                rem_str = f"{remaining // 3600}ч {(remaining % 3600) // 60}мин"
            elif remaining > 60:
                rem_str = f"{remaining // 60}мин {remaining % 60}сек"
            else:
                rem_str = f"{remaining}сек" if remaining > 0 else "—"
            self.progress.emit(
                cur_idx, total_idx,
                f"{fmt_mrf(mrf_name)} | База #{base_num_0} | осталось: {rem_str}")

            # Загрузка базы
            self._log("  ⏳ Загрузка базы...")
            t = datetime.now()
            try:
                df_base = pd.read_excel(base_path, sheet_name=SHEET_TABLE2)
            except Exception as e:
                self._log(f"  ❌ {e}")
                summary.append(f"    База #{base_num_0} ({base_name}): ОШИБКА — {e}")
                continue
            self._log(f"  ✓ {len(df_base):,} строк ({(datetime.now()-t).total_seconds():.1f} сек)")

            # Загрузка начислений
            df_amount: Optional[pd.DataFrame] = None
            if charges_mode == MODE_EXTERNAL:
                if not charges_path:
                    self._log("  ❌ Путь к файлу начислений не задан")
                    continue
                self._log(f"  ⏳ Загрузка начислений...")
                t = datetime.now()
                try:
                    df_amount = pd.read_excel(charges_path, sheet_name=SHEET_TABLE1)
                except Exception as e:
                    self._log(f"  ❌ {e}"); continue
                self._log(f"  ✓ {len(df_amount):,} строк ({(datetime.now()-t).total_seconds():.1f} сек)")
                if amount_col not in df_amount.columns:
                    self._log(f"  ❌ Нет колонки '{amount_col}'"); continue
                if "MSISDN" not in df_amount.columns:
                    self._log("  ❌ Нет колонки 'MSISDN'"); continue

            # Расчёт pivot
            self._log("  ⏳ Расчёт эффекта...")
            t_calc = datetime.now()
            gcols = [c for c in [BASE_COL_MRF, BASE_COL_RF,
                                  BASE_COL_SEGMENT, BASE_COL_SUBSEG,
                                  BASE_COL_SEGMENT1] if c in df_base.columns]
            try:
                if charges_mode == MODE_EXTERNAL:
                    pivot = calc_pivot_external(df_base, df_amount,
                                               base_col, id_col, amount_col, gcols)
                else:
                    pivot = calc_pivot_inbase(df_base, base_col, current_col, gcols)
            except Exception as e:
                self._log(f"  ❌ Ошибка расчёта: {e}")
                summary.append(f"    База #{base_num_0} ({base_name}): ОШИБКА расчёта")
                continue
            finally:
                # Освобождаем начисления сразу после расчёта
                del df_amount; gc.collect()

            calc_sec = (datetime.now() - t_calc).total_seconds()
            self._log(f"  ✓ Групп: {len(pivot)}, "
                      f"эффект: {pivot['Эффект_тыс'].sum():,.3f} тыс. руб. "
                      f"({calc_sec:.1f} сек)")
            self._check_mem()

            # Pivot → SQLite (освобождаем RAM)
            db.save_pivot(sid, mrf_name, base_num_0, pivot)

            # Сопоставление
            if not sel:
                self._log("  ⚠️  Фильтры не заданы для этой базы — пропускаем")
                del pivot; gc.collect(); continue

            self._log("  ⏳ Сопоставление с отчётом...")
            t_match = datetime.now()
            upd, add, nf, df_report = match_pivot_to_report(
                pivot, df_report, sel, target_col,
                sid, mrf_name, base_num_0, db)

            msec = (datetime.now() - t_match).total_seconds()
            self._log(f"  ✓ Записано: {upd} | Добавлено: {add} | "
                      f"Не найдено: {nf} | ⏱ {msec:.1f} сек")

            session_counts["matched"]   += upd
            session_counts["added"]     += add
            session_counts["not_found"] += nf
            mrf_upd += upd; mrf_add += add; mrf_eff += pivot['Эффект_тыс'].sum()

            mode_str = "📂 внешний" if charges_mode == MODE_EXTERNAL else "📊 в базе"
            summary.append(
                f"    База #{base_num_0} ({base_name}) [{mode_str}]:\n"
                f"      Записано: {upd} | Добавлено: {add} | "
                f"Эффект: {pivot['Эффект_тыс'].sum():,.3f} тыс. руб.")

            completed.append((mrf_name, base_num_0))
            db.save_checkpoint(sid, month, self.params["chosen_mrf"],
                                self.params["table3_path"],
                                self.params["target_col"], completed)

            # Pivot больше не нужен в RAM
            del pivot
            # GC раз в 5 баз или при превышении порога — не после каждой
            self._bases_since_gc += 1
            if self._bases_since_gc >= 5:
                gc.collect()
                self._bases_since_gc = 0
                self._log(f"  🔵 RAM после GC: {memory_mb():.0f} МБ")
            elif memory_mb() > MEMORY_WARN_MB:
                self._check_mem()

        # После завершения МРФ — один GC
        self._log(f"\n  ✓ МРФ {fmt_mrf(mrf_name)} завершён.")
        gc.collect()
        self._log(f"  🔵 RAM: {memory_mb():.0f} МБ")

        return df_report, (
            [f"\n  МРФ {fmt_mrf(mrf_name)}:"] + summary +
            [f"    ИТОГО: записано {mrf_upd}, добавлено {mrf_add}, "
             f"эффект {mrf_eff:,.3f} тыс. руб."]
        )

    def _finalize(self, db: TempDB, sid: str,
                   df_report: pd.DataFrame, target_col: str,
                   save_path: str) -> None:
        """Применяет обновления из SQLite, нормализует, пишет Excel."""
        self._log("  ⏳ Применение обновлений из SQLite (пачками)...")
        if target_col in df_report.columns:
            df_report[target_col] = df_report[target_col].astype(object)

        matched_rows: list[int] = []
        added_rows:   list[int] = []
        nf_rows:      list[int] = []

        for chunk in db.iter_updates(sid):
            for ridx, col_name, new_value, fill_type in chunk:
                if ridx < len(df_report):
                    try:    val: Any = float(new_value)
                    except (ValueError, TypeError): val = new_value
                    if new_value not in ("None", ""): df_report.loc[ridx, col_name] = val
                if   fill_type == "updated":   matched_rows.append(ridx)
                elif fill_type == "added":     added_rows.append(ridx)
                elif fill_type == "not_found": nf_rows.append(ridx)

        self._log(f"  ✓ Применено обновлений: {len(matched_rows)+len(added_rows)+len(nf_rows)}")
        self._log("  ⏳ Нормализация...")
        for rpt_col, fn in [
            (RPT_COL_SERVICE, fmt_service), (RPT_COL_MRF, fmt_mrf),
            (RPT_COL_RF, fmt_title),        (RPT_COL_SEGMENT, fmt_seg),
            (RPT_COL_SUBSEG, fmt_seg),      (RPT_COL_SEGMENT1, fmt_seg),
        ]:
            real = find_col(df_report, rpt_col)
            if real:
                df_report[real] = df_report[real].apply(
                    lambda x, f=fn: f(x) if pd.notna(x) and str(x).strip() else x)

        real_date = find_col(df_report, RPT_COL_DATE)
        if real_date:
            df_report[real_date] = df_report[real_date].apply(
                lambda x: pd.to_datetime(x, dayfirst=True, errors="coerce").date()
                          if pd.notna(x) and str(x).strip() else x)

        for rpt_col, fn in [(RPT_COL_PCT, fmt_pct), (target_col, fmt_num3)]:
            real = find_col(df_report, rpt_col)
            if real:
                df_report[real] = df_report[real].apply(
                    lambda x, f=fn: f(x) if pd.notna(x) and str(x).strip() else x)

        self._log("  ⏳ Запись Excel...")
        with pd.ExcelWriter(save_path, engine='openpyxl', mode='w') as writer:
            df_report.to_excel(writer, sheet_name=SHEET_TABLE3, index=False)

        self._log("  ⏳ Заливка цветом...")
        wb = load_workbook(save_path); ws = wb[SHEET_TABLE3]
        grn  = PatternFill(start_color=FILL_UPDATED,   end_color=FILL_UPDATED,   fill_type='solid')
        blue = PatternFill(start_color=FILL_ADDED,     end_color=FILL_ADDED,     fill_type='solid')
        yel  = PatternFill(start_color=FILL_NOT_FOUND, end_color=FILL_NOT_FOUND, fill_type='solid')

        cols = list(df_report.columns)
        ci_t = (cols.index(target_col) + 1) if target_col in cols else 1
        TEXT_COLS = [RPT_COL_SERVICE, RPT_COL_MRF, RPT_COL_RF,
                     RPT_COL_SEGMENT, RPT_COL_SUBSEG, RPT_COL_SEGMENT1]
        FMT = {RPT_COL_DATE: "DD.MM.YYYY", RPT_COL_PCT: "0.00%",
               target_col: "#,##0.000"}

        for rn in range(2, ws.max_row + 1):
            for c_name in TEXT_COLS:
                if c_name in cols:
                    ws.cell(rn, cols.index(c_name) + 1).number_format = "@"
            for c_name, fmt_str in FMT.items():
                if c_name in cols:
                    ws.cell(rn, cols.index(c_name) + 1).number_format = fmt_str

        for ridx in set(matched_rows): ws.cell(ridx + 2, ci_t).fill = grn
        for ridx in set(added_rows):
            for c in range(1, len(cols) + 1): ws.cell(ridx + 2, c).fill = blue
        for ridx in set(nf_rows): ws.cell(ridx + 2, ci_t).fill = yel

        wb.save(save_path)
        self._log(f"  ✓ Сохранено: {os.path.basename(save_path)}")
        self._log(f"     🟢 {len(set(matched_rows))} | "
                  f"🔵 {len(set(added_rows))} | 🟡 {len(set(nf_rows))}")

