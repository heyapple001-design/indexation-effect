    def _show_filters(self):
        """Показывает диалог настройки фильтров"""
        if self.df_report is None:
            QMessageBox.warning(self, "Ошибка", "Сначала загрузите файл отчёта!")
            return
        
        selected_mrf = [cb.text() for cb in self.mrf_checks if cb.isChecked()]
        if not selected_mrf:
            QMessageBox.warning(self, "Ошибка", "Выберите хотя бы один МРФ!")
            return
        
        dialog = FilterDialog(self.df_report, selected_mrf[0], self)
        if dialog.exec_():
            self.filters = dialog.get_filters()
            self.filter_status.setText(f"✅ Фильтры настроены (дата: {self.filters.get('date', '')})")
            self._log(f"🔍 Фильтры применены: {len(self.filters.get('segments', {}))} групп")
        else:
            self.filter_status.setText("Фильтры не настроены")
    
    def _log(self, message):
        """Добавляет сообщение в журнал"""
        timestamp = datetime.now().strftime("%H:%M:%S")
        self.log_text.append(f"[{timestamp}] {message}")
        cursor = self.log_text.textCursor()
        cursor.movePosition(cursor.End)
        self.log_text.setTextCursor(cursor)
        QApplication.processEvents()
    
    def _start_calculation(self):
        """Запуск расчёта"""
        if not self.report_path:
            QMessageBox.warning(self, "Ошибка", "Выберите файл отчёта!")
            return
        
        if not self.base_path:
            QMessageBox.warning(self, "Ошибка", "Выберите файл базы индексации!")
            return
        
        selected_mrf = [cb.text() for cb in self.mrf_checks if cb.isChecked()]
        if not selected_mrf:
            QMessageBox.warning(self, "Ошибка", "Выберите хотя бы один МРФ!")
            return
        
        mode = self.mode_group.checkedId()
        charges_mode = MODE_EXTERNAL if mode == 0 else MODE_INBASE
        
        if charges_mode == MODE_EXTERNAL:
            if not self.charges_path:
                QMessageBox.warning(self, "Ошибка", "Выберите файл начислений!")
                return
            if not self.amount_col_combo.currentText():
                QMessageBox.warning(self, "Ошибка", "Выберите колонку начислений!")
                return
        
        if not self.col_combo.currentText():
            QMessageBox.warning(self, "Ошибка", "Укажите колонку 'до индексации'!")
            return
        
        if not self.filters:
            reply = QMessageBox.question(
                self, "Подтверждение",
                "Фильтры не настроены. Продолжить?\n"
                "Без фильтров данные могут записаться во все строки.",
                QMessageBox.Yes | QMessageBox.No
            )
            if reply == QMessageBox.No:
                return
        
        self.run_btn.setEnabled(False)
        self.run_btn.setText("⏳ Выполняется...")
        self.progress_bar.setValue(0)
        self.progress_label.setText("Начинаем расчёт...")
        
        month = self.month_combo.currentText()
        
        target_col = None
        if self.df_report is not None:
            for col in self.df_report.columns:
                col_lower = str(col).lower()
                if month in col_lower and "эффект" in col_lower and "факт" in col_lower:
                    target_col = col
                    break
        
        if not target_col:
            target_col = f"Эффект от индексации тыс.руб. без НДС {month} 2026 факт"
            self._log(f"⚠️ Целевая колонка не найдена, используем: {target_col}")
        else:
            self._log(f"✅ Найдена целевая колонка: {target_col}")
        
        params = {
            'month': month,
            'mrf_name': selected_mrf[0],
            'report_path': self.report_path,
            'base_path': self.base_path,
            'charges_mode': charges_mode,
            'base_col': self.col_combo.currentText(),
            'target_col': target_col,
            'amount_col': self.amount_col_combo.currentText() if charges_mode == MODE_EXTERNAL else None,
            'charges_path': self.charges_path if charges_mode == MODE_EXTERNAL else None,
            'filters': self.filters
        }
        
        self._log("=" * 60)
        self._log("🚀 ЗАПУСК РАСЧЁТА")
        self._log(f"📅 Месяц: {month}")
        self._log(f"🏢 МРФ: {selected_mrf[0]}")
        self._log(f"📁 Отчёт: {os.path.basename(self.report_path)}")
        self._log(f"📁 База: {os.path.basename(self.base_path)}")
        self._log(f"📋 Колонка 'до': {self.col_combo.currentText()}")
        if charges_mode == MODE_EXTERNAL:
            self._log(f"📋 Колонка начислений: {self.amount_col_combo.currentText()}")
        self._log(f"🎯 Целевая колонка: {target_col}")
        self._log("🔑 КЛЮЧИ СОПОСТАВЛЕНИЯ: Услуга + Дата + МРФ + РФ + Сегмент + Подсегмент")
        self._log("=" * 60)
        
        self.calculation_thread = CalculationThread(params)
        self.calculation_thread.progress.connect(self._on_progress)
        self.calculation_thread.log.connect(self._log)
        self.calculation_thread.finished.connect(self._on_finished)
        self.calculation_thread.error.connect(self._on_error)
        self.calculation_thread.start()
    
    def _on_progress(self, value, message):
        self.progress_bar.setValue(value)
        self.progress_label.setText(message)
        QApplication.processEvents()
    
    def _on_finished(self, result):
        self.run_btn.setEnabled(True)
        self.run_btn.setText("🚀 Начать расчёт")
        self.progress_label.setText("✅ Расчёт завершён!")
        
        self._log("=" * 60)
        self._log("✅ РАСЧЁТ ЗАВЕРШЁН")
        self._log(f"📊 Обновлено строк: {result['matched_count']}")
        self._log(f"📊 Добавлено строк: {result['added_count']}")
        if result['not_found_count']:
            self._log(f"⚠️ Не найдено в базе: {result['not_found_count']}")
        self._log(f"💰 Суммарный эффект: {result['total_effect']:.3f} тыс. руб.")
        self._log(f"💾 Сохранено: {result['save_path']}")
        self._log("=" * 60)
        
        QMessageBox.information(
            self, "Расчёт завершён",
            f"Расчёт успешно завершён!\n\n"
            f"📊 Обновлено строк: {result['matched_count']}\n"
            f"📊 Добавлено строк: {result['added_count']}\n"
            f"💰 Суммарный эффект: {result['total_effect']:.3f} тыс. руб.\n\n"
            f"💾 Сохранено: {os.path.basename(result['save_path'])}"
        )
    
    def _on_error(self, error_msg):
        self.run_btn.setEnabled(True)
        self.run_btn.setText("🚀 Начать расчёт")
        self.progress_label.setText("❌ Ошибка!")
        self._log(f"❌ Ошибка: {error_msg}")
        QMessageBox.critical(self, "Ошибка", f"Произошла ошибка:\n\n{error_msg}")


