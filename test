class FilterDialog(QDialog):
    """Диалог выбора фильтров (дата, услуга, сегменты)"""
    
    def __init__(self, df_report: pd.DataFrame, mrf_name: str, parent=None):
        super().__init__(parent)
        self.setWindowTitle(f"Фильтры — МРФ {mrf_name}")
        self.setMinimumSize(800, 600)
        
        self.df_report = df_report
        self.mrf_name = mrf_name
        self.filters = {}
        
        self._init_ui()
        self._load_data()
    
    def _init_ui(self):
        """Инициализация интерфейса"""
        layout = QVBoxLayout(self)
        
        # Заголовок
        title = QLabel(f"Фильтры — МРФ {self.mrf_name}")
        title.setObjectName("title")
        title.setAlignment(Qt.AlignCenter)
        layout.addWidget(title)
        
        # Дата (обязательная)
        date_group = QGroupBox("📅 Дата индексации — ОБЯЗАТЕЛЬНО!")
        date_group.setStyleSheet("QGroupBox { color: #C42B1C; }")
        date_layout = QHBoxLayout(date_group)
        
        self.date_edit = QDateEdit()
        self.date_edit.setCalendarPopup(True)
        self.date_edit.setDate(QDate.currentDate())
        self.date_edit.setDisplayFormat("dd.MM.yyyy")
        date_layout.addWidget(self.date_edit)
        date_layout.addWidget(QLabel("(выберите дату начала индексации)"))
        date_layout.addStretch()
        
        layout.addWidget(date_group)
        
        # Создаём прокручиваемую область для фильтров
        scroll = QScrollArea()
        scroll.setWidgetResizable(True)
        scroll_widget = QWidget()
        scroll_layout = QVBoxLayout(scroll_widget)
        
        # Фильтры по колонкам
        self.filter_widgets = {}
        
        # Получаем уникальные значения из отчёта для каждой колонки
        cols_to_filter = [
            (RPT_COL_SERVICE, "Услуга", True),  # Обязательная
            (RPT_COL_MRF, "МРФ", False),
            (RPT_COL_RF, "РФ", False),
            (RPT_COL_SEGMENT, "Краткий Сегмент", False),
            (RPT_COL_SUBSEG, "Подсегмент", False)
        ]
        
        for col_name, display_name, required in cols_to_filter:
            if col_name not in self.df_report.columns:
                continue
            
            # Получаем уникальные значения
            values = self.df_report[col_name].dropna().unique()
            values = [str(v).strip() for v in values if str(v).strip()]
            
            if not values:
                continue
            
            # Сортируем
            values = sorted(set(values))
            
            group = QGroupBox(f"{'🔴' if required else '📌'} {display_name}" + 
                             (" — выберите обязательно!" if required else ""))
            if required:
                group.setStyleSheet("QGroupBox { color: #C42B1C; }")
            
            group_layout = QVBoxLayout(group)
            
            # Кнопки "Выбрать все" и "Снять все"
            btn_row = QHBoxLayout()
            select_all_btn = QPushButton("✓ Выбрать все")
            select_all_btn.setObjectName("secondary")
            deselect_all_btn = QPushButton("✗ Снять все")
            deselect_all_btn.setObjectName("secondary")
            btn_row.addWidget(select_all_btn)
            btn_row.addWidget(deselect_all_btn)
            btn_row.addStretch()
            group_layout.addLayout(btn_row)
            
            # Чекбоксы в сетке
            grid = QGridLayout()
            checkboxes = []
            
            for i, val in enumerate(values):
                cb = QCheckBox(val)
                
                # Автоматически выбираем МРФ и РФ текущего МРФ
                if col_name == RPT_COL_MRF and val == self.mrf_name:
                    cb.setChecked(True)
                elif col_name == RPT_COL_RF:
                    # Проверяем, относится ли РФ к текущему МРФ
                    mrf_to_rf = get_mrf_to_rf()
                    if self.mrf_name in mrf_to_rf:
                        rf_list = mrf_to_rf[self.mrf_name]
                        if val in rf_list:
                            cb.setChecked(True)
                
                checkboxes.append(cb)
                row = i // 3
                col = i % 3
                grid.addWidget(cb, row, col)
            
            group_layout.addLayout(grid)
            
            # Сохраняем для доступа
            self.filter_widgets[col_name] = {
                'checkboxes': checkboxes,
                'select_all': select_all_btn,
                'deselect_all': deselect_all_btn,
                'required': required
            }
            
            # Подключаем кнопки
            select_all_btn.clicked.connect(lambda checked, cbs=checkboxes: self._set_all(cbs, True))
            deselect_all_btn.clicked.connect(lambda checked, cbs=checkboxes: self._set_all(cbs, False))
            
            scroll_layout.addWidget(group)
        
        scroll_layout.addStretch()
        scroll.setWidget(scroll_widget)
        layout.addWidget(scroll)
        
        # Кнопки
        btn_layout = QHBoxLayout()
        apply_btn = QPushButton("✅ Применить фильтры")
        apply_btn.clicked.connect(self._apply)
        clear_btn = QPushButton("🔄 Сбросить всё")
        clear_btn.setObjectName("secondary")
        clear_btn.clicked.connect(self._clear_all)
        cancel_btn = QPushButton("❌ Отмена")
        cancel_btn.setObjectName("danger")
        cancel_btn.clicked.connect(self.reject)
        
        btn_layout.addWidget(apply_btn)
        btn_layout.addWidget(clear_btn)
        btn_layout.addWidget(cancel_btn)
        layout.addLayout(btn_layout)
    
    def _set_all(self, checkboxes: List[QCheckBox], state: bool):
        """Устанавливает состояние всех чекбоксов"""
        for cb in checkboxes:
            cb.setChecked(state)
    
    def _clear_all(self):
        """Сбрасывает все фильтры"""
        for col_data in self.filter_widgets.values():
            for cb in col_data['checkboxes']:
                cb.setChecked(False)
        self.date_edit.setDate(QDate.currentDate())
    
    def _load_data(self):
        """Загружает данные для фильтров"""
        pass
    
    def _apply(self):
        """Применяет фильтры"""
        # Проверяем, что выбрана дата
        selected_date = self.date_edit.date().toString("dd.MM.yyyy")
        if not selected_date:
            QMessageBox.warning(self, "Ошибка", "Выберите дату индексации!")
            return
        
        # Проверяем, что выбрана хотя бы одна услуга
        service_widgets = self.filter_widgets.get(RPT_COL_SERVICE)
        if service_widgets:
            selected_services = [cb.text() for cb in service_widgets['checkboxes'] if cb.isChecked()]
            if not selected_services:
                QMessageBox.warning(
                    self, "Ошибка", 
                    "Выберите хотя бы одну УСЛУГУ!\n"
                    "Без фильтра данные запишутся во все строки."
                )
                return
        
        # Собираем выбранные фильтры
        self.filters = {
            'date': selected_date,
            'segments': {}
        }
        
        for col_name, col_data in self.filter_widgets.items():
            selected = [cb.text() for cb in col_data['checkboxes'] if cb.isChecked()]
            if selected:
                # Для МРФ и РФ нормализуем значения
                if col_name == RPT_COL_MRF:
                    selected = [norm_text(v) for v in selected]
                elif col_name == RPT_COL_RF:
                    selected = [norm_text(map_rf(v)) for v in selected]
                elif col_name == RPT_COL_SERVICE:
                    selected = [norm_text(v) for v in selected]
                elif col_name in (RPT_COL_SEGMENT, RPT_COL_SUBSEG):
                    selected = [norm_text(v) for v in selected]
                self.filters['segments'][col_name] = selected
        
        self.accept()
    
    def get_filters(self) -> Dict:
        """Возвращает выбранные фильтры"""
        return self.filters


