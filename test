    def _init_data(self):
        """Инициализация данных"""
        try:
            all_mrf = get_all_mrf()
            mrf_container = None
            for child in self.findChildren(QWidget):
                if child.layout() and isinstance(child.layout(), QGridLayout):
                    if child.parent() and hasattr(child.parent(), 'mrf_checks'):
                        mrf_container = child
                        break
            
            if mrf_container:
                for i in reversed(range(mrf_container.layout().count())):
                    item = mrf_container.layout().itemAt(i)
                    if item and item.widget():
                        item.widget().deleteLater()
                
                self.mrf_checks = []
                cols = 3
                for i, mrf in enumerate(all_mrf):
                    cb = QCheckBox(mrf)
                    self.mrf_checks.append(cb)
                    row = i // cols
                    col = i % cols
                    mrf_container.layout().addWidget(cb, row, col)
        except Exception as e:
            self._log(f"⚠️ Ошибка загрузки справочников: {e}")
    
    def _select_all_mrf(self):
        for cb in self.mrf_checks:
            cb.setChecked(True)
    
    def _deselect_all_mrf(self):
        for cb in self.mrf_checks:
            cb.setChecked(False)
    
