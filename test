    def _load_report_columns(self):
        """Загружает колонки из файла отчёта"""
        if not self.report_path:
            QMessageBox.warning(self, "Ошибка", "Сначала выберите файл отчёта!")
            return
        
        try:
            df = pd.read_excel(self.report_path, sheet_name=SHEET_TABLE3)
            self.df_report = df
            self.col_combo.clear()
            for col in df.columns:
                self.col_combo.addItem(str(col))
            
            month = self.month_combo.currentText()
            for col in df.columns:
                col_lower = str(col).lower()
                if month in col_lower and "начисление" in col_lower:
                    self.col_combo.setCurrentText(str(col))
                    break
            
            self._log(f"✅ Загружено {len(df.columns)} колонок из отчёта")
        except Exception as e:
            self._log(f"❌ Ошибка загрузки колонок: {e}")
            QMessageBox.warning(self, "Ошибка", f"Не удалось загрузить колонки:\n{e}")
    
    def _load_charges_columns(self):
        """Загружает колонки из файла начислений"""
        if not self.charges_path:
            QMessageBox.warning(self, "Ошибка", "Сначала выберите файл начислений!")
            return
        
        try:
            df = pd.read_excel(self.charges_path, sheet_name=SHEET_TABLE1)
            self.df_charges = df
            self.amount_col_combo.clear()
            for col in df.columns:
                self.amount_col_combo.addItem(str(col))
            
            month = self.month_combo.currentText()
            for col in df.columns:
                col_lower = str(col).lower()
                if month in col_lower and ("без ндс" in col_lower or "начисление" in col_lower):
                    self.amount_col_combo.setCurrentText(str(col))
                    break
            
            self.amount_col_combo.setEnabled(True)
            self.load_amount_cols_btn.setEnabled(True)
            self._log(f"✅ Загружено {len(df.columns)} колонок из начислений")
        except Exception as e:
            self._log(f"❌ Ошибка загрузки колонок начислений: {e}")
