class CalculationThread(QThread):
    """Поток для выполнения вычислений без блокировки интерфейса"""
    
    progress = pyqtSignal(int, str)
    log = pyqtSignal(str)
    finished = pyqtSignal(object)
    error = pyqtSignal(str)
    
    def __init__(self, params: Dict):
        super().__init__()
        self.params = params
        self._is_running = True
    
    def stop(self):
        self._is_running = False
    
    def run(self):
        try:
            self._do_calculation()
        except Exception as e:
            self.error.emit(str(e))
            import traceback
            traceback.print_exc()
    
    def _do_calculation(self):
        """Основная логика расчёта"""
        month = self.params['month']
        mrf_name = self.params['mrf_name']
        report_path = self.params['report_path']
        base_path = self.params['base_path']
        charges_mode = self.params['charges_mode']
        base_col = self.params['base_col']
        target_col = self.params['target_col']
        amount_col = self.params.get('amount_col')
        current_col = self.params.get('current_col')
        charges_path = self.params.get('charges_path')
        filters = self.params.get('filters', {})
        
        self.log.emit(f"🚀 Начинаем расчёт для МРФ: {mrf_name}")
        self.log.emit(f"📋 Целевая колонка: {target_col}")
        self.log.emit(f"📋 Колонка начислений: {amount_col if amount_col else 'не задана'}")
        self.progress.emit(5, "Загрузка отчёта...")
        
        # Загрузка отчёта
        df_report = pd.read_excel(report_path, sheet_name=SHEET_TABLE3)
        self.log.emit(f"✅ Отчёт загружен: {len(df_report)} строк")
        self.log.emit(f"📋 Колонки отчёта: {list(df_report.columns)}")
        
        # Проверяем наличие целевой колонки
        if target_col not in df_report.columns:
            self.log.emit(f"⚠️ Целевая колонка '{target_col}' не найдена в отчёте")
            for col in df_report.columns:
                if month in str(col).lower() and "эффект" in str(col).lower():
                    target_col = col
                    self.log.emit(f"✅ Используем колонку: {target_col}")
                    break
        
        self.progress.emit(10, "Загрузка базы индексации...")
        
        # Загрузка базы
        df_base = pd.read_excel(base_path, sheet_name=SHEET_TABLE2)
        self.log.emit(f"✅ База индексации загружена: {len(df_base)} строк")
        self.log.emit(f"📋 Колонки базы: {list(df_base.columns)}")
        
        # Загрузка начислений (режим А)
        df_amount = None
        if charges_mode == MODE_EXTERNAL and charges_path:
            self.progress.emit(20, "Загрузка файла начислений...")
            df_amount = pd.read_excel(charges_path, sheet_name=SHEET_TABLE1)
            self.log.emit(f"✅ Начисления загружены: {len(df_amount)} строк")
            self.log.emit(f"📋 Колонки начислений: {list(df_amount.columns)}")
            
            if amount_col not in df_amount.columns:
                raise ValueError(f"Колонка '{amount_col}' не найдена в файле начислений!")
            if "MSISDN" not in df_amount.columns:
                raise ValueError("Колонка 'MSISDN' не найдена в файле начислений!")
        
        self.progress.emit(30, "Подготовка данных...")
        
        # Группировка - добавляем ДАТУ в группировку!
        gcols = [c for c in [BASE_COL_SERVICE, BASE_COL_DATE, BASE_COL_MRF, 
                            BASE_COL_RF, BASE_COL_SEGMENT, BASE_COL_SUBSEG, 
                            BASE_COL_SEGMENT1]
                if c in df_base.columns]
        
        if not gcols:
            raise ValueError("Нет колонок группировки в базе")
        
        self.log.emit(f"📊 Колонки группировки: {gcols}")
        
        # Расчёт эффекта
        self.progress.emit(40, "Вычисление эффекта индексации...")
        
        if charges_mode == MODE_EXTERNAL:
            pivot = self._calc_pivot_external(df_base, df_amount, base_col, 
                                              "MSISDN", amount_col, gcols)
        else:
            pivot = self._calc_pivot_inbase(df_base, base_col, current_col, gcols)
        
        self.log.emit(f"✅ Сформировано {len(pivot)} групп")
        self.log.emit(f"💰 Суммарный эффект: {pivot['Эффект_тыс'].sum():.3f} тыс. руб.")
        
        # Применение фильтров и обновление отчёта
        self.progress.emit(60, "Применение фильтров...")
        
        result = self._apply_filters_and_update(df_report, pivot, target_col, 
                                                month, mrf_name, filters)
        
        self.progress.emit(80, "Подготовка к сохранению...")
        
        # Сохранение
        save_path = self._save_report(df_report, target_col, result, month)
        
        self.progress.emit(100, "Готово!")
        self.log.emit(f"✅ Сохранено в: {save_path}")
        
        # Формируем результат
        result['save_path'] = save_path
        result['total_effect'] = pivot['Эффект_тыс'].sum()
        self.finished.emit(result)
    
    def _calc_pivot_external(self, df_base, df_amount, base_col, id_col, 
                             amount_col, group_cols):
        """Расчёт эффекта для режима А (отдельный файл начислений)"""
        self.log.emit("🔄 Выполняется соединение по MSISDN...")
        self.log.emit(f"📋 Колонка 'до': {base_col}")
        self.log.emit(f"📋 Колонка начислений: {amount_col}")
        
        df_base = df_base.copy()
        df_amount = df_amount.copy()
        
        df_base[base_col] = pd.to_numeric(df_base[base_col], errors='coerce')
        df_amount[amount_col] = pd.to_numeric(df_amount[amount_col], errors='coerce')
        
        df_base[id_col] = df_base[id_col].astype(str).str.strip().str.replace('.0', '', regex=False)
        df_amount["MSISDN"] = df_amount["MSISDN"].astype(str).str.strip().str.replace('.0', '', regex=False)
        
        merged = df_base.merge(df_amount[["MSISDN", amount_col]], 
                               left_on=id_col, right_on="MSISDN", how='left')
        
        self.log.emit(f"✅ Соединено: {len(merged):,} строк")
        
        merged['Эффект_руб'] = merged[amount_col] - merged[base_col]
        merged.loc[merged['Эффект_руб'] < 0, 'Эффект_руб'] = 0
        
        positive = (merged['Эффект_руб'] > 0).sum()
        self.log.emit(f"✅ С положительным эффектом: {positive:,}")
        
        extra_cols = [c for c in [BASE_COL_PCT, BASE_COL_SEGMENT1] if c in merged.columns]
        agg_dict = {'Эффект_руб': 'sum'}
        for c in extra_cols:
            agg_dict[c] = 'first'
        
        pivot = merged.groupby(group_cols, as_index=False).agg(agg_dict)
        pivot['Эффект_тыс'] = (pivot['Эффект_руб'] / 1000).round(3)
        
        return pivot
    
    def _calc_pivot_inbase(self, df_base, base_col, current_col, group_cols):
        """Расчёт эффекта для режима В (начисления в базе)"""
        self.log.emit("🔄 Выполняется расчёт из колонок базы...")
        self.log.emit(f"📋 Колонка 'до': {base_col}")
        self.log.emit(f"📋 Колонка 'текущее': {current_col}")
        
        df = df_base.copy()
        df[base_col] = pd.to_numeric(df[base_col], errors='coerce')
        df[current_col] = pd.to_numeric(df[current_col], errors='coerce')
        
        df['Эффект_руб'] = df[current_col] - df[base_col]
        df.loc[df['Эффект_руб'] < 0, 'Эффект_руб'] = 0
        
        positive = (df['Эффект_руб'] > 0).sum()
        self.log.emit(f"✅ С положительным эффектом: {positive:,}")
        
        extra_cols = [c for c in [BASE_COL_PCT, BASE_COL_SEGMENT1] if c in df.columns]
        agg_dict = {'Эффект_руб': 'sum'}
        for c in extra_cols:
            agg_dict[c] = 'first'
        
        pivot = df.groupby(group_cols, as_index=False).agg(agg_dict)
        pivot['Эффект_тыс'] = (pivot['Эффект_руб'] / 1000).round(3)
        
        return pivot
    
    def _apply_filters_and_update(self, df_report, pivot, target_col, 
                                   month, mrf_name, filters):
        """
        Применяет фильтры и обновляет отчёт.
        
        🔑 КЛЮЧИ СОПОСТАВЛЕНИЯ (6 параметров):
        1. Услуга (обязательно)
        2. ДАТА ИНДЕКСАЦИИ (обязательно!) - добавлена для корректной обработки
        3. МРФ
        4. РФ
        5. Краткий Сегмент
        6. Подсегмент
        
        Почему дата важна: одна услуга может индексироваться в разные даты!
        """
        self.log.emit(f"🔍 Применяем фильтры...")
        self.log.emit(f"📋 КЛЮЧИ СОПОСТАВЛЕНИЯ: Услуга + Дата + МРФ + РФ + Сегмент + Подсегмент")
        
        selected_date = filters.get('date', '')
        selected_segments = filters.get('segments', {})
        
        self.log.emit(f"📅 Выбранная дата: {selected_date}")
        self.log.emit(f"🔍 Фильтры сегментов: {list(selected_segments.keys())}")
        
        if not selected_date:
            raise ValueError("Не выбрана дата индексации")
        
        selected_services = set()
        for fc, fv in selected_segments.items():
            if fc == RPT_COL_SERVICE:
                selected_services = set(fv)
                self.log.emit(f"📋 Выбраны услуги: {selected_services}")
                break
        
        # --- 1. Строим словарь отчёта с ПОЛНЫМ ключом (6 параметров: Услуга + Дата + МРФ + РФ + Сегмент + Подсегмент) ---
        report_dict = {}  # full_key -> список индексов строк
        for idx, row in df_report.iterrows():
            # Проверяем ДАТУ (обязательно!)
            rd = norm_date(row[RPT_COL_DATE]) if RPT_COL_DATE in df_report.columns else ""
            if rd != norm_date(selected_date):
                continue
            
            svc = norm_text(row[RPT_COL_SERVICE]) if RPT_COL_SERVICE in df_report.columns else ""
            if selected_services and svc not in selected_services:
                continue
            
            mrf_ = norm_text(row[RPT_COL_MRF]) if RPT_COL_MRF in df_report.columns else ""
            rf_ = map_rf(row[RPT_COL_RF]) if RPT_COL_RF in df_report.columns else ""
            seg_ = norm_text(row[RPT_COL_SEGMENT]) if RPT_COL_SEGMENT in df_report.columns else ""
            sub_ = norm_text(row[RPT_COL_SUBSEG]) if RPT_COL_SUBSEG in df_report.columns else ""
            
            # 🔑 ПОЛНЫЙ ключ: (Услуга, Дата, МРФ, РФ, Сегмент, Подсегмент)
            full_key = (svc, rd, mrf_, rf_, seg_, sub_)
            if full_key not in report_dict:
                report_dict[full_key] = []
            report_dict[full_key].append(idx)
        
        total_rpt = sum(len(v) for v in report_dict.values())
        self.log.emit(f"📋 Строк в отчёте по фильтрам: {total_rpt}")
        
        if total_rpt == 0:
            self.log.emit("⚠️ Нет строк в отчёте, соответствующих фильтрам. Все группы будут добавлены как новые.")
        
        # --- 2. Строим словарь Pivot с ПОЛНЫМ ключом (6 параметров) ---
        pivot_dict = {}  # full_key -> суммарный эффект
        for _, pr in pivot.iterrows():
            svc = norm_text(pr[BASE_COL_SERVICE]) if BASE_COL_SERVICE in pr.index else ""
            date = norm_date(pr[BASE_COL_DATE]) if BASE_COL_DATE in pr.index else selected_date
            mrf_ = norm_text(pr[BASE_COL_MRF]) if BASE_COL_MRF in pr.index else ""
            rf_ = map_rf(pr[BASE_COL_RF]) if BASE_COL_RF in pr.index else ""
            seg_ = norm_text(pr[BASE_COL_SEGMENT]) if BASE_COL_SEGMENT in pr.index else ""
            sub_ = norm_text(pr[BASE_COL_SUBSEG]) if BASE_COL_SUBSEG in pr.index else ""
            eff = pr['Эффект_тыс']
            
            # 🔑 ПОЛНЫЙ ключ: (Услуга, Дата, МРФ, РФ, Сегмент, Подсегмент)
            full_key = (svc, date, mrf_, rf_, seg_, sub_)
            if full_key not in pivot_dict:
                pivot_dict[full_key] = 0
            pivot_dict[full_key] += eff
        
        self.log.emit(f"📊 Ключей в pivot: {len(pivot_dict)}")
        
        # Выводим несколько ключей для отладки
        for i, (key, eff) in enumerate(list(pivot_dict.items())[:5]):
            self.log.emit(f"  Ключ {i+1}: {key} -> {eff:.3f}")
        if len(pivot_dict) > 5:
            self.log.emit(f"  ... и ещё {len(pivot_dict) - 5} ключей")
        
        # --- 3. Получаем фильтры МРФ и РФ ---
        filter_mrfs = set(selected_segments.get(RPT_COL_MRF, []))
        filter_rfs = set(selected_segments.get(RPT_COL_RF, []))
        
        self.log.emit(f"🔍 Фильтр МРФ: {filter_mrfs}")
        self.log.emit(f"🔍 Фильтр РФ: {filter_rfs}")
        
        # --- 4. Сопоставление ---
        matched_count = 0
        added_count = 0
        not_found_count = 0
        matched_indices = []
        added_indices = []
        not_found_indices = []
        
        # 4a. Находим строки в отчёте, которых нет в базе (жёлтые ячейки)
        for full_key, ridxs in report_dict.items():
            svc, date, mrf_, rf_, seg_, sub_ = full_key
            
            # Проверяем фильтры МРФ и РФ
            if filter_mrfs and mrf_ not in filter_mrfs:
                continue
            if filter_rfs and rf_ not in filter_rfs:
                continue
            
            if full_key not in pivot_dict:
                self.log.emit(f"⚠️ Не найдено в базе: {full_key}")
                for ridx in ridxs:
                    try:
                        cur = df_report.loc[ridx, target_col]
                        if pd.isna(cur):
                            df_report.loc[ridx, target_col] = 0
                            self.log.emit(f"✅ Установлен 0 для строки {ridx+2}")
                    except Exception as e:
                        self.log.emit(f"❌ Ошибка установки 0: {e}")
                    not_found_indices.append(ridx)
                    not_found_count += 1
        
        # 4b. Обновляем существующие строки (зелёные ячейки)
        self.log.emit("🔄 Сопоставление данных...")
        
        for full_key, ridxs in report_dict.items():
            svc, date, mrf_, rf_, seg_, sub_ = full_key
            
            # Проверяем фильтры МРФ и РФ
            if filter_mrfs and mrf_ not in filter_mrfs:
                continue
            if filter_rfs and rf_ not in filter_rfs:
                continue
            
            if full_key in pivot_dict:
                eff = pivot_dict[full_key]
                self.log.emit(f"✅ Найдено совпадение: {full_key} -> {eff:.3f}")
                for ridx in ridxs:
                    try:
                        df_report.loc[ridx, target_col] = eff
                        self.log.emit(f"✅ Записано {eff:.3f} в строку {ridx+2}")
                        matched_indices.append(ridx)
                        matched_count += 1
                    except Exception as e:
                        self.log.emit(f"❌ Ошибка записи: {e}")
        
        # 4c. Добавляем новые строки (синие строки) - которых нет в отчёте
        for full_key, eff in pivot_dict.items():
            svc, date, mrf_, rf_, seg_, sub_ = full_key
            
            # Проверяем фильтры МРФ и РФ
            if filter_mrfs and mrf_ not in filter_mrfs:
                continue
            if filter_rfs and rf_ not in filter_rfs:
                continue
            
            # Проверяем, есть ли услуга в выбранных
            if selected_services and svc not in selected_services:
                continue
            
            if full_key not in report_dict:
                self.log.emit(f"➕ Добавляем новую строку: {full_key} -> {eff:.3f}")
                new_row = self._build_new_row(df_report, full_key, svc, date, target_col, eff)
                df_report = pd.concat([df_report, pd.DataFrame([new_row])], ignore_index=True)
                added_indices.append(len(df_report) - 1)
                added_count += 1
                self.log.emit(f"✅ Добавлена строка {len(df_report)}")
        
        self.log.emit(f"✅ Обновлено: {matched_count} строк")
        self.log.emit(f"✅ Добавлено: {added_count} строк")
        if not_found_count:
            self.log.emit(f"⚠️ Не найдено в базе: {not_found_count} строк")
        
        return {
            'matched_indices': matched_indices,
            'added_indices': added_indices,
            'not_found_indices': not_found_indices,
            'matched_count': matched_count,
            'added_count': added_count,
            'not_found_count': not_found_count,
            'df_report': df_report
        }
    
    def _build_new_row(self, df_report, full_key, svc_val, selected_date, 
                       target_col, eff_value):
        """Строит новую строку для отчёта"""
        svc, date, mrf_, rf_, seg_, sub_ = full_key
        new_row = {col: None for col in df_report.columns}
        
        # Услуга
        if RPT_COL_SERVICE in new_row:
            new_row[RPT_COL_SERVICE] = fmt_service(svc_val)
        
        # Дата
        if RPT_COL_DATE in new_row:
            try:
                new_row[RPT_COL_DATE] = pd.to_datetime(selected_date, dayfirst=True).date()
            except:
                new_row[RPT_COL_DATE] = selected_date
        
        # МРФ
        if RPT_COL_MRF in new_row:
            new_row[RPT_COL_MRF] = fmt_mrf(mrf_)
        
        # РФ
        if RPT_COL_RF in new_row:
            new_row[RPT_COL_RF] = unmap_rf(rf_)
        
        # Краткий Сегмент
        if RPT_COL_SEGMENT in new_row:
            new_row[RPT_COL_SEGMENT] = fmt_seg(seg_)
        
        # Подсегмент
        if RPT_COL_SUBSEG in new_row:
            new_row[RPT_COL_SUBSEG] = fmt_seg(sub_)
        
        # Эффект
        if target_col in new_row:
            new_row[target_col] = fmt_num3(eff_value)
        
        return new_row
    
    def _save_report(self, df_report, target_col, result, month):
        """Сохраняет отчёт с форматированием"""
        save_dir = QFileDialog.getExistingDirectory(
            None, "Выберите папку для сохранения",
            os.path.expanduser("~/Desktop")
        )
        
        if not save_dir:
            save_dir = os.path.dirname(self.params['report_path'])
        
        default_name = f"Факт-эффект индексации {month} {datetime.now().strftime('%Y%m%d_%H%M%S')}.xlsx"
        save_path = os.path.join(save_dir, default_name)
        
        self.log.emit(f"💾 Сохранение в: {save_path}")
        self.log.emit(f"📊 Обновлено ячеек: {len(result['matched_indices'])}")
        self.log.emit(f"📊 Добавлено строк: {len(result['added_indices'])}")
        
        # Нормализация данных
        df_report = self._normalize_report(df_report, target_col)
        
        # Сохранение
        self.log.emit("💾 Запись Excel файла...")
        with pd.ExcelWriter(save_path, engine='openpyxl', mode='w') as writer:
            df_report.to_excel(writer, sheet_name=SHEET_TABLE3, index=False)
        
        self.log.emit("🎨 Применение форматирования...")
        
        wb = load_workbook(save_path)
        ws = wb[SHEET_TABLE3]
        
        grn = PatternFill(start_color=FILL_UPDATED, end_color=FILL_UPDATED, fill_type='solid')
        blue = PatternFill(start_color=FILL_ADDED, end_color=FILL_ADDED, fill_type='solid')
        yel = PatternFill(start_color=FILL_NOT_FOUND, end_color=FILL_NOT_FOUND, fill_type='solid')
        
        cols_list = list(df_report.columns)
        
        if target_col in cols_list:
            ci_target = cols_list.index(target_col) + 1
            self.log.emit(f"🎯 Целевая колонка на позиции {ci_target}")
        else:
            self.log.emit(f"⚠️ Целевая колонка '{target_col}' не найдена!")
            ci_target = 1
        
        # Заливка зелёным (обновлённые)
        self.log.emit(f"🟢 Зелёных ячеек: {len(result['matched_indices'])}")
        for ridx in result['matched_indices']:
            try:
                ws.cell(row=ridx + 2, column=ci_target).fill = grn
            except Exception as e:
                self.log.emit(f"⚠️ Ошибка заливки строки {ridx+2}: {e}")
        
        # Заливка синим (добавленные строки)
        self.log.emit(f"🔵 Синих строк: {len(result['added_indices'])}")
        for ridx in result['added_indices']:
            try:
                for c in range(1, len(cols_list) + 1):
                    ws.cell(row=ridx + 2, column=c).fill = blue
            except Exception as e:
                self.log.emit(f"⚠️ Ошибка заливки строки {ridx+2}: {e}")
        
        # Заливка жёлтым (не найденные)
        self.log.emit(f"🟡 Жёлтых ячеек: {len(result['not_found_indices'])}")
        for ridx in result['not_found_indices']:
            try:
                ws.cell(row=ridx + 2, column=ci_target).fill = yel
            except Exception as e:
                self.log.emit(f"⚠️ Ошибка заливки строки {ridx+2}: {e}")
        
        wb.save(save_path)
        self.log.emit("✅ Файл сохранён!")
        
        return save_path
    
    def _normalize_report(self, df_report, target_col):
        """Нормализует данные отчёта перед сохранением"""
        df = df_report.copy()
        
        real_svc = find_col_name(df, RPT_COL_SERVICE)
        real_mrf = find_col_name(df, RPT_COL_MRF)
        real_rf = find_col_name(df, RPT_COL_RF)
        real_date = find_col_name(df, RPT_COL_DATE)
        real_pct = find_col_name(df, RPT_COL_PCT)
        real_seg = find_col_name(df, RPT_COL_SEGMENT)
        real_sub = find_col_name(df, RPT_COL_SUBSEG)
        real_seg1 = find_col_name(df, RPT_COL_SEGMENT1)
        real_tgt = find_col_name(df, target_col)
        
        if real_svc:
            df[real_svc] = df[real_svc].apply(
                lambda x: fmt_service(x) if pd.notna(x) and str(x).strip() != "" else x)
        
        if real_mrf:
            df[real_mrf] = df[real_mrf].apply(
                lambda x: fmt_mrf(x) if pd.notna(x) and str(x).strip() != "" else x)
        
        if real_rf:
            df[real_rf] = df[real_rf].apply(
                lambda x: fmt_title(x) if pd.notna(x) and str(x).strip() != "" else x)
        
        if real_date:
            df[real_date] = df[real_date].apply(
                lambda x: pd.to_datetime(x, dayfirst=True, errors="coerce").date()
                if pd.notna(x) and str(x).strip() != "" else x)
        
        if real_pct:
            df[real_pct] = df[real_pct].apply(
                lambda x: fmt_pct(x) if pd.notna(x) and str(x).strip() != "" else x)
        
        if real_seg:
            df[real_seg] = df[real_seg].apply(
                lambda x: fmt_seg(x) if pd.notna(x) and str(x).strip() != "" else x)
        
        if real_sub:
            df[real_sub] = df[real_sub].apply(
                lambda x: fmt_seg(x) if pd.notna(x) and str(x).strip() != "" else x)
        
        if real_seg1:
            df[real_seg1] = df[real_seg1].apply(
                lambda x: fmt_seg(x) if pd.notna(x) and str(x).strip() != "" else x)
        
        if real_tgt:
            df[real_tgt] = df[real_tgt].apply(
                lambda x: fmt_num3(x) if pd.notna(x) and str(x).strip() != "" else x)
        
        return df


