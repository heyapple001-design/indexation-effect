_mappings = None


def load_mappings() -> Dict:
    """Загружает справочники из data/mappings.json"""
    global _mappings
    
    if _mappings is not None:
        return _mappings
    
    json_path = pathlib.Path(__file__).parent / "data" / "mappings.json"
    
    if not json_path.exists():
        raise FileNotFoundError(
            f"Файл справочников не найден: {json_path}\n"
            "Убедитесь что папка data/ с файлом mappings.json лежит рядом с программой."
        )
    
    with open(json_path, encoding="utf-8") as f:
        _mappings = json.load(f)
    
    return _mappings


def get_all_mrf() -> List[str]:
    """Возвращает список всех МРФ"""
    m = load_mappings()
    return m.get("ALL_MRF", [])


def get_mrf_to_rf() -> Dict:
    """Возвращает словарь МРФ -> РФ"""
    m = load_mappings()
    return m.get("MRF_TO_RF", {})


def get_rf_mapping() -> Dict:
    """Возвращает словарь РФ -> нормализованное значение"""
    m = load_mappings()
    return m.get("RF_MAPPING", {})


def get_rf_reverse() -> Dict:
    """Возвращает обратный словарь РФ"""
    m = load_mappings()
    return m.get("RF_REVERSE", {})


def get_service_exact() -> Dict:
    """Возвращает точные соответствия услуг"""
