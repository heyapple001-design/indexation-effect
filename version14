def calc_pivot_external(df_base: pd.DataFrame, df_amount: pd.DataFrame,
                        base_col: str, id_col: str,
                        amount_col: str, gcols: List[str]) -> pd.DataFrame:
    df_b = df_base.copy()
    df_a = df_amount.copy()
    df_b[base_col] = pd.to_numeric(df_b[base_col], errors='coerce')
    df_a[amount_col] = pd.to_numeric(df_a[amount_col], errors='coerce')
    df_b[id_col] = df_b[id_col].astype(str).str.strip().str.replace('.0', '', regex=False)
    df_a["MSISDN"] = df_a["MSISDN"].astype(str).str.strip().str.replace('.0', '', regex=False)
    merged = df_b.merge(df_a[["MSISDN", amount_col]],
                        left_on=id_col, right_on="MSISDN", how='left')
    del df_b, df_a
    gc.collect()
    merged['Эффект_руб'] = (merged[amount_col] - merged[base_col]).clip(lower=0)
    extra = [c for c in [BASE_COL_PCT, BASE_COL_SEGMENT1] if c in merged.columns]
    agg = {'Эффект_руб': 'sum', **{c: 'first' for c in extra}}
    pivot = merged.groupby(gcols, as_index=False).agg(agg)
    pivot['Эффект_тыс'] = (pivot['Эффект_руб'] / 1000).round(3)
    del merged
    return pivot


def calc_pivot_inbase(df_base: pd.DataFrame, base_col: str,
                      current_col: str, gcols: List[str]) -> pd.DataFrame:
    df = df_base.copy()
    df[base_col] = pd.to_numeric(df[base_col], errors='coerce')
    df[current_col] = pd.to_numeric(df[current_col], errors='coerce')
    df['Эффект_руб'] = (df[current_col] - df[base_col]).clip(lower=0)
    extra = [c for c in [BASE_COL_PCT, BASE_COL_SEGMENT1] if c in df.columns]
    agg = {'Эффект_руб': 'sum', **{c: 'first' for c in extra}}
    pivot = df.groupby(gcols, as_index=False).agg(agg)
    pivot['Эффект_тыс'] = (pivot['Эффект_руб'] / 1000).round(3)
    del df
    return pivot


