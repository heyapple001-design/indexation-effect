class _UILogHandler(logging.Handler):
    def __init__(self) -> None:
        super().__init__()
        self._worker_ref: Optional[Any] = None

    def set_worker(self, worker) -> None:
        if worker is None:
            self._worker_ref = None
        else:
            self._worker_ref = weakref.ref(worker)

    def emit(self, record: logging.LogRecord) -> None:
        if self._worker_ref is None:
            return
        worker = self._worker_ref()
        if worker is None:
            self._worker_ref = None
            return
        if record.levelno >= logging.WARNING:
            try:
                worker.log_msg.emit(f"  ⚠️  {record.getMessage()}")
            except Exception:
                pass


_ui_log_handler = _UILogHandler()
_ui_log_handler.setLevel(logging.WARNING)
log.addHandler(_ui_log_handler)

