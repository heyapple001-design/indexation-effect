class TempDB:
    def __init__(self, db_path: str) -> None:
        self.path = db_path
        self._local = threading.local()
        self._get_conn()
        self._init_schema()
        log.info(f"TempDB: {db_path}")

    def _get_conn(self) -> sqlite3.Connection:
        if not hasattr(self._local, 'conn') or self._local.conn is None:
            self._local.conn = sqlite3.connect(
                self.path, check_same_thread=True)
            self._local.conn.executescript(
                "PRAGMA journal_mode=WAL; PRAGMA synchronous=NORMAL;")
        return self._local.conn

    def _init_schema(self) -> None:
        self._get_conn().executescript("""
            PRAGMA journal_mode=WAL;
            PRAGMA synchronous=NORMAL;

            CREATE TABLE IF NOT EXISTS pivot_results (
                session_id TEXT, mrf_name TEXT, base_num INTEGER,
                data_blob  BLOB,
                created_at TEXT DEFAULT (datetime('now'))
            );
            CREATE TABLE IF NOT EXISTS report_updates (
                session_id TEXT, mrf_name TEXT, base_num INTEGER,
                row_idx INTEGER, col_name TEXT,
                new_value TEXT, fill_type TEXT
            );
            CREATE TABLE IF NOT EXISTS checkpoints (
                session_id TEXT PRIMARY KEY,
                month TEXT, chosen_mrf TEXT,
                table3_path TEXT, target_col TEXT,
                completed_bases TEXT,
                updated_at TEXT DEFAULT (datetime('now'))
            );
            CREATE INDEX IF NOT EXISTS idx_pivot
                ON pivot_results(session_id, mrf_name, base_num);
            CREATE INDEX IF NOT EXISTS idx_updates
                ON report_updates(session_id);
        """)
        self._get_conn().commit()

    def save_pivot(self, sid: str, mrf: str, num: int,
                   pivot: pd.DataFrame) -> None:
        blob = pickle.dumps(pivot, protocol=pickle.HIGHEST_PROTOCOL)
        self._get_conn().execute(
            "INSERT INTO pivot_results(session_id,mrf_name,base_num,data_blob)"
            " VALUES(?,?,?,?)", (sid, mrf, num, blob))
        self._get_conn().commit()

    def save_update(self, sid: str, mrf: str, num: int,
                    ridx: int, col: str, val: Any, fill: str) -> None:
        self._get_conn().execute(
            "INSERT INTO report_updates"
            "(session_id,mrf_name,base_num,row_idx,col_name,new_value,fill_type)"
            " VALUES(?,?,?,?,?,?,?)",
            (sid, mrf, num, ridx, col, str(val), fill))

    def flush(self) -> None:
        self._get_conn().commit()

    def iter_updates(self, sid: str, chunk: int = 5_000):
        cursor = self._get_conn().execute(
            "SELECT row_idx,col_name,new_value,fill_type"
            " FROM report_updates WHERE session_id=? ORDER BY row_idx",
            (sid,))
        while True:
            rows = cursor.fetchmany(chunk)
            if not rows:
                break
            yield rows

    def save_checkpoint(self, sid: str, month: str, mrfs: List[str],
                        path: str, col: str,
                        done: List[Tuple[str, int]]) -> None:
        self._get_conn().execute("""
            INSERT INTO checkpoints
              (session_id,month,chosen_mrf,table3_path,target_col,
               completed_bases,updated_at)
            VALUES(?,?,?,?,?,?,datetime('now'))
            ON CONFLICT(session_id) DO UPDATE SET
              completed_bases=excluded.completed_bases,
              updated_at=excluded.updated_at
        """, (sid, month, json.dumps(mrfs, ensure_ascii=False),
              path, col, json.dumps(done, ensure_ascii=False)))
        self._get_conn().commit()

    def load_checkpoint(self, sid: str) -> Optional[dict]:
        row = self._get_conn().execute(
            "SELECT month,chosen_mrf,table3_path,target_col,completed_bases"
            " FROM checkpoints WHERE session_id=?", (sid,)).fetchone()
        if not row:
            return None
        return {
            "month": row[0],
            "chosen_mrf": json.loads(row[1]),
            "table3_path": row[2],
            "target_col": row[3],
            "completed": [tuple(x) for x in json.loads(row[4])]
        }

    def list_sessions(self) -> List[Tuple]:
        rows = self._get_conn().execute(
            "SELECT session_id,month,chosen_mrf,updated_at"
            " FROM checkpoints ORDER BY updated_at DESC").fetchall()
        return [(r[0], r[1], json.loads(r[2]), r[3]) for r in rows]

    def close(self) -> None:
        try:
            if hasattr(self._local, 'conn') and self._local.conn:
                self._local.conn.close()
                self._local.conn = None
        except Exception:
            pass


_temp_db: Optional[TempDB] = None
_temp_db_lock = threading.Lock()


def get_temp_db() -> TempDB:
    global _temp_db
    if _temp_db is None:
        with _temp_db_lock:
            if _temp_db is None:
                p = pathlib.Path(tempfile.gettempdir()) / "indexation_session.db"
                _temp_db = TempDB(str(p))
    return _temp_db


