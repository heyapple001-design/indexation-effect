class MainWindow(QMainWindow):
    def __init__(self) -> None:
        super().__init__()
        self.setWindowTitle("Расчёт эффекта индексации")
        self.resize(860, 560)
        self.setStyleSheet(STYLESHEET)
        self._worker: Optional[CalcWorker] = None
        self._thread: Optional[QThread] = None

        central = QWidget()
        self.setCentralWidget(central)
        vl = QVBoxLayout(central)
        vl.setContentsMargins(0, 0, 0, 0)
        vl.addWidget(make_header("Расчёт фактического эффекта от индексации"))

        mem_bar = QWidget()
        ml = QHBoxLayout(mem_bar)
        ml.setContentsMargins(12, 3, 12, 3)
        self._mem_lbl = QLabel("RAM: — МБ")
        self._mem_lbl.setStyleSheet(f"color:{HINT};font-size:9pt;")
        self._mem_pb = QProgressBar()
        if _HAS_PSUTIL and _psutil is not None:
            max_mem = int(_psutil.virtual_memory().total / 1024 / 1024)
        else:
            max_mem = 4096
        self._mem_pb.setMaximum(max_mem)
        self._mem_pb.setFixedHeight(10)
        self._mem_pb.setFixedWidth(180)
        self._mem_pb.setTextVisible(False)
        ml.addWidget(self._mem_lbl)
        ml.addWidget(self._mem_pb)
        ml.addStretch()
        vl.addWidget(mem_bar)

        self._progress = QProgressBar()
        self._progress.setFixedHeight(14)
        self._progress.setValue(0)
        self._progress.setFormat("Ожидание...")
        vl.addWidget(self._progress)

        self._console = QTextEdit()
        self._console.setReadOnly(True)
        self._console.setStyleSheet(
            "font-family:Consolas;font-size:9pt;background:#FAFAFA;border:none;")
        vl.addWidget(self._console)

        btn_bar = QWidget()
        bl = QHBoxLayout(btn_bar)
        bl.setContentsMargins(12, 8, 12, 8)
        self._run_btn = QPushButton("▶  Новая сессия")
        self._resume_btn = sec_btn("⟳  Восстановить")
        self._stop_btn = danger_btn("■  Стоп")
        self._stop_btn.setEnabled(False)
        self._run_btn.clicked.connect(self._start_new)
        self._resume_btn.clicked.connect(self._resume)
        self._stop_btn.clicked.connect(self._stop)
        bl.addWidget(self._run_btn)
        bl.addWidget(self._resume_btn)
        bl.addStretch()
        bl.addWidget(self._stop_btn)
        vl.addWidget(btn_bar)

        self._mem_timer = QTimer(self)
        self._mem_timer.timeout.connect(self._update_mem)
        self._mem_timer.start(2000)
        self._update_mem()
        self.show()

    def _update_mem(self) -> None:
        mb = int(memory_mb())
        self._mem_lbl.setText(f"RAM: {mb} МБ")
        self._mem_pb.setValue(mb)
        if mb > MEMORY_WARN_MB:
            color = RED
        elif mb > MEMORY_WARN_MB * 0.7:
            color = "#E8A000"
        else:
            color = ACCENT
        self._mem_pb.setStyleSheet(
            f"QProgressBar::chunk{{background:{color};border-radius:2px;}}")

    def log(self, msg: str) -> None:
        self._console.append(msg)

    def _start_new(self) -> None:
        dlg = SessionBuilderDialog(self)
        if dlg.exec_() != QDialog.Accepted or not dlg.result_params:
            return
        self._run_worker(dlg.result_params)

    def _resume(self) -> None:
        db = get_temp_db()
        sessions = db.list_sessions()
        if not sessions:
            QMessageBox.information(self, "Нет сессий",
                                    "Нет сохранённых сессий для восстановления.")
            return

        dlg = ResumeDialog(sessions, self)
        if dlg.exec_() != QDialog.Accepted or not dlg.chosen_sid:
            return

        ckp = db.load_checkpoint(dlg.chosen_sid)
        if not ckp:
            return

        done = ckp["completed"]
        QMessageBox.information(self, "Восстановление",
                                f"Месяц: {ckp['month']}\n"
                                f"МРФ: {', '.join(ckp['chosen_mrf'])}\n"
                                f"Уже выполнено: {len(done)} баз.\n\n"
                                "Сейчас нужно заново указать файлы оставшихся баз.")

        builder = SessionBuilderDialog(self)
        if builder.exec_() != QDialog.Accepted or not builder.result_params:
            return

        params = builder.result_params
        params["session_id"] = dlg.chosen_sid
        params["completed"] = done
        params["table3_path"] = ckp["table3_path"]
        params["target_col"] = ckp["target_col"]
        self._run_worker(params)

    def _run_worker(self, params: dict) -> None:
        self._run_btn.setEnabled(False)
        self._resume_btn.setEnabled(False)
        self._stop_btn.setEnabled(True)
        total = max(params.get("total_bases", 1), 1)
        self._progress.setMaximum(total * 100)
        self._progress.setValue(0)
        self._progress.setFormat("Запуск...")

        self._thread = QThread()
        self._worker = CalcWorker(params)
        self._worker.moveToThread(self._thread)

        self._thread.started.connect(self._worker.run)
        self._worker.log_msg.connect(self.log)
        self._worker.progress.connect(self._on_progress)
        self._worker.finished.connect(self._on_finished)
        self._worker.error.connect(self._on_error)

        self._thread.start()

    def _stop(self) -> None:
        if self._worker:
            self._worker.stop()
            self.log("\n⚠️  Остановка после текущей операции...")

    def _on_progress(self, cur: int, total: int, desc: str) -> None:
        self._progress.setMaximum(total)
        self._progress.setValue(cur)
        self._progress.setFormat(f"{desc}")

    def _on_finished(self, stats: dict) -> None:
        self._cleanup_thread()
        c = stats["counts"]
        self.log(f"\n{'='*55}\nГОТОВО\n{'='*55}")
        self.log(f"🟢 Записано: {c['matched']} | "
                 f"🔵 Добавлено: {c['added']} | "
                 f"🟡 Не найдено: {c['not_found']}")
        self._update_mem()
        summary_lines = stats.get("summary", [])
        summary_short = "\n".join(summary_lines[:30])
        if len(summary_lines) > 30:
            summary_short += f"\n  ... и ещё {len(summary_lines)-30} строк"
        QMessageBox.information(self, "Готово",
                                f"Расчёт за {stats['month']} завершён!\n\n"
                                f"🟢 Записано:   {c['matched']}\n"
                                f"🔵 Добавлено:  {c['added']}\n"
                                f"🟡 Не найдено: {c['not_found']}\n\n"
                                f"{summary_short}")

    def _on_error(self, msg: str) -> None:
        self._cleanup_thread()
        self.log(f"\n❌ ОШИБКА: {msg}")
        QMessageBox.critical(self, "Ошибка",
                             f"Произошла ошибка:\n{msg}\n\n"
                             "Сессия сохранена — можно продолжить через «⟳ Восстановить».")

    def _cleanup_thread(self) -> None:
        self._run_btn.setEnabled(True)
        self._resume_btn.setEnabled(True)
        self._stop_btn.setEnabled(False)
        self._progress.setFormat("Ожидание...")
        if self._thread:
            self._thread.quit()
            self._thread.wait(3000)
            self._thread = None
        self._worker = None
        gc.collect()


