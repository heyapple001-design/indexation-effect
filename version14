                filters[fkey] = {
                    "date": flt_dlg.result_date,
                    "segments": flt_dlg.result_selected or {},
                }
                bases[mrf].append({
                    "base_path": base_path,
                    "charges_mode": charges_mode,
                    "base_col": base_col,
                    "id_col": id_col,
                    "current_col": current_col,
                    "charges_path": charges_path,
                })
                total_bases += 1

                reply2 = QMessageBox.question(
                    parent, "Ещё одна база?",
                    f"МРФ {fmt_mrf(mrf)}, база #{base_num} настроена.\n"
                    "Добавить ещё одну базу для этого МРФ?",
                    QMessageBox.Yes | QMessageBox.No)
                if reply2 != QMessageBox.Yes:
                    break

        if total_bases == 0:
            QMessageBox.warning(parent, "Нет баз", "Не задано ни одной базы.")
            return

        sid = datetime.now().strftime("%Y%m%d_%H%M%S")
        self.result_params = {
            "session_id": sid,
            "month": month,
            "chosen_mrf": chosen_mrf,
            "table3_path": table3_path,
            "target_col": target_col,
            "bases": bases,
            "filters": filters,
            "total_bases": total_bases,
            "completed": [],
        }
        self.accept()


class ResumeDialog(QDialog):
    def __init__(self, sessions: List[Tuple], parent=None) -> None:
        super().__init__(parent)
        self.setWindowTitle("Восстановление сессии")
        self.resize(600, 350)
        self.setStyleSheet(STYLESHEET)
        self.chosen_sid: Optional[str] = None

        layout = QVBoxLayout(self)
        layout.setContentsMargins(0, 0, 0, 0)
        layout.addWidget(make_header("Выберите сессию для восстановления"))
        body = QWidget()
        bl = QVBoxLayout(body)
        bl.setContentsMargins(16, 12, 16, 12)
        bl.addWidget(QLabel("Доступные сессии (от новых к старым):"))
        self._list = QListWidget()
        db = get_temp_db()
        for sid, month, mrfs, updated_at in sessions:
            ckp = db.load_checkpoint(sid)
            done = len(ckp["completed"]) if ckp else 0
            self._list.addItem(
                f"{updated_at[:16]}  |  {month}  |  "
                f"{', '.join(mrfs)}  |  выполнено: {done} баз")
        self._sessions = sessions
        self._list.itemDoubleClicked.connect(self._pick)
        bl.addWidget(self._list)
        brow = QHBoxLayout()
        ok_btn = QPushButton("Восстановить →")
        ok_btn.clicked.connect(self._pick)
        cancel = sec_btn("Отмена")
        cancel.clicked.connect(self.reject)
        brow.addWidget(ok_btn)
        brow.addWidget(cancel)
        brow.addStretch()
        bl.addLayout(brow)
        layout.addWidget(body)

    def _pick(self) -> None:
        idx = self._list.currentRow()
        if idx < 0:
            return
        self.chosen_sid = self._sessions[idx][0]
        self.accept()


