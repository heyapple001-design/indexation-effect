        hint_d = QLabel("Выберите дату — без неё применить фильтры невозможно")
        hint_d.setStyleSheet(f"color:{RED};font-size:9pt;")
        dl.addWidget(hint_d)
        cl.addWidget(date_box)

        cols = [c for c in [RPT_COL_SERVICE, RPT_COL_MRF, RPT_COL_RF,
                            RPT_COL_SEGMENT, RPT_COL_SUBSEG] if c in df_report.columns]
        for col in cols:
            is_svc = (col == RPT_COL_SERVICE)
            title = f"⚠  {col}  — выберите обязательно!" if is_svc else f"  {col}"
            box = QGroupBox(title)
            if is_svc:
                box.setStyleSheet(f"QGroupBox{{color:{RED};border:1px solid {RED};}}")
            bl2 = QVBoxLayout(box)

            br = QHBoxLayout()
            sel_all = sec_btn("✓ Выбрать все")
            sel_all.setFixedHeight(26)
            des_all = sec_btn("✗ Снять все")
            des_all.setFixedHeight(26)
            br.addWidget(sel_all)
            br.addWidget(des_all)
            br.addStretch()
            bl2.addLayout(br)

            if col == RPT_COL_RF and mrf_name:
                lbl = QLabel(f"  ✅ Автоматически выбраны РФ МРФ {fmt_mrf(mrf_name)}")
                lbl.setStyleSheet(f"color:{GREEN};font-size:9pt;")
                bl2.addWidget(lbl)
            if col == RPT_COL_MRF and mrf_name:
                lbl = QLabel(f"  ✅ Автоматически выбран МРФ {fmt_mrf(mrf_name)}")
                lbl.setStyleSheet(f"color:{GREEN};font-size:9pt;")
                bl2.addWidget(lbl)

            values = self._make_values(col)
            self._checks[col] = {}
            grid = QWidget()
            gl = QGridLayout(grid)
            gl.setSpacing(2)
            for idx, val in enumerate(values):
                r, c = divmod(idx, 3)
                default = self._auto_check(col, val)
                cb = QCheckBox(val)
                cb.setChecked(default)
                self._checks[col][val] = cb
                gl.addWidget(cb, r, c)
            bl2.addWidget(grid)

            checks_ref = self._checks[col]
            sel_all.clicked.connect(lambda _, d=checks_ref: [cb.setChecked(True) for cb in d.values()])
            des_all.clicked.connect(lambda _, d=checks_ref: [cb.setChecked(False) for cb in d.values()])
            cl.addWidget(box)

        cl.addStretch()
        scroll.setWidget(container)
        layout.addWidget(scroll)
        layout.addWidget(sep())

        act = QWidget()
        al = QHBoxLayout(act)
        al.setContentsMargins(16, 8, 16, 8)
        apply_btn = QPushButton("Применить фильтры →")
        apply_btn.clicked.connect(self._apply)
        clear_btn = sec_btn("Сбросить всё")
        clear_btn.clicked.connect(self._clear)
        cancel_btn = danger_btn("Отмена")
        cancel_btn.clicked.connect(self.reject)
        al.addWidget(apply_btn)
        al.addWidget(clear_btn)
        al.addWidget(cancel_btn)
        al.addStretch()
        layout.addWidget(act)

        self.setWindowFlag(Qt.WindowCloseButtonHint, True)
        self.rejected.connect(self._on_reject)

    def _on_reject(self) -> None:
        self.result_date = None
        self.result_selected = None

    def _make_values(self, col: str) -> List[str]:
        s = self._df[col].dropna()
        if col == RPT_COL_RF:
            all_v = sorted(set(unmap_rf(map_rf(x)) for x in s if str(x).strip()))
            if self._mrf_rf_canonical:
                flt = [v for v in all_v if norm_text(map_rf(v)) in self._mrf_rf_canonical]
                return flt if flt else all_v
            return all_v
        if col == RPT_COL_MRF:
            return sorted(set(fmt_mrf(v) for v in s if str(v).strip()))
        if col == RPT_COL_SERVICE:
            return sorted(set(fmt_service(str(v).strip()) for v in s if str(v).strip()))
        if col in (RPT_COL_SEGMENT, RPT_COL_SUBSEG):
            return sorted(set(fmt_seg(norm_text(v)) for v in s if str(v).strip()))
        return sorted(set(norm_text(v) for v in s if norm_text(v)))

    def _auto_check(self, col: str, val: str) -> bool:
        if col == RPT_COL_RF:
            return norm_text(map_rf(val)) in self._mrf_rf_canonical
        if col == RPT_COL_MRF:
            return fmt_mrf(val).lower() == self._mrf_norm or val == fmt_mrf(self._mrf_name)
        return False

    def _apply(self) -> None:
        if self._date_combo.currentText() == "(выберите дату)":
            QMessageBox.warning(self, "Внимание", "Выберите дату индексации!")
            return
        svc_checks = self._checks.get(RPT_COL_SERVICE, {})
        if svc_checks and not any(cb.isChecked() for cb in svc_checks.values()):
            QMessageBox.warning(self, "Внимание",
                                "Выберите хотя бы одну УСЛУГУ!\nБез фильтра данные запишутся во все строки.")
            return
        self.result_date = self._date_combo.currentText()
        selected: Dict[str, List[str]] = {}
        for col, checks in self._checks.items():
            vals = [v for v, cb in checks.items() if cb.isChecked()]
            if col == RPT_COL_MRF:
                vals = [norm_text(v) for v in vals]
            elif col == RPT_COL_RF:
                vals = [norm_text(map_rf(v)) for v in vals]
            elif col == RPT_COL_SERVICE:
                vals = [norm_text(v) for v in vals]
            elif col in (RPT_COL_SEGMENT, RPT_COL_SUBSEG):
                vals = [norm_text(v) for v in vals]
            if vals:
                selected[col] = vals
        self.result_selected = selected
        self.accept()

    def _clear(self) -> None:
        self._date_combo.setCurrentIndex(0)
        for checks in self._checks.values():
            for cb in checks.values():
                cb.setChecked(False)


class SessionBuilderDialog(QDialog):
    def __init__(self, parent=None) -> None:
        super().__init__(parent)
        self.setWindowTitle("Настройка сессии")
        self.resize(500, 200)
        self.setStyleSheet(STYLESHEET)
        self.result_params: Optional[dict] = None

        layout = QVBoxLayout(self)
        layout.setContentsMargins(0, 0, 0, 0)
        layout.addWidget(make_header("Настройка сессии расчёта"))
        body = QWidget()
        bl = QVBoxLayout(body)
        bl.setContentsMargins(24, 16, 24, 16)
        bl.addWidget(QLabel("Нажмите «Начать» — программа проведёт вас шаг за шагом."))
        bl.addSpacing(12)
        ok_btn = QPushButton("Начать →")
        ok_btn.clicked.connect(self._build)
        bl.addWidget(ok_btn)
        layout.addWidget(body)

    def _build(self) -> None:
        parent = self.parent()

        dlg = MonthDialog(parent)
        if dlg.exec_() != QDialog.Accepted:
            return
        month = dlg.result_month

        dlg2 = MRFDialog(parent)
        if dlg2.exec_() != QDialog.Accepted:
            return
        chosen_mrf = dlg2.chosen

        table3_path, _ = QFileDialog.getOpenFileName(
            parent, "Выберите файл отчёта (Таблица 3)",
            os.path.expanduser("~/Desktop"), "Excel files (*.xlsx)")
        if not table3_path:
            return

        try:
            df_head = pd.read_excel(table3_path, sheet_name=SHEET_TABLE3, nrows=0)
        except Exception as e:
            QMessageBox.critical(parent, "Ошибка", f"Не могу открыть отчёт:\n{e}")
            return

        target_col = next(
            (col for col in df_head.columns
             if month in str(col).lower()
             and all(kw in str(col).lower() for kw in TARGET_KEYWORDS)), None)
        if not target_col:
            QMessageBox.critical(parent, "Ошибка",
                                 f"Нет целевой колонки для '{month}'.\n"
                                 f"Колонка должна содержать: {TARGET_KEYWORDS}")
            return

        try:
            _filter_cols = [RPT_COL_DATE, RPT_COL_SERVICE, RPT_COL_MRF,
                            RPT_COL_RF, RPT_COL_SEGMENT, RPT_COL_SUBSEG]
            _avail = [c for c in df_head.columns
                      if any(fc.lower() == str(c).lower() for fc in _filter_cols)]
            df_report = pd.read_excel(table3_path, sheet_name=SHEET_TABLE3,
                                      usecols=_avail if _avail else None)
        except Exception as e:
            QMessageBox.critical(parent, "Ошибка", f"Ошибка загрузки отчёта:\n{e}")
            return

        bases: Dict[str, List[dict]] = {}
        filters: Dict[str, dict] = {}
        total_bases = 0
        amount_col = f"Без НДС {month}"

        for mrf in chosen_mrf:
            bases[mrf] = []
            base_num = 0

            while True:
                base_num += 1
                reply = QMessageBox.question(
                    parent, f"МРФ {fmt_mrf(mrf)}",
                    f"Загрузить базу #{base_num} для МРФ {fmt_mrf(mrf)}?",
                    QMessageBox.Yes | QMessageBox.No)
                if reply != QMessageBox.Yes:
                    break

                base_path, _ = QFileDialog.getOpenFileName(
                    parent, f"База #{base_num} — МРФ {fmt_mrf(mrf)}",
                    os.path.expanduser("~/Desktop"), "Excel files (*.xlsx)")
                if not base_path:
                    break

                try:
                    df_tmp = pd.read_excel(base_path, sheet_name=SHEET_TABLE2, nrows=5)
                except Exception as e:
                    QMessageBox.critical(parent, "Ошибка", f"Не могу открыть базу:\n{e}")
                    continue

                mode_dlg = ChargesModeDialog(os.path.basename(base_path), mrf, parent)
                if mode_dlg.exec_() != QDialog.Accepted:
                    continue
                charges_mode = mode_dlg.mode

                col_dlg = ColumnDialog(list(df_tmp.columns),
                                       f"МРФ {fmt_mrf(mrf)} — база #{base_num}: начисление ДО",
                                       "Выберите колонку с НАЧИСЛЕНИЕМ ДО ИНДЕКСАЦИИ:", parent)
