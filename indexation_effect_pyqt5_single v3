# Утилиты нормализации
# ============================================================================

def unmap_rf(canon_value: Any) -> str:
    key = " ".join(str(canon_value).replace("xa0", " ").strip().lower().split())
    return RF_REVERSE.get(key, str(canon_value))


def fmt_title(x: Any) -> Any:
    if pd.isna(x) or str(x).strip() == "":
        return x
    s = str(x).strip()
    return s[0].upper() + s[1:].lower()


def fmt_upper(x: Any) -> Any:
    if pd.isna(x) or str(x).strip() == "":
        return x
    return str(x).strip().upper()


def fmt_mrf(x: Any) -> Any:
    if pd.isna(x) or str(x).strip() == "":
        return x
    key = str(x).strip().lower()
    if key in MRF_EXACT:
        return MRF_EXACT[key]
    return fmt_title(x)


def fmt_service(x: Any) -> Any:
    if pd.isna(x) or str(x).strip() == "":
        return x
    s = str(x).strip()
    key = s.lower()
    if key in SERVICE_EXACT:
        return SERVICE_EXACT[key]
    if key in UPPERCASE_SERVICES:
        return s.upper()
    return fmt_title(s)


def fmt_seg(x: Any) -> Any:
    """
    Нормализация сегмента/подсегмента.
    Правила:
    • слово с латиницей или цифрами -> ВЕРХНИЙ регистр (VPN, B2B, 3K, M2M ...)
    • короткое (<=4) кириллическое слово -> ВЕРХНИЙ регистр (аббревиатура: ДНК, РУ, МРФ, РФ, ШПД, КК ...)
    • прочие кириллические слова -> с заглавной буквы (Прочие, Бизнес ...)
    """
    if pd.isna(x) or str(x).strip() == "":
        return x
    s = str(x).strip()
    result = []
    for word in s.split():
        if re.search(r'[a-zA-Z0-9]', word):
            result.append(word.upper())
        else:
            letters = re.sub(r'[^a-zA-Zа-яА-Я]', '', word)
            if len(letters) <= 4:
                result.append(word.upper())
            else:
                result.append(word.capitalize())
    return ' '.join(result)


def fmt_pct(x: Any) -> Any:
    try:
        v = float(str(x).replace(",", ".").replace("%", "").strip())
        return v / 100 if v > 1 else v
    except (ValueError, TypeError):
        return x


def fmt_num3(x: Any) -> Any:
    try:
        return round(float(x), 3)
    except (ValueError, TypeError):
        return x


def fmt_rf(x: Any) -> Any:
    if pd.isna(x) or str(x).strip() == "":
        return x
    s = str(x).strip()
    canon = canonical_rf_from_display(s)
    if canon in RF_REVERSE:
        return RF_REVERSE[canon]
    return fmt_title(s)


def find_col_name(df: pd.DataFrame, name: str) -> Optional[str]:
    name_lower = name.strip().lower()
    for c in df.columns:
        if str(c).strip().lower() == name_lower:
            return c
    return None


def norm_text(x: Any) -> str:
    if pd.isna(x):
        return ""
    return "".join(str(x).replace("\\xa0", "").strip().lower().split())


def norm_date(x: Any) -> str:
    if x is None:
        return ""
    try:
        if pd.isna(x):
            return ""
    except TypeError:
        pass
    dt = pd.to_datetime(x, errors="coerce", dayfirst=True)
    if pd.isna(dt):
        return str(x).strip()
    return dt.strftime("%d.%m.%Y")


def map_rf(raw_value: Any) -> str:
    raw_str = str(raw_value).strip()
    if raw_str in RF_MAPPING:
        return norm_text(RF_MAPPING[raw_str])
    raw_lower = raw_str.lower()
    if raw_lower in RF_MAPPING:
        return norm_text(RF_MAPPING[raw_lower])
    return norm_text(raw_str)


def canonical_rf_from_display(val: str) -> str:
    key = norm_text(val)
    return RF_REVERSE.get(key, map_rf(val))


