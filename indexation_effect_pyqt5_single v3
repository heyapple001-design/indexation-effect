    def __init__(self, parent=None):
        super().__init__(parent)
        self._checkbox_vars: Dict[str, Dict[str, QCheckBox]] = {}
        self._build()

    def _build(self):
        self.title_lbl = QLabel("Шаг 4. Фильтры")
        self.title_lbl.setObjectName("subheader")
        self._layout.addWidget(self.title_lbl)
        self.add_hint("Выберите дату индексации и нужные значения. Фильтр по УСЛУГЕ обязателен.")

        date_layout = QHBoxLayout()
        date_layout.addWidget(QLabel("Дата индексации:"))
        self.date_combo = QComboBox()
        self.date_combo.setMinimumWidth(200)
        date_layout.addWidget(self.date_combo)
        date_layout.addStretch()
        self._layout.addLayout(date_layout)

        self.scroll = QScrollArea()
        self.scroll.setWidgetResizable(True)
        self.scroll.setHorizontalScrollBarPolicy(Qt.ScrollBarAlwaysOff)
        self.scroll.setMaximumHeight(400)
        self.container = QWidget()
        self.cl = QVBoxLayout(self.container)
        self.cl.setSpacing(8)
        self.cl.setContentsMargins(5, 5, 5, 5)
        self.scroll.setWidget(self.container)
        self._layout.addWidget(self.scroll)

    def reset(self, df_report: pd.DataFrame, mrf_name: str):
        self.title_lbl.setText(f"Шаг 4. Фильтры — МРФ {fmt_mrf(mrf_name)}")
        self.df_report = df_report
        self.mrf_name = mrf_name
        self._checkbox_vars = {}

        while self.cl.count():
            item = self.cl.takeAt(0)
            if item.widget():
                item.widget().deleteLater()

        self.date_combo.clear()
        if RPT_COL_DATE in df_report.columns:
            raw_dates = df_report[RPT_COL_DATE].dropna().unique()
            udates = sorted(
                set(norm_date(d) for d in raw_dates if norm_date(d)),
                key=lambda d: pd.to_datetime(d, dayfirst=True, errors="coerce"),
                reverse=False
            )
            self.date_combo.addItems(["выберите дату"] + list(udates))
        else:
            self.date_combo.addItem("(нет колонки даты)")
            self.date_combo.setEnabled(False)

        mrf_rf_canonical = set()
        if mrf_name and mrf_name in MRF_TO_RF:
            for rf_raw in MRF_TO_RF[mrf_name]:
                mrf_rf_canonical.add(norm_text(map_rf(rf_raw)))
        mrf_norm = norm_text(mrf_name)

        cols = [c for c in [RPT_COL_SERVICE, RPT_COL_MRF, RPT_COL_RF,
                            RPT_COL_SEGMENT, RPT_COL_SUBSEG]
                if c in df_report.columns]

        for col in cols:
            dn = col.replace(".1", "")
            is_service = (dn == "Услуга")
            group = QGroupBox(f"{'★ ' if is_service else ''}{dn}{' — обязательно!' if is_service else ''}")
            if is_service:
                group.setStyleSheet("QGroupBox{color:#C42B1C;font-weight:bold;}")

            gl = QVBoxLayout(group)
            gl.setSpacing(4)
            gl.setContentsMargins(8, 6, 8, 6)

            if col == RPT_COL_RF and mrf_rf_canonical:
                hint = QLabel(f"✓ Автоматически выбраны РФ МРФ {mrf_name}")
                hint.setObjectName("hint")
                gl.addWidget(hint)
            if col == RPT_COL_MRF and mrf_norm:
                hint = QLabel(f"✓ Автоматически выбран МРФ {mrf_name}")
                hint.setObjectName("hint")
                gl.addWidget(hint)

            btn_row = QHBoxLayout()
            btn_all = QPushButton("✓ Все")
            btn_all.setObjectName("secondaryButton")
            btn_all.setFixedWidth(60)
            btn_all.clicked.connect(lambda checked, c=col: self._select_all(c))
            btn_none = QPushButton("✕ Снять")
            btn_none.setObjectName("secondaryButton")
            btn_none.setFixedWidth(60)
            btn_none.clicked.connect(lambda checked, c=col: self._deselect_all(c))
            btn_row.addWidget(btn_all)
            btn_row.addWidget(btn_none)
            btn_row.addStretch()
            gl.addLayout(btn_row)

            values = self._make_values(col, df_report, mrf_rf_canonical)
            self._checkbox_vars[col] = {}

            widget = QWidget()
            vgl = QGridLayout(widget)
            vgl.setSpacing(4)
            vgl.setContentsMargins(2, 2, 2, 2)
            max_c = 4
            rows = (len(values) + max_c - 1) // max_c if max_c else 1
            for idx, val in enumerate(values):
                r, cn = idx % rows, idx // rows
                default = self._auto_check(col, val, mrf_rf_canonical, mrf_norm)
                cb = QCheckBox(val)
                cb.setChecked(default)
                cb.setMinimumHeight(22)
                self._checkbox_vars[col][val] = cb
                vgl.addWidget(cb, r, cn, Qt.AlignLeft)

            if len(values) > 15:
                inner = QScrollArea()
                inner.setWidgetResizable(True)
                inner.setFixedHeight(120)
                inner.setHorizontalScrollBarPolicy(Qt.ScrollBarAlwaysOff)
                inner.setWidget(widget)
                gl.addWidget(inner)
            else:
                gl.addWidget(widget)
            self.cl.addWidget(group)

        if self.cl.count() < 6:
            self.cl.addStretch()

    def _make_values(self, col: str, df_report: pd.DataFrame, mrf_rf_canonical: Set[str]) -> List[str]:
        s = df_report[col].dropna()
        if col == RPT_COL_RF:
            all_vals = sorted(dict.fromkeys(unmap_rf(canonical_rf_from_display(x)) for x in s if str(x).strip()))
            if mrf_rf_canonical:
                filtered = [v for v in all_vals if canonical_rf_from_display(v) in mrf_rf_canonical]
                return filtered if filtered else all_vals
            return all_vals
        elif col == RPT_COL_MRF:
            return sorted(dict.fromkeys(fmt_mrf(v) for v in s if str(v).strip()))
        elif col == RPT_COL_SERVICE:
            return sorted(dict.fromkeys(fmt_service(str(v).strip()) for v in s if str(v).strip()))
        elif col in (RPT_COL_SEGMENT, RPT_COL_SUBSEG):
            return sorted(dict.fromkeys(fmt_seg(str(v).strip()) for v in s if str(v).strip()))
        else:
            vals = [norm_text(v) for v in s]
            return sorted(dict.fromkeys([v for v in vals if v]))

    def _auto_check(self, col: str, val: str, mrf_rf_canonical: Set[str], mrf_norm: str) -> bool:
        if col == RPT_COL_RF:
            return canonical_rf_from_display(val) in mrf_rf_canonical
        if col == RPT_COL_MRF:
            return fmt_mrf(val).lower() == mrf_norm or val == fmt_mrf(self.mrf_name)
        return False

    def _select_all(self, col: str):
        for cb in self._checkbox_vars[col].values():
            cb.setChecked(True)

    def _deselect_all(self, col: str):
        for cb in self._checkbox_vars[col].values():
            cb.setChecked(False)

    def validate(self) -> Tuple[bool, str]:
        if not self.date_combo.isEnabled() or self.date_combo.currentText() == "выберите дату":
            return False, "Выберите дату индексации"

        svc_col = RPT_COL_SERVICE if RPT_COL_SERVICE in self._checkbox_vars else None
        if svc_col and not any(cb.isChecked() for cb in self._checkbox_vars[svc_col].values()):
            return False, "Выберите хотя бы одну УСЛУГУ"
        return True, ""

    def get_data(self) -> dict:
        selected = {}
        for c in self._checkbox_vars:
            selected[c] = [val for val, cb in self._checkbox_vars[c].items() if cb.isChecked()]
        return {
            "date": self.date_combo.currentText(),
            "selected": selected
        }


