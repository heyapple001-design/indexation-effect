def calc_pivot_external(df_base: pd.DataFrame, df_amount: pd.DataFrame,
                        base_col: str, id_col: str,
                        amount_col: str, group_cols: List[str]) -> pd.DataFrame:
    df_base = df_base.copy()
    df_amount = df_amount.copy()
    df_base[base_col] = pd.to_numeric(df_base[base_col], errors='coerce')
    df_amount[amount_col] = pd.to_numeric(df_amount[amount_col], errors='coerce')
    df_base[id_col] = df_base[id_col].astype(str).str.strip().str.replace('+7', '', regex=False)
    df_amount["MSISDN"] = df_amount["MSISDN"].astype(str).str.strip().str.replace('+7', '', regex=False)
    merged = df_base.merge(df_amount[["MSISDN", amount_col]],
                           left_on=id_col, right_on="MSISDN", how='left')
    merged['Эффект_руб'] = merged[amount_col] - merged[base_col]
    merged.loc[merged['Эффект_руб'] < 0, 'Эффект_руб'] = 0

    extra_cols = [c for c in [BASE_COL_PCT, BASE_COL_SEGMENT1] if c in merged.columns]
    agg_dict = {'Эффект_руб': 'sum'}
    for c in extra_cols:
        agg_dict[c] = 'first'

    pivot = merged.groupby(group_cols, as_index=False).agg(agg_dict)
    return pivot


def calc_pivot_inbase(df_base: pd.DataFrame, base_col: str,
                      current_col: str, group_cols: List[str]) -> pd.DataFrame:
    df_base = df_base.copy()
    df_base[base_col] = pd.to_numeric(df_base[base_col], errors='coerce')
    df_base[current_col] = pd.to_numeric(df_base[current_col], errors='coerce')
    df_base['Эффект_руб'] = df_base[current_col] - df_base[base_col]
    df_base.loc[df_base['Эффект_руб'] < 0, 'Эффект_руб'] = 0

    extra_cols = [c for c in [BASE_COL_PCT, BASE_COL_SEGMENT1] if c in df_base.columns]
    agg_dict = {'Эффект_руб': 'sum'}
    for c in extra_cols:
        agg_dict[c] = 'first'

    pivot = df_base.groupby(group_cols, as_index=False).agg(agg_dict)
    return pivot


def process_one_base(df_base: pd.DataFrame, df_amount: Optional[pd.DataFrame],
                     df_report: pd.DataFrame, base_col: str, id_col: Optional[str],
                     amount_col: str, current_col: Optional[str],
                     charges_mode: str, available_group_cols: List[str],
                     target_col: str, selected_filters: dict):
    print(f"==== process_one_base started ===")
    print(f"target_col: {target_col}")
    print(f"available_group_cols: {available_group_cols}")
    print(f"charges_mode: {charges_mode}")

    if not selected_filters or not selected_filters.get("date") or selected_filters.get("selected") is None:
        print("Нет фильтров")
        return None

    selected_date = selected_filters["date"]
    selected_segments = selected_filters.get("selected") or {}
    selected_services = selected_segments.get(RPT_COL_SERVICE, [])

    print(f"selected_date: {selected_date}")
    print(f"selected_services: {selected_services}")

    try:
        if charges_mode == MODE_EXTERNAL:
            print("Режим external")
            pivot = calc_pivot_external(df_base, df_amount, base_col, id_col,
                                        amount_col, available_group_cols)
        else:
            print("Режим inbase")
            pivot = calc_pivot_inbase(df_base, base_col, current_col, available_group_cols)

        print(f"Pivot shape: {pivot.shape}")

        if pivot.empty:
            print("Pivot пустой")
            return 0, 0, [], [], [], 0.0, df_report

        # Проверяем, есть ли колонка Эффект_тыс
        if 'Эффект_тыс' not in pivot.columns:
            print(f"Колонка 'Эффект_тыс' не найдена. Доступные колонки: {list(pivot.columns)}")
            if 'Эффект_руб' in pivot.columns:
                pivot['Эффект_тыс'] = (pivot['Эффект_руб'] / 1000).round(3)
            else:
                print("Колонка 'Эффект_руб' тоже не найдена")
                pivot['Эффект_тыс'] = 0

        total_rpt = len(df_report)
        print(f"Длина отчета: {total_rpt}")

        # Строим словарь отчёта для быстрого поиска
        report_dict = defaultdict(list)
        for idx, r in df_report.iterrows():
            svc = norm_text(r[RPT_COL_SERVICE]) if RPT_COL_SERVICE in r.index else ""
            mrf = norm_text(r[RPT_COL_MRF]) if RPT_COL_MRF in r.index else ""
            rf = canonical_rf_from_display(r[RPT_COL_RF]) if RPT_COL_RF in r.index else ""
            seg = norm_text(r[RPT_COL_SEGMENT]) if RPT_COL_SEGMENT in r.index else ""
            sub = norm_text(r[RPT_COL_SUBSEG]) if RPT_COL_SUBSEG in r.index else ""
            key = (svc, mrf, rf, seg, sub)
            report_dict[key].append(idx)

        print(f"Словарь отчета построен, ключей: {len(report_dict)}")

        # Строим lookup для процентов
        pct_col_report = find_col_name(df_report, RPT_COL_PCT)
        pct_lookup = {}
        if pct_col_report and total_rpt > 0:
            for key_full, ridxs in report_dict.items():
                mrf_k = key_full[1]
                rf_k = key_full[2]
                for ridx in ridxs:
                    val = df_report.loc[ridx, pct_col_report]
                    if pd.notna(val) and str(val).strip() not in ("", "0", "0.0"):
                        pct_lookup[(mrf_k, rf_k)] = fmt_pct(val)
                        break

        filter_mrfs = set(selected_segments.get(RPT_COL_MRF, []))
        filter_rfs = set(selected_segments.get(RPT_COL_RF, []))
        filter_segments = set(selected_segments.get(RPT_COL_SEGMENT, []))
        filter_subseg = set(selected_segments.get(RPT_COL_SUBSEG, []))

        print(f"Фильтры: МРФ={filter_mrfs}, РФ={filter_rfs}")

        not_found_indices = []

        # Помечаем строки, которые не будут найдены в базе
        if total_rpt > 0:
            pivot_keys = set()
            for _, pr in pivot.iterrows():
                mrf_ = norm_text(pr[BASE_COL_MRF]) if BASE_COL_MRF in pr.index else ""
                rf_ = canonical_rf_from_display(pr[BASE_COL_RF]) if BASE_COL_RF in pr.index else ""
                seg_ = norm_text(pr[BASE_COL_SEGMENT]) if BASE_COL_SEGMENT in pr.index else ""
                sub_ = norm_text(pr[BASE_COL_SUBSEG]) if BASE_COL_SUBSEG in pr.index else ""
                pivot_keys.add((mrf_, rf_, seg_, sub_))

            for key_full, ridxs in report_dict.items():
                row_mrf = key_full[1]
                row_rf = key_full[2]
                row_seg = key_full[3]
                row_sub = key_full[4]

                if filter_mrfs and row_mrf not in filter_mrfs:
                    continue
                if filter_rfs and row_rf not in filter_rfs:
                    continue
                if filter_segments and row_seg not in filter_segments:
                    continue
                if filter_subseg and row_sub not in filter_subseg:
                    continue

                key_no_svc = (row_mrf, row_rf, row_seg, row_sub)
                if key_no_svc not in pivot_keys:
                    for ridx in ridxs:
                        try:
                            cur = df_report.loc[ridx, target_col]
                            if pd.isna(cur):
                                df_report.loc[ridx, target_col] = 0
                        except (TypeError, KeyError, IndexError):
                            pass
                        not_found_indices.append(ridx)

        updated_count = 0
        added_count = 0
        matched_indices = []
        added_indices = []

        # Основной цикл сопоставления
        for _, pivot_row in pivot.iterrows():
            eff_value = pivot_row.get('Эффект_тыс', 0)
            if eff_value == 0:
                continue

            service = fmt_service(pivot_row.get(BASE_COL_SERVICE, ""))
            if selected_services and service not in selected_services:
                continue

            mrf_val = fmt_mrf(pivot_row.get(BASE_COL_MRF, ""))
            rf_val = unmap_rf(canonical_rf_from_display(pivot_row.get(BASE_COL_RF, "")))
            seg_val = fmt_seg(pivot_row.get(BASE_COL_SEGMENT, ""))
            sub_val = fmt_seg(pivot_row.get(BASE_COL_SUBSEG, ""))

            # Поиск в отчете
            found = False
            for idx, r in df_report.iterrows():
                r_svc = fmt_service(r[RPT_COL_SERVICE]) if RPT_COL_SERVICE in r.index else ""
                r_mrf = fmt_mrf(r[RPT_COL_MRF]) if RPT_COL_MRF in r.index else ""
                r_rf = unmap_rf(canonical_rf_from_display(r[RPT_COL_RF])) if RPT_COL_RF in r.index else ""
                r_seg = fmt_seg(r[RPT_COL_SEGMENT]) if RPT_COL_SEGMENT in r.index else ""
                r_sub = fmt_seg(r[RPT_COL_SUBSEG]) if RPT_COL_SUBSEG in r.index else ""

                if (service == r_svc and mrf_val == r_mrf and
                    rf_val == r_rf and seg_val == r_seg and sub_val == r_sub):
                    # Обновляем существующую строку
                    df_report.loc[idx, target_col] = fmt_num3(eff_value)
                    matched_indices.append(idx)
                    updated_count += 1
                    found = True
                    break

            if not found:
                # Добавляем новую строку
                new_row = {}
                if RPT_COL_SERVICE in df_report.columns:
                    new_row[RPT_COL_SERVICE] = service
                if RPT_COL_DATE in df_report.columns:
                    new_row[RPT_COL_DATE] = selected_date
                if RPT_COL_PCT in df_report.columns:
                    mrf_key = norm_text(mrf_val)
                    rf_key = canonical_rf_from_display(rf_val)
                    pct_val = pct_lookup.get((mrf_key, rf_key))
                    if pct_val is None:
                        pct_val = pivot_row.get(BASE_COL_PCT, None)
                        if pct_val is not None:
                            pct_val = fmt_pct(pct_val)
                    new_row[RPT_COL_PCT] = pct_val if pct_val is not None else 0
                if RPT_COL_MRF in df_report.columns:
                    new_row[RPT_COL_MRF] = mrf_val
                if RPT_COL_RF in df_report.columns:
                    new_row[RPT_COL_RF] = rf_val
                if RPT_COL_SEGMENT in df_report.columns:
                    new_row[RPT_COL_SEGMENT] = seg_val
                if RPT_COL_SEGMENT1 in df_report.columns:
                    new_row[RPT_COL_SEGMENT1] = fmt_seg(pivot_row.get(BASE_COL_SEGMENT1, ""))
                if RPT_COL_SUBSEG in df_report.columns:
                    new_row[RPT_COL_SUBSEG] = sub_val
                new_row[target_col] = fmt_num3(eff_value)

                idx = len(df_report)
                df_report.loc[idx] = new_row
                added_indices.append(idx)
                added_count += 1

        total_eff = pivot['Эффект_тыс'].sum()
        print(f'Итог: updated={updated_count}, added={added_count}, eff={total_eff}')

        return updated_count, added_count, matched_indices, added_indices, not_found_indices, total_eff, df_report

    except Exception as e:
        print(f'Ошибка в process_one_base: {e}')
        import traceback
        traceback.print_exc()
        raise


