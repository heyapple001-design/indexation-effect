            self.combo_base_col.clear()
            self.combo_base_col.addItems(cols)
            self.combo_id_col.clear()
            self.combo_id_col.addItems(cols)
            self.combo_current_col.clear()
            self.combo_current_col.addItems(cols)

            for c in cols:
                if "до" in c.lower() or "начисление" in c.lower():
                    self.combo_base_col.setCurrentText(c)
                    break

            possible_ids = ["MSISDN", "Уникальный идентификационный номер услуги (ШПД, VPN - логин порта)",
                           "Уникальный идентификационный номер услуги", "MSISDN/Логин"]
            id_col = next((c for c in possible_ids if c in cols), None)
            if id_col:
                self.combo_id_col.setCurrentText(id_col)

            for c in cols:
                if "без ндс" in c.lower() or "текущ" in c.lower() or "после" in c.lower():
                    self.combo_current_col.setCurrentText(c)
                    break

