        else:
            self.mrf_lbl.setText("МРФ: —")

        self.base_lbl.setText(f"База: #{self.current_base_num}" if self.current_base_num > 0 else "База: —")

        self.back_btn.setEnabled(self.state != "start" and self.state != "summary")

        if self.state == "summary":
            self.next_btn.setVisible(False)
            self.back_btn.setVisible(False)
        elif self.state == "process" or self.state == "save":
            self.next_btn.setVisible(False)
            self.back_btn.setVisible(False)
        else:
            self.next_btn.setVisible(True)
            self.back_btn.setVisible(True)
            self.next_btn.setText("Далее →")

    def set_status(self, text: str):
        self.status_lbl.setText(text)

    def on_next(self):
        if self.state == "start":
            ok, msg = self._page("start").validate()
            if not ok:
                QMessageBox.warning(self, "Внимание", msg)
                return
            data = self._page("start").get_data()
            self.month = data["month"]
            self.amount_col = f"Без НДС {self.month}"
            self.chosen_mrf = data["mrf"]
            self.current_mrf_idx = 0
            self.current_base_num = 0
            self.session_summary = []
            self.session_counts = {"matched": 0, "added": 0, "not_found": 0}
            # сброс общего пути сохранения для нового расчёта
            save_page = self._page("save")
            save_page._common_path = ""
            save_page._common_month = ""
            save_page._filename_generated = False
            self._go_to("report")

        elif self.state == "report":
            ok, msg = self._page("report").validate()
            if not ok:
                QMessageBox.warning(self, "Внимание", msg)
                return
            self.table3_path = self._page("report").get_data()["path"]
            self._load_report()

        elif self.state == "base":
            ok, msg = self._page("base").validate()
            if not ok:
                QMessageBox.warning(self, "Внимание", msg)
                return
            self._load_base_and_charges()

        elif self.state == "filter":
            ok, msg = self._page("filter").validate()
            if not ok:
                QMessageBox.warning(self, "Внимание", msg)
                return
            self._run_calculation()

        elif self.state == "save":
            ok, msg = self._page("save").validate()
            if not ok:
                QMessageBox.warning(self, "Внимание", msg)
                return
            self._run_save()

    def on_back(self):
        if self.history:
            prev = self.history.pop()
            self.state = prev
            self._update_ui()

    def _go_to(self, state: str):
        if self.state != state:
            self.history.append(self.state)
            self.state = state
            self._update_ui()

    def _load_report(self):
        page = self._page("report")
        page.set_info("Загрузка отчёта...")
        self.set_status("Загрузка отчёта...")
        self.next_btn.setEnabled(False)
        self.back_btn.setEnabled(False)

        worker = LoadExcelWorker(self.table3_path, SHEET_TABLE3)
        worker.finished.connect(self._on_report_loaded)
        worker.error.connect(self._on_report_error)
        self._workers.append(worker)
        worker.start()

    def _on_report_loaded(self, df, elapsed):
        self.df_report = df
        page = self._page("report")
        page.set_info(f"✓ Загружено: {len(df):,} строк ({elapsed:.1f} сек)")
        self.set_status(f"Отчёт загружен: {len(df):,} строк")

        self.target_col = None
        for col in self.df_report.columns:
            cs = str(col).lower()
            if self.month in cs and all(kw in cs for kw in TARGET_COL_KEYWORDS):
                self.target_col = col
                break

        if not self.target_col:
            QMessageBox.critical(self, "Ошибка",
                                 f"Нет целевой колонки для '{self.month}'\n"
                                 f"Колонка должна содержать: {TARGET_COL_KEYWORDS}")
            self.next_btn.setEnabled(True)
            self.back_btn.setEnabled(True)
            return

        self._start_mrf_base()

    def _on_report_error(self, error):
        QMessageBox.critical(self, "Ошибка", f"Ошибка загрузки отчёта:\n{error}")
        self.set_status("Ошибка загрузки отчёта")
        self.next_btn.setEnabled(True)
        self.back_btn.setEnabled(True)

    def _start_mrf_base(self):
        self.current_mrf_idx = 0
        self.current_base_num = 0
        self.df_amount_cache = None
        self._start_next_base()

    def _start_next_base(self):
        self.current_base_num += 1
        mrf_name = self.chosen_mrf[self.current_mrf_idx]
        self._page("base").reset(mrf_name, self.current_base_num)
        self._go_to("base")
        self.next_btn.setEnabled(True)

    def _load_base_and_charges(self):
        data = self._page("base").get_data()
        self.base_data = data
        self._page("base").base_info.setText("Загрузка базы...")
        self.set_status("Загрузка базы индексации...")
        self.next_btn.setEnabled(False)
        self.back_btn.setEnabled(False)

        worker = LoadExcelWorker(data["base_path"], SHEET_TABLE2)
        worker.finished.connect(self._on_base_loaded)
        worker.error.connect(self._on_base_error)
        self._workers.append(worker)
        worker.start()

    def _on_base_loaded(self, df, elapsed):
        self.df_base = df
        self._page("base").base_info.setText(f"✓ {len(df):,} строк ({elapsed:.1f} сек)")
        self.set_status(f"База загружена: {len(df):,} строк")

        if self.base_data["mode"] == MODE_EXTERNAL:
            if self.df_amount_cache is not None:
                self._after_charges_loaded()
            else:
                self._load_charges()
        else:
            self._after_charges_loaded()

    def _on_base_error(self, error):
        QMessageBox.critical(self, "Ошибка", f"Ошибка загрузки базы:\n{error}")
        self.set_status("Ошибка загрузки базы")
        self.next_btn.setEnabled(True)
        self.back_btn.setEnabled(True)

    def _load_charges(self):
        self.set_status("Загрузка файла начислений...")
        worker = LoadExcelWorker(self.base_data["charges_path"], SHEET_TABLE1)
        worker.finished.connect(self._on_charges_loaded)
        worker.error.connect(self._on_charges_error)
        self._workers.append(worker)
        worker.start()

    def _on_charges_loaded(self, df, elapsed):
        self.df_amount_cache = df
        self._page("base").charges_info.setText(f"✓ {len(df):,} строк ({elapsed:.1f} сек)")
        self.set_status(f"Начисления загружены: {len(df):,} строк")

        if self.amount_col not in df.columns:
            QMessageBox.critical(self, "Ошибка",
                                 f"В файле начислений нет колонки '{self.amount_col}'")
            self.df_amount_cache = None
            self.next_btn.setEnabled(True)
            self.back_btn.setEnabled(True)
            return

        if "MSISDN" not in df.columns:
            QMessageBox.critical(self, "Ошибка",
                                 "В файле начислений нет колонки 'MSISDN'")
            self.df_amount_cache = None
            self.next_btn.setEnabled(True)
            self.back_btn.setEnabled(True)
            return

        self._after_charges_loaded()

    def _on_charges_error(self, error):
        QMessageBox.critical(self, "Ошибка", f"Ошибка загрузки начислений:\n{error}")
        self.set_status("Ошибка загрузки начислений")
        self.next_btn.setEnabled(True)
        self.back_btn.setEnabled(True)

    def _after_charges_loaded(self):
        gcols = [c for c in [BASE_COL_MRF, BASE_COL_RF, BASE_COL_SEGMENT,
                             BASE_COL_SUBSEG, BASE_COL_SEGMENT1]
                 if c in self.df_base.columns]

        if not gcols:
            QMessageBox.critical(self, "Ошибка",
                                 "В базе нет колонок группировки (МРФ, РФ, Сегмент, Подсегмент)")
            self.next_btn.setEnabled(True)
            self.back_btn.setEnabled(True)
            return

        self.gcols = gcols
        self._page("filter").reset(self.df_report, self.chosen_mrf[self.current_mrf_idx])
        self._go_to("filter")
        self.next_btn.setEnabled(True)

    def _run_calculation(self):
        selected_filters = self._page("filter").get_data()
        self.selected_filters = selected_filters
        self.selected_date = selected_filters.get("date", "")

        page = self._page("process")
        page.reset("Шаг 5. Расчёт эффекта", "Идёт расчёт и сопоставление...")
        self._go_to("process")
        self.set_status("Расчёт эффекта...")

        df_amount = self.df_amount_cache if self.base_data["mode"] == MODE_EXTERNAL else None

        worker = ProcessWorker(
            self.df_base, df_amount, self.df_report,
            self.base_data["base_col"], self.base_data["id_col"], self.amount_col,
            self.base_data["current_col"], self.base_data["mode"], self.gcols,
            self.target_col, selected_filters
        )
        worker.finished.connect(self._on_calculation_done)
        worker.error.connect(self._on_calculation_error)
        worker.progress.connect(self._on_process_progress)
        self._workers.append(worker)
        worker.start()

    def _on_process_progress(self, value):
        page = self._page("process")
        page.progress.setRange(0, 100)
        page.progress.setValue(value)
        QApplication.processEvents()

    def _on_calculation_done(self, result):
        if result is None:
            QMessageBox.warning(self, "Внимание",
                                "Расчёт не выполнен: пустой результат или не выбраны фильтры.")
            self._go_to("filter")
            return

        self.last_result = result
        upd, add, m_idx, a_idx, nf_idx, eff, df_report = result
        self.df_report = df_report

        self.session_counts["matched"] += upd
        self.session_counts["added"] += add
        self.session_counts["not_found"] += len(nf_idx)
        self.last_m_idx = m_idx
        self.last_a_idx = a_idx
        self.last_nf_idx = nf_idx
        self.last_eff = eff
        self.last_upd = upd
        self.last_add = add

        page = self._page("process")
        page.append_log(f"✓ Записано строк: {upd}")
        page.append_log(f"✓ Добавлено строк: {add}")
        page.append_log(f"✓ Эффект: {eff:,.3f} тыс. руб.")
        self.set_status("Расчёт завершён")

        mrf_name = (self.chosen_mrf[self.current_mrf_idx]
                    if self.chosen_mrf and self.current_mrf_idx < len(self.chosen_mrf)
                    else "")
        self._page("save").reset(
            current_path=self.table3_path,
            month=self.month,
            mrf_name=mrf_name,
            date=self.selected_date,
        )
        self._go_to("save")

    def _on_calculation_error(self, error):
        QMessageBox.critical(self, "Ошибка", f"Ошибка расчёта:\n{error}")
        self.set_status("Ошибка расчёта")
        self._go_to("filter")

    def _run_save(self):
        # Проверка на уже запущенный процесс сохранения
        if self._save_in_progress:
            print("Сохранение уже выполняется")
            return

        save_path = self._page("save").get_save_path()
        self.save_path = save_path

        print(f"=== Начинаем сохранение ===")
        print(f"Путь: {save_path}")
        print(f"Целевая колонка: {self.target_col}")
        print(f"DF shape: {self.df_report.shape}")
        print(f"Колонки DF: {list(self.df_report.columns)}")

        page = self._page("save")
        page.set_status("Сохранение файла...")
        page.progress.setRange(0, 100)
        page.progress.setValue(0)

        self.set_status("Сохранение файла...")
        self.next_btn.setEnabled(False)
        self.back_btn.setEnabled(False)

        # Проверяем, что target_col существует
        if self.target_col not in self.df_report.columns:
            QMessageBox.critical(self, "Ошибка",
                                 f"Целевая колонка '{self.target_col}' не найдена в отчете.\n"
                                 f"Доступные колонки: {list(self.df_report.columns)}")
            self.next_btn.setEnabled(True)
            self.back_btn.setEnabled(True)
            return

        # Проверка, что DataFrame не пустой
        if self.df_report.empty:
            QMessageBox.critical(self, "Ошибка",
                                 "DataFrame пуст, нечего сохранять")
            self.next_btn.setEnabled(True)
            self.back_btn.setEnabled(True)
            return

        self._save_in_progress = True

        worker = SaveWorker(
            self.df_report, self.target_col,
            self.last_m_idx, self.last_a_idx, self.last_nf_idx,
            save_path, self.month
        )
        worker.finished.connect(self._on_save_done)
        worker.error.connect(self._on_save_error)
        worker.progress.connect(self._on_save_progress)
        self._workers.append(worker)
        worker.start()

    def _on_save_progress(self, value):
        print(f"Прогресс сохранения: {value}%")
        page = self._page("save")
        page.progress.setValue(value)
        # Принудительно обновляем UI
        QApplication.processEvents()

    def _on_save_done(self, result):
        self._save_in_progress = False
        path, df, fallback_reason = result

        # В режиме «общий файл» сохраняем именно в общий путь,
        # чтобы следующие базы накапливались в него.
        if self._page("save").get_mode() == "common":
            self.table3_path = path
            self.df_report = df

        page = self._page("save")
        page.progress.setValue(100)
        status = f"✓ Сохранено: {path}"
        if fallback_reason:
            status += f"\n△ {fallback_reason}"
        page.set_status(status)
        self.set_status(f"Сохранено: {os.path.basename(path)}")

        # Подсказка пользователю, где именно лежит файл
        if fallback_reason:
            QMessageBox.information(
                self, "Файл сохранён (резервно)",
                f"Не удалось сохранить по выбранному пути (вероятно, файл открыт в Excel).\n\n"
                f"Файл сохранён сюда:\n{path}"
            )
        else:
            QMessageBox.information(
                self, "Готово",
                f"Файл успешно сохранён:\n{path}"
            )

        self.next_btn.setEnabled(True)
        self.back_btn.setEnabled(True)

        mode_str = "внешние начисления" if self.base_data["mode"] == MODE_EXTERNAL else "начисления из базы"
        summary = (
            f"База #{self.current_base_num} ({os.path.basename(self.base_data['base_path'])})\n"
            f"Режим: {mode_str}\n"
            f"Записано строк: {self.last_upd}\n"
            f"Добавлено строк: {self.last_add}\n"
            f"Эффект: {self.last_eff:,.3f} тыс. руб.\n"
            f"Не найдено в базе: {len(self.last_nf_idx)} строк\n"
            f"Сохранено: {path}"
        )

        has_next_mrf = self.current_mrf_idx + 1 < len(self.chosen_mrf)

        self.session_summary.append(f"\nМРФ {self.chosen_mrf[self.current_mrf_idx]}:")
        self.session_summary.append(summary.replace("\n", "\n  "))

        self.summary_page().reset(summary, has_next_mrf)
        self._go_to("summary")

    def _on_save_error(self, error):
        self._save_in_progress = False
        QMessageBox.critical(self, "Ошибка сохранения",
                             f"Не удалось сохранить файл:\n{error}")
        self.set_status("Ошибка сохранения")
        page = self._page("save")
        page.progress.setRange(0, 100)
        page.progress.setValue(0)
        self.next_btn.setEnabled(True)
        self.back_btn.setEnabled(True)

    def on_another_base(self):
        self._start_next_base()

    def on_next_mrf(self):
        self.current_mrf_idx += 1
        self.current_base_num = 0
        self.df_amount_cache = None
        self._start_next_base()

    def on_finish(self):
        if self.state == "summary" and not self.summary_page().btn_another_base.isVisible():
            self.close()
            return

        summary = (
            f"Расчёт за {self.month} 2026 завершён\n"
            f"МРФ: {', '.join(self.chosen_mrf)}\n\n"
            + "\n".join(self.session_summary)
            + f"\n\nЗаписано строк: {self.session_counts['matched']}\n"
            f"Добавлено новых строк: {self.session_counts['added']}\n"
            f"Не найдено в базе: {self.session_counts['not_found']} строк"
        )
        self.summary_page().set_final(summary)
        self._update_ui()

    def closeEvent(self, event):
        # Останавливаем все рабочие потоки
        for w in self._workers:
            if w.isRunning():
                w.terminate()
                w.wait(1000)
        event.accept()


# ============================================================================
# Точка входа
# ============================================================================

def get_app() -> QApplication:
    app = QApplication.instance()
    if app is None:
        app = QApplication(sys.argv)
    return app


def main():
    created = QApplication.instance() is None
    app = get_app()
    window = MainWindow()
    window.show()
    try:
        app.exec_()
    finally:
        if created:
            del app


if __name__ == "__main__":
    main()