        self.hint_lbl.setText(f"Загрузите базу индексации для МРФ {fmt_mrf(mrf_name)}. "
                              f"Если для этого МРФ несколько баз, обработаем их по очереди.")
        self._base_path = ""
        self._charges_path = ""
        self.base_edit.clear()
        self.base_edit.setPlaceholderText("Файл не выбран")
        self.base_info.clear()
        self.combo_base_col.clear()
        self.combo_id_col.clear()
        self.combo_current_col.clear()
        self.charges_edit.clear()
        self.charges_info.clear()
        self.radio_external.setChecked(True)
        self._on_mode_changed()

