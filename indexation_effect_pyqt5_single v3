class LoadExcelWorker(QThread):
    finished = pyqtSignal(object, float)
    error = pyqtSignal(str)

    def __init__(self, path: str, sheet_name: str):
        super().__init__()
        self.path = path
        self.sheet_name = sheet_name

    def run(self):
        try:
            start = datetime.now()
            df = pd.read_excel(self.path, sheet_name=self.sheet_name)
            elapsed = (datetime.now() - start).total_seconds()
            self.finished.emit(df, elapsed)
        except Exception as e:
            self.error.emit(str(e))


class SaveWorker(QThread):
    finished = pyqtSignal(object)
    error = pyqtSignal(str)
    progress = pyqtSignal(int)

    def __init__(self, df_report, target_col, matched, added, not_found, path, month):
        super().__init__()
        self.df_report = df_report
        self.target_col = target_col
        self.matched = matched or []
        self.added = added or []
        self.not_found = not_found or []
        self.path = path
        self.month = month
        self._is_running = False
        self._mutex = QMutex()

    def _emit_progress(self, value: int):
        self.progress.emit(max(0, min(100, value)))

    def _write_to(self, path: str) -> None:
        """
        Записать DataFrame + форматирование в указанный путь.
        Бросает исключение при ошибке.
        """
        df_report = self.df_report
        target_col = self.target_col

        dir_name = os.path.dirname(os.path.abspath(path))
        if dir_name:
            os.makedirs(dir_name, exist_ok=True)

        if target_col not in df_report.columns:
            raise ValueError(
                f"Целевая колонка '{target_col}' не найдена. Доступные: {list(df_report.columns)}"
            )

        # Запись DataFrame
        with pd.ExcelWriter(path, engine='openpyxl', mode='w') as writer:
            df_report.to_excel(writer, sheet_name=SHEET_TABLE3, index=False)

        # Открытие и форматирование
        wb = load_workbook(path)
        ws = wb[SHEET_TABLE3]

        grn = PatternFill(start_color=FILL_UPDATED, end_color=FILL_UPDATED, fill_type='solid')
        blue = PatternFill(start_color=FILL_ADDED, end_color=FILL_ADDED, fill_type='solid')
        yel = PatternFill(start_color=FILL_NOT_FOUND, end_color=FILL_NOT_FOUND, fill_type='solid')

        cols_list = list(df_report.columns)

        def col_idx(name: str) -> Optional[int]:
            return cols_list.index(name) + 1 if name in cols_list else None

        ci_target = col_idx(target_col)
        if ci_target is None:
            raise ValueError(f"Колонка '{target_col}' не найдена в списке колонок")

        ci_service = col_idx(RPT_COL_SERVICE)
        ci_date = col_idx(RPT_COL_DATE)
        ci_pct = col_idx(RPT_COL_PCT)
        ci_mrf = col_idx(RPT_COL_MRF)
        ci_rf = col_idx(RPT_COL_RF)
        ci_seg = col_idx(RPT_COL_SEGMENT)
        ci_sub = col_idx(RPT_COL_SUBSEG)

        FMT_DATE = "dd.mm.yyyy"
        FMT_PCT = "0.00%"
        FMT_NUM3 = "#,##0.00"
        FMT_TEXT = "@"

        max_row = ws.max_row
        max_col = len(cols_list)

        fmt_cols: List[Tuple[Optional[int], str]] = [
            (ci_service, FMT_TEXT),
            (ci_date, FMT_DATE),
            (ci_pct, FMT_PCT),
            (ci_mrf, FMT_TEXT),
            (ci_rf, FMT_TEXT),
            (ci_seg, FMT_TEXT),
            (ci_sub, FMT_TEXT),
            (ci_target, FMT_NUM3),
        ]

        for col_num, fmt in fmt_cols:
            if col_num is None or max_row < 2:
                continue
            try:
                for row_num in range(2, max_row + 1):
                    ws.cell(row=row_num, column=col_num).number_format = fmt
            except Exception as e:
                print(f"Ошибка применения формата к колонке {col_num}: {e}")

        # Зелёная — обновлённые строки (только целевая колонка)
        if ci_target:
            for ridx in self.matched:
                try:
                    row_num = ridx + 2
                    if 2 <= row_num <= max_row:
                        ws.cell(row=row_num, column=ci_target).fill = grn
                except Exception as e:
                    print(f"Ошибка зелёной заливки {ridx}: {e}")

        # Синяя — добавленные строки (все колонки)
        for ridx in self.added:
            try:
                row_num = ridx + 2
                if 2 <= row_num <= max_row:
                    for c in range(1, max_col + 1):
                        ws.cell(row=row_num, column=c).fill = blue
            except Exception as e:
                print(f"Ошибка синей заливки {ridx}: {e}")

        # Жёлтая — ненайденные в базе
        ci_mark = ci_target if ci_target else 1
        for ridx in self.not_found:
            try:
                row_num = ridx + 2
                if 2 <= row_num <= max_row:
                    ws.cell(row=row_num, column=ci_mark).fill = yel
            except Exception as e:
                print(f"Ошибка жёлтой заливки {ridx}: {e}")

        wb.save(path)

        # Финальная проверка, что файл действительно создан на диске
        if not os.path.exists(path):
            raise IOError(f"Файл не был создан: {path}")
        if os.path.getsize(path) == 0:
            raise IOError(f"Файл создан пустым: {path}")

    def run(self):
        with QMutexLocker(self._mutex):
            if self._is_running:
                print("Сохранение уже выполняется")
                return
            self._is_running = True

        try:
            print(f"== SaveWorker started ==")
            print(f"Path: {self.path}")
            print(f"Target col: {self.target_col}")
            print(f"DF shape: {self.df_report.shape}")
            print(f"Matched: {len(self.matched)}, Added: {len(self.added)}, Not found: {len(self.not_found)}")

            path = self.path
            if not path or not str(path).strip():
                self.error.emit("Не задан путь для сохранения файла.")
                return

            # Проверка, что DataFrame не пустой
            if self.df_report.empty:
                self.error.emit("DataFrame пуст, нечего сохранять")
                return

            self._emit_progress(10)
            saved_path = None
            fallback_reason = ""

            # Основная попытка записи в выбранный путь
            try:
                self._write_to(path)
                saved_path = path
                print(f"Файл успешно сохранён: {path}")

            except PermissionError as e:
                # Чаще всего — файл открыт в Excel / заблокирован.
                fallback_reason = (
                    f"Не удалось сохранить в выбранный путь\n{path}\n"
                    f"Причина: файл, вероятно, открыт в Excel или заблокирован "
                    f"({e}).\nПробую сохранить на Рабочий стол..."
                )
                print(fallback_reason)

            except OSError as e:
                fallback_reason = (
                    f"Ошибка записи в {path} ({e}).\n"
                    f"Пробую сохранить на Рабочий стол..."
                )
                print(fallback_reason)

            except Exception as e:
                fallback_reason = (
                    f"Неизвестная ошибка при сохранении в {path}:\n{e}\n"
                    f"Пробую сохранить на Рабочий стол..."
                )
                print(fallback_reason)
                traceback.print_exc()

            # Резервная попытка — на Рабочий стол
            if saved_path is None:
                desktop = os.path.expanduser("~/Desktop") or os.path.expanduser("~")
                base_name = os.path.basename(path) if path else "отчёт.xlsx"
                if not base_name.lower().endswith(".xlsx"):
                    base_name += ".xlsx"
                ts = datetime.now().strftime("%Y%m%d_%H%M%S")
                stem, ext = os.path.splitext(base_name)
                fb_path = os.path.join(desktop, f"{stem}_{ts}{ext}")
                try:
                    self._emit_progress(60)
                    self._write_to(fb_path)
                    saved_path = fb_path
                    print(f"Сохранено (резервно) на Рабочий стол: {fb_path}")
                except Exception as e2:
                    import traceback
                    traceback.print_exc()
                    msg = fallback_reason + f"\n\nРезервное сохранение тоже не удалось:\n{e2}"
                    self.error.emit(msg)
                    with QMutexLocker(self._mutex):
                        self._is_running = False
                    return

            self._emit_progress(100)
            final_path = os.path.abspath(saved_path)
            self.finished.emit((final_path, self.df_report, fallback_reason))

        except Exception as e:
            print(f"Критическая ошибка в SaveWorker: {e}")
            traceback.print_exc()
            self.error.emit(str(e))
        finally:
            with QMutexLocker(self._mutex):
                self._is_running = False


class ProcessWorker(QThread):
    finished = pyqtSignal(object)
    error = pyqtSignal(str)
    progress = pyqtSignal(int)

    def __init__(self, df_base, df_amount, df_report, base_col, id_col,
                 amount_col, current_col, charges_mode, group_cols,
                 target_col, selected_filters):
        super().__init__()
        self.df_base = df_base
        self.df_amount = df_amount
        self.df_report = df_report
        self.base_col = base_col
        self.id_col = id_col
        self.amount_col = amount_col
        self.current_col = current_col
        self.charges_mode = charges_mode
        self.group_cols = group_cols
        self.target_col = target_col
        self.selected_filters = selected_filters

    def run(self):
        try:
            self.progress.emit(10)
            result = process_one_base(
                self.df_base, self.df_amount, self.df_report,
                self.base_col, self.id_col, self.amount_col,
                self.current_col, self.charges_mode, self.group_cols,
                self.target_col, self.selected_filters
            )
            self.progress.emit(100)
            self.finished.emit(result)
        except Exception as e:
            self.error.emit(str(e))


