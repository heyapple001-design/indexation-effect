        if not self._base_path:
            return False, "Выберите файл базы индексации"
        if not self.combo_base_col.currentText():
            return False, "Выберите колонку 'ДО индексации'"
        if self.radio_external.isChecked():
            if not self.combo_id_col.currentText():
