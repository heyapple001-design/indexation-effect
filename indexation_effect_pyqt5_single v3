class SavePage(BasePage):
    def __init__(self, parent=None):
        super().__init__(parent)
        self._save_path = ""
        self._current_path = ""
        self._month = ""
        self._mrf_name = ""
        self._date = ""
        self._mode = "common"
        self._common_path = ""
        self._common_month = ""
        self._filename_generated = False  # Флаг для предотвращения повторной генерации
        self._build()

    def _build(self):
        self.add_header("Шаг 6. Сохранение")
        self.add_hint("Выберите способ сохранения результата расчёта.")

        # Режим сохранения
        g_mode = QGroupBox("Куда сохранять")
        gl = QVBoxLayout(g_mode)
        self.radio_common = QRadioButton(
            "Сохранять в один общий файл (накапливать все обработанные базы в один файл)"
        )
        self.radio_separate = QRadioButton("В отдельный файл для каждой базы")
        self.radio_common.setChecked(True)
        self.radio_common.toggled.connect(self._on_mode_changed)
        self.radio_separate.toggled.connect(self._on_mode_changed)
        gl.addWidget(self.radio_common)
        gl.addWidget(self.radio_separate)
        self.mode_hint = QLabel("")
        self.mode_hint.setObjectName("hint")
        self.mode_hint.setWordWrap(True)
        gl.addWidget(self.mode_hint)
        self._layout.addWidget(g_mode)

        self.name_lbl = QLabel("")
        self.name_lbl.setObjectName("hint")
        self.name_lbl.setWordWrap(True)
        self._layout.addWidget(self.name_lbl)

        row = QHBoxLayout()
        self.edit = QLineEdit()
        self.edit.setPlaceholderText("Имя файла")
        row.addWidget(self.edit)
        self.btn_browse = QPushButton("Обзор... (выбрать папку)")
        self.btn_browse.clicked.connect(self._browse)
        row.addWidget(self.btn_browse)
        self._layout.addLayout(row)

        self.progress = QProgressBar()
        self.progress.setRange(0, 100)
        self.progress.setTextVisible(True)
        self._layout.addWidget(self.progress)

        self.status_lbl = QLabel("")
        self.status_lbl.setObjectName("hint")
        self.status_lbl.setWordWrap(True)
        self._layout.addWidget(self.status_lbl)
        self.add_spacer()
        self._on_mode_changed()

    def _on_mode_changed(self):
        if self.radio_common.isChecked():
            self._mode = "common"
            self.mode_hint.setText(
                "Все обработанные базы/МРФ будут дописываться в один и тот же файл. "
                "Имя не зависит от МРФ и даты — чтобы результаты накопились вместе."
            )
        else:
            self._mode = "separate"
            self.mode_hint.setText(
                "Для каждой базы создаётся отдельный файл (имя включает МРФ и дату)."
            )
        # Сбрасываем флаг, чтобы перегенерировать имя при смене режима
        self._filename_generated = False
        self._generate_filename()

    def _slugify(self, s: str) -> str:
        if not s:
            return ""
        s = str(s).strip()
        s = re.sub(r'[\\/:*?"<>|]+', '_', s)
        s = re.sub(r'\s+', '_', s)
        return s.strip('_')

    def _dir_name(self) -> str:
        if self._current_path:
            return os.path.dirname(self._current_path) or os.path.expanduser("~/Desktop")
        return os.path.expanduser("~/Desktop")

    def _generate_filename(self) -> str:
        # Предотвращаем повторную генерацию, если уже сгенерировали и параметры не изменились
        if self._filename_generated and self._save_path:
            return self._save_path

        dir_name = self._dir_name()

        if self._mode == "common":
            # Используем сохраненный путь или генерируем новый
            if not self._common_path or self._common_month != self._month:
                month_slug = self._slugify(self._month) if self._month else ""
                base = (f"{month_slug}_" if month_slug else "") + "эффект_индексации_все_базы"
                new_name = f"{base}.xlsx"
                self._common_path = os.path.join(dir_name, new_name)
                self._common_month = self._month
            self._save_path = self._common_path
            self.edit.setText(os.path.basename(self._save_path))
            self.edit.setToolTip(self._save_path)
            self.name_lbl.setText(f"Общий файл (накапливается): {os.path.basename(self._save_path)}")
            self._filename_generated = True
            return self._save_path

        # separate — уникальное имя для каждой базы
        parts: List[str] = []
        if self._month:
            parts.append(self._slugify(self._month))
        if self._mrf_name:
            parts.append(self._slugify(fmt_mrf(self._mrf_name)))
        if self._date:
            parts.append(self._slugify(str(self._date).replace('.', '-')))
        if not parts:
            parts.append("отчёт")
        base = "_".join(parts) + "_эффект_индексации"
        new_name = f"{base}.xlsx"
        self._save_path = os.path.join(dir_name, new_name)
        self.edit.setText(new_name)
        self.edit.setToolTip(self._save_path)
        self.name_lbl.setText(f'Имя файла (сгенерировано): {new_name}')
        self._filename_generated = True
        return self._save_path

    def _browse(self):
        if not self._save_path:
            self._generate_filename()
        f, _ = QFileDialog.getSaveFileName(
            self,
            "Выберите папку и подтвердите имя файла",
            self._save_path,
            "Excel files (*.xlsx)"
        )
        if f:
            if not f.lower().endswith(".xlsx"):
                f = f + ".xlsx"
            self._save_path = f
            if self._mode == "common":
                self._common_path = f
            self.edit.setText(os.path.basename(f))
            self.edit.setToolTip(f)
            self.name_lbl.setText(f'Сохранение в: {f}')

    def reset(self, current_path: str = "", month: str = "", mrf_name: str = "", date: str = ""):
        self._current_path = current_path
        self._month = month
        self._mrf_name = mrf_name
        self._date = date
        self._filename_generated = False  # Сбрасываем флаг, чтобы сгенерировать новое имя
        self._generate_filename()
        self.status_lbl.setText("")
        self.progress.setRange(0, 100)
        self.progress.setValue(0)

    def validate(self) -> Tuple[bool, str]:
        if not self._save_path or not self.edit.text().strip():
            return False, "Не задано имя файла"
        return True, ""

    def get_save_path(self) -> str:
        edited = self.edit.text().strip()
        if edited and self._save_path:
            dir_name = os.path.dirname(self._save_path)
            if not edited.lower().endswith(".xlsx"):
                edited = edited + ".xlsx"
            return os.path.join(dir_name, edited)
        return self._save_path

    def get_mode(self) -> str:
        return self._mode

    def set_status(self, text: str):
        self.status_lbl.setText(text)


