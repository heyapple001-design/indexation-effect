    if not cols:
        return None

    result = {"selected": None, "date": None}

    root = tk.Tk()
    root.title("Фильтры Таблицы 3")
    root.geometry("1000x800")
    root.resizable(True, True)
    root.attributes('-topmost', True)
    root.update_idletasks()
    x = (root.winfo_screenwidth() // 2) - (1000 // 2)
    y = (root.winfo_screenheight() // 2) - (800 // 2)
    root.geometry(f"1000x800+{x}+{y}")
    setup_styles()

    ttk.Label(root, text="Выбор фильтров для Таблицы 3", style='Title.TLabel').pack(pady=10)
    ttk.Label(root, text="Сначала выберите ДАТУ ИНДЕКСАЦИИ, затем отметьте галочками нужные значения", 
              style='Instruction.TLabel', wraplength=900).pack(pady=5)

    main_container = ttk.Frame(root)
    main_container.pack(fill=tk.BOTH, expand=True, padx=15, pady=10)

    canvas = tk.Canvas(main_container, highlightthickness=0)
    scrollbar = ttk.Scrollbar(main_container, orient="vertical", command=canvas.yview)
    scroll_frame = ttk.Frame(canvas)

    scroll_frame.bind("<Configure>", lambda e: canvas.configure(scrollregion=canvas.bbox("all")))
    canvas.create_window((0, 0), window=scroll_frame, anchor="nw")
    canvas.configure(yscrollcommand=scrollbar.set)

    canvas.pack(side=tk.LEFT, fill=tk.BOTH, expand=True)
    scrollbar.pack(side=tk.RIGHT, fill=tk.Y)

    def _on_mousewheel(event):
        canvas.yview_scroll(int(-1 * (event.delta / 120)), "units")
    
    def _bind_mousewheel(widget):
        widget.bind("<MouseWheel>", _on_mousewheel)
        widget.bind("<Button-4>", lambda e: canvas.yview_scroll(-1, "units"))
        widget.bind("<Button-5>", lambda e: canvas.yview_scroll(1, "units"))
    
    _bind_mousewheel(canvas)
    _bind_mousewheel(scroll_frame)

    date_frame = ttk.LabelFrame(scroll_frame, text="Выбор даты индексации", padding=10)
    date_frame.pack(fill=tk.X, padx=5, pady=5)

    if 'Дата индексации' in df_report.columns:
        unique_dates = df_report['Дата индексации'].dropna().unique()
        unique_dates = sorted(unique_dates, reverse=True)
        date_var = tk.StringVar(value="(выберите дату)")
        date_combo = ttk.Combobox(date_frame, textvariable=date_var, values=["(выберите дату)"] + list(unique_dates), 
                                   state="readonly", width=30, font=('Segoe UI', 10))
        date_combo.pack(pady=5, padx=10)
        ttk.Label(date_frame, text="Выберите дату индексации, для которой будете заполнять эффект", 
                  style='Instruction.TLabel', wraplength=800).pack(pady=5)
    else:
        date_var = None
        ttk.Label(date_frame, text="В отчёте нет колонки с датой индексации", 
                  style='Instruction.TLabel', foreground='red').pack(pady=5)

    checkbox_vars = {}

    def make_values(col, df_filtered=None):
        if df_filtered is None:
            df_filtered = df_report
        s = df_filtered[col].dropna()
        if col == "РФ":
            vals = [norm_text(RF_MAPPING.get(str(v).strip(), str(v).strip())) for v in s]
        else:
            vals = [norm_text(v) for v in s]
        vals = [v for v in vals if v != ""]
        vals = sorted(list(dict.fromkeys(vals)))
        return vals

    for i, col in enumerate(cols):
        display_name = col.replace(".1", "")
        values = make_values(col)
        
        group_frame = ttk.LabelFrame(scroll_frame, text=display_name, padding=10)
        group_frame.pack(fill=tk.X, padx=5, pady=5)
        
        btn_frame = ttk.Frame(group_frame)
        btn_frame.pack(fill=tk.X, pady=5)
        
        check_frame = ttk.Frame(group_frame)
        check_frame.pack(fill=tk.BOTH, expand=True, pady=5)
        
        if len(values) > 10:
            check_canvas = tk.Canvas(check_frame, height=150, highlightthickness=0)
            check_scrollbar = ttk.Scrollbar(check_frame, orient="vertical", command=check_canvas.yview)
            check_inner = ttk.Frame(check_canvas)
            
            check_inner.bind("<Configure>", lambda e: check_canvas.configure(scrollregion=check_canvas.bbox("all")))
            check_canvas.create_window((0, 0), window=check_inner, anchor="nw")
            check_canvas.configure(yscrollcommand=check_scrollbar.set)
            
            check_canvas.pack(side=tk.LEFT, fill=tk.BOTH, expand=True)
            check_scrollbar.pack(side=tk.RIGHT, fill=tk.Y)
            
            _bind_mousewheel(check_canvas)
            
            check_container = check_inner
        else:
            check_container = check_frame
        
        checkbox_vars[col] = {}
        
        def select_all(col=col, vars_dict=checkbox_vars[col]):
            for val, var in vars_dict.items():
                var.set(True)
        
        def deselect_all(col=col, vars_dict=checkbox_vars[col]):
            for val, var in vars_dict.items():
                var.set(False)
        
        ttk.Button(btn_frame, text="✓ Выбрать всё", command=select_all, width=15).pack(side=tk.LEFT, padx=2)
        ttk.Button(btn_frame, text="✗ Снять всё", command=deselect_all, width=15).pack(side=tk.LEFT, padx=2)
        
        max_cols = 3
        rows_per_col = (len(values) + max_cols - 1) // max_cols
        
        for idx, val in enumerate(values):
            row = idx % rows_per_col
            col_num = idx // rows_per_col
            
            frame = ttk.Frame(check_container)
            frame.grid(row=row, column=col_num, sticky="w", padx=10, pady=2)
            
            var = tk.BooleanVar(value=False)
            checkbox_vars[col][val] = var
            ttk.Checkbutton(frame, text=val, variable=var, width=35).pack(side=tk.LEFT)
            
            _bind_mousewheel(frame)
        
        for c in range(max_cols):
            check_container.columnconfigure(c, weight=1)

    def on_apply():
        if date_var is None or date_var.get() == "(выберите дату)":
            messagebox.showwarning("Внимание", "Пожалуйста, выберите дату индексации!")
            return
        
        selected = {}
        for col in cols:
            selected_values = [val for val, var in checkbox_vars[col].items() if var.get()]
            if selected_values:
                selected[col] = selected_values
        
        result["selected"] = selected
        result["date"] = date_var.get()
        root.destroy()

    def on_clear():
        for col in cols:
            for val, var in checkbox_vars[col].items():
                var.set(False)
        if date_var is not None:
            date_var.set("(выберите дату)")

    btn_frame = ttk.Frame(root)
    btn_frame.pack(pady=15)
    ttk.Button(btn_frame, text="Применить фильтры", command=on_apply, style='Modern.TButton', width=18).pack(side=tk.LEFT, padx=8)
    ttk.Button(btn_frame, text="Сбросить всё", command=on_clear, style='Modern.TButton', width=15).pack(side=tk.LEFT, padx=8)
    ttk.Button(btn_frame, text="Отмена", command=root.destroy, style='Modern.TButton', width=15).pack(side=tk.LEFT, padx=8)

    root.mainloop()
    return result

