def load_amounts_with_cache(file_path, month, mrf_name, force_reload=False):
    """Загружает начисления с кэшированием в формате pickle (не требует дополнительных библиотек)"""
    script_dir = os.path.dirname(os.path.abspath(__file__))
    cache_dir = os.path.join(script_dir, "cache")
    os.makedirs(cache_dir, exist_ok=True)
    
    base_name = os.path.splitext(os.path.basename(file_path))[0]
    cache_file = os.path.join(cache_dir, f"{base_name}_{mrf_name}_{month}.pkl")
    
    if force_reload and os.path.exists(cache_file):
        os.remove(cache_file)
        print(f"   🔄 Принудительная перезагрузка (кэш удалён)")
    
    if os.path.exists(cache_file):
        cache_time = os.path.getmtime(cache_file)
        source_time = os.path.getmtime(file_path)
        if cache_time > source_time:
            print(f"   ⏳ Загрузка из кэша: {cache_file}")
            with open(cache_file, 'rb') as f:
                return pickle.load(f)
    
    print(f"   ⏳ Загрузка начислений (в первый раз, будет сохранено в кэш)...")
    print("   ⚠️ Файл большой, может занять 1-3 минуты...")
    df = pd.read_excel(file_path, sheet_name="Sheet")
    
    with open(cache_file, 'wb') as f:
        pickle.dump(df, f)
    print(f"   ✓ Сохранено в кэш: {cache_file}")
    
    return df

def filter_window(df_report):
    cols = [c for c in ["Услуга.1", "МРФ", "РФ", "Краткий Сегмент", "Подсегмент"] if c in df_report.columns]
