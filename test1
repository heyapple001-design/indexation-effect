def norm_text(x):
    if pd.isna(x):
        return ""
    return " ".join(str(x).replace("\xa0", " ").strip().lower().split())

def norm_date(x):
    if pd.isna(x):
        return ""
    dt = pd.to_datetime(x, errors="coerce", dayfirst=True)
    if pd.isna(dt):
        return norm_text(x)
    return dt.strftime("%Y-%m-%d")

