    # ─── Busy-state helpers ───

    def _set_busy(self, busy, message='Загрузка...'):
        """Блокировать/разблокировать UI во время операций."""
        self._busy = busy
        self.progress_bar.setVisible(busy)
        self.progress_bar.setFormat(message)

        # Блокируем кнопки
        for btn in [self.btn_load_base, self.btn_load_more_base,
                    self.btn_load_accruals, self.btn_clear_cache,
                    self.btn_calculate, self.btn_next_mrf,
                    self.btn_save_report, self.btn_start_mrf]:
            btn.setEnabled(not busy)

        if busy:
            QApplication.setOverrideCursor(Qt.WaitCursor)
        else:
            QApplication.restoreOverrideCursor()

    # ─── Async helpers ───

    def _start_worker(self, worker):
        """Запустить воркер в отдельном потоке."""
        self._worker_thread = QThread()
        self._worker = worker
        self._worker.moveToThread(self._worker_thread)
        self._worker_thread.started.connect(self._worker.run)
        # Сигналы подключаются в вызывающем методе
        self._worker_thread.start()

    def _cleanup_worker(self):
        """Завершить поток воркера."""
        if self._worker_thread is not None:
            self._worker_thread.quit()
            self._worker_thread.wait()
            self._worker_thread = None
            self._worker = None

    # ─── Обработчики событий ───

    def _on_mode_changed(self):
        if self.rb_mode_a.isChecked():
            self.mode = 'A'
            self._log('Режим переключён: А (отдельный файл начислений)')
        else:
            self.mode = 'B'
            self._log('Режим переключён: Б (начисления в базе индексации)')
        self._clear_cache()
        self._update_visibility()

    def _update_visibility(self):
        is_a = (self.mode == 'A')
        self.btn_load_accruals.setVisible(is_a)
        self.lbl_cache_status.setVisible(is_a)
        self.btn_clear_cache.setVisible(is_a)
        self.lbl_sep_accrual.setVisible(is_a)
        self.cmb_accrual_msisdn.setVisible(is_a)
        self.cmb_accrual_value.setVisible(is_a)
