class ExcelLoadWorker(QObject):
    """Воркер для загрузки Excel-файла в отдельном потоке."""
    finished = pyqtSignal(object, str)      # (DataFrame, sheet_name)
    error = pyqtSignal(str)
    progress = pyqtSignal(str)              # текстовый статус

    def __init__(self, filepath, sheet_name):
        super().__init__()
        self.filepath = filepath
        self.sheet_name = sheet_name

    def run(self):
        try:
            self.progress.emit(f'Чтение файла: {os.path.basename(self.filepath)}...')
            df = pd.read_excel(
                self.filepath,
                sheet_name=self.sheet_name,
                engine='openpyxl',
            )
            self.finished.emit(df, self.sheet_name)
        except Exception as e:
            self.error.emit(str(e))


class AccrualsCacheWorker(QObject):
    """Воркер для построения кеша начислений (vectorized)."""
    finished = pyqtSignal(dict, int)   # (cache_dict, count)
    error = pyqtSignal(str)
    progress = pyqtSignal(str)

    def __init__(self, df, msisdn_col, value_col):
        super().__init__()
        self.df = df
        self.msisdn_col = msisdn_col
        self.value_col = value_col

    def run(self):
        try:
            self.progress.emit('Построение кеша начислений...')
            df = self.df

            # Векторизованное построение кеша — в ~100x быстрее iterrows
            msisdn_series = df[self.msisdn_col].astype(str).str.strip()

            # Преобразуем значения в float векторно
            value_series = pd.to_numeric(
                df[self.value_col]
                    .astype(str)
                    .str.replace(',', '.', regex=False)
                    .str.replace(' ', '', regex=False)
                    .str.strip(),
                errors='coerce'
            ).fillna(0.0)

            # Фильтруем пустые MSISDN
            valid_mask = (msisdn_series != '') & (msisdn_series != 'nan') & (msisdn_series != 'None')
            msisdn_valid = msisdn_series[valid_mask]
            value_valid = value_series[valid_mask]

            # Строим dict через zip (vectorized)
            cache = dict(zip(msisdn_valid.values, value_valid.values))

            self.finished.emit(cache, len(cache))
        except Exception as e:
            self.error.emit(str(e))


class CalculationWorker(QObject):
    """Воркер для расчёта фактического эффекта (vectorized)."""
    finished = pyqtSignal(dict, dict)   # (results, stats)
    error = pyqtSignal(str)
    progress = pyqtSignal(str)

    def __init__(self, df_base, col_mapping, accruals_dict, mode,
                 filter_dates, filter_services, filter_segments, filter_subsegments):
        super().__init__()
        self.df_base = df_base
        self.col_mapping = col_mapping
        self.accruals_dict = accruals_dict
        self.mode = mode
        self.filter_dates = filter_dates
        self.filter_services = filter_services
        self.filter_segments = filter_segments
        self.filter_subsegments = filter_subsegments

    def run(self):
        try:
            self.progress.emit('Расчёт фактического эффекта...')
            df = self.df_base
            cm = self.col_mapping
            results = defaultdict(float)
            stats = {
                'total_rows': len(df),
                'processed': 0,
                'no_accrual': 0,
                'zero_effect': 0,
            }

            col_msisdn = cm['msisdn']
            col_ap_before = cm['ap_before']
            col_ap_after = cm.get('ap_after', '')
            col_date = cm.get('date', '')
            col_service = cm.get('service', '')
            col_percent = cm.get('percent', '')
            col_mrf = cm.get('mrf', '')
            col_rf = cm.get('rf', '')
            col_segment = cm.get('short_segment', '')
            col_subsegment = cm.get('subsegment', '')
            col_accrual = cm.get('accrual_report', '')

            # === Векторизованная подготовка данных ===
            # MSISDN — строка
            msisdn_arr = df[col_msisdn].astype(str).str.strip().values

            # АП до — float
            ap_before_raw = df[col_ap_before]
            ap_before_arr = pd.to_numeric(
                ap_before_raw.astype(str)
                    .str.replace(',', '.', regex=False)
                    .str.replace(' ', '', regex=False),
                errors='coerce'
            ).fillna(0.0).values

            # АП после
            if col_ap_after and col_ap_after in df.columns:
                ap_after_arr = pd.to_numeric(
                    df[col_ap_after].astype(str)
                        .str.replace(',', '.', regex=False)
                        .str.replace(' ', '', regex=False),
                    errors='coerce'
                ).fillna(0.0).values
            else:
                ap_after_arr = np.zeros(len(df))

            # Дата, услуга, процент, МРФ, РФ, сегмент, подсегмент — строки
            date_arr = df[col_date].astype(str).str.strip().values if col_date and col_date in df.columns else np.array([''] * len(df))
            service_arr = df[col_service].astype(str).str.strip().values if col_service and col_service in df.columns else np.array([''] * len(df))
            percent_arr = df[col_percent].astype(str).str.strip().values if col_percent and col_percent in df.columns else np.array([''] * len(df))
            mrf_arr = df[col_mrf].astype(str).str.strip().values if col_mrf and col_mrf in df.columns else np.array([''] * len(df))
            rf_arr = df[col_rf].astype(str).str.strip().values if col_rf and col_rf in df.columns else np.array([''] * len(df))
            seg_arr = df[col_segment].astype(str).str.strip().values if col_segment and col_segment in df.columns else np.array([''] * len(df))
            subseg_arr = df[col_subsegment].astype(str).str.strip().values if col_subsegment and col_subsegment in df.columns else np.array([''] * len(df))

            # Начисления за отчётный месяц
            if self.mode == 'A':
                # Lookup из кеша — для каждого MSISDN
                accruals = self.accruals_dict
                accrual_arr = np.zeros(len(df))
                no_accrual_count = 0
                for i in range(len(df)):
                    msn = msisdn_arr[i]
                    if msn == '' or msn == 'nan':
                        accrual_arr[i] = 0.0
                        continue
                    val = accruals.get(msn)
                    if val is None:
                        # Пробуем альтернативные форматы
                        if msn.startswith('8') and len(msn) == 11:
                            val = accruals.get('7' + msn[1:])
                        if val is None and msn.startswith('7') and len(msn) == 11:
                            val = accruals.get('8' + msn[1:])
                        if val is None and len(msn) >= 10:
                            val = accruals.get(msn[-10:])
                    if val is not None:
                        accrual_arr[i] = val
                    else:
                        accrual_arr[i] = 0.0
                        no_accrual_count += 1
                stats['no_accrual'] = no_accrual_count
            else:
                # Режим Б
                if col_accrual and col_accrual in df.columns:
                    accrual_arr = pd.to_numeric(
                        df[col_accrual].astype(str)
                            .str.replace(',', '.', regex=False)
                            .str.replace(' ', '', regex=False),
                        errors='coerce'
                    ).fillna(0.0).values
                else:
                    accrual_arr = np.zeros(len(df))

            # === Применение фильтров (векторно) ===
            valid_mask = np.ones(len(df), dtype=bool)
            valid_mask &= (msisdn_arr != '') & (msisdn_arr != 'nan')

            if self.filter_dates and col_date:
                mask = np.zeros(len(df), dtype=bool)
                for d in self.filter_dates:
                    mask |= (date_arr == d)
                valid_mask &= mask

            if self.filter_services and col_service:
                mask = np.zeros(len(df), dtype=bool)
                for s in self.filter_services:
                    mask |= (service_arr == s)
                valid_mask &= mask

            if self.filter_segments and col_segment:
                mask = np.zeros(len(df), dtype=bool)
                for s in self.filter_segments:
                    mask |= (seg_arr == s)
                valid_mask &= mask

            if self.filter_subsegments and col_subsegment:
                mask = np.zeros(len(df), dtype=bool)
                for s in self.filter_subsegments:
                    mask |= (subseg_arr == s)
                valid_mask &= mask

            # === Векторный расчёт эффекта ===
            # Основной случай: ap_before > 0 → max(0, accrual - ap_before)
            # Специальный: ap_before == 0 → по правилам
            effect_arr = np.zeros(len(df))

            # Основной случай
            main_mask = ap_before_arr > 0
            delta_main = accrual_arr - ap_before_arr
            effect_arr[main_mask] = np.maximum(0.0, delta_main[main_mask])

            # Специальный случай: ap_before == 0
            special_mask = ~main_mask & valid_mask
            # Если начисления == АП после → прогнозный эффект
            close_to_after = np.abs(accrual_arr - ap_after_arr) < 0.01
            forecast_effect = ap_after_arr - ap_before_arr  # = ap_after - 0 = ap_after
            effect_arr[special_mask & close_to_after] = np.maximum(
                0.0, forecast_effect[special_mask & close_to_after]
            )
            # Если начисления > АП до
            greater_than_before = (accrual_arr > ap_before_arr) & ~close_to_after
            effect_arr[special_mask & greater_than_before] = np.maximum(
                0.0, (accrual_arr - ap_before_arr)[special_mask & greater_than_before]
            )

            # Применяем valid_mask
            effect_arr[~valid_mask] = 0.0

            # === Приводим МРФ к формату отчёта (векторно через numpy) ===
            mrf_report_arr = np.array([normalize_mrf_to_report(m) for m in mrf_arr])
            # Где не удалось — пробуем по РФ
            empty_mrf = (mrf_report_arr == '') | (mrf_report_arr == 'None') | (mrf_report_arr == None)
            for i in np.where(empty_mrf)[0]:
                if rf_arr[i] and rf_arr[i] != 'nan':
                    r = rf_to_report_mrf(rf_arr[i])
                    if r:
                        mrf_report_arr[i] = r

            # === Агрегация (по уникальным комбинациям) ===
            zero_count = 0
            processed_count = 0
            for i in np.where(valid_mask)[0]:
                key = (
                    service_arr[i], date_arr[i], percent_arr[i],
                    mrf_report_arr[i], rf_arr[i], seg_arr[i], subseg_arr[i]
                )
                eff = float(effect_arr[i])
                results[key] += eff
                processed_count += 1
                if eff == 0:
                    zero_count += 1

            stats['processed'] = processed_count
            stats['zero_effect'] = zero_count

            self.finished.emit(dict(results), stats)
        except Exception as e:
            self.error.emit(str(e))


