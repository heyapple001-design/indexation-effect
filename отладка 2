    flat_button(body, "Продолжить →", ok, width=18).pack(anchor="w")
    _get_file_root().wait_window(win); return result[0]

def ask_charges_mode(base_name: str, mrf_name: str) -> Optional[str]:
    """
    Диалог: начисления в отдельном файле или в этой базе?
    Возвращает MODE_EXTERNAL или MODE_INBASE.
    """
    win = make_window("Источник начислений", 560, 280)
    result = [None]
    header_bar(win, "Источник начислений")

    body = tk.Frame(win, bg=C_BG); body.pack(fill=tk.BOTH, expand=True, padx=24, pady=16)
    tk.Label(body,
             text=f"МРФ {mrf_name}  |  База: {base_name}",
             bg=C_BG, fg=C_TEXT_HINT, font=FONT_SMALL).pack(anchor="w", pady=(0,4))
    tk.Label(body,
             text="Где хранятся текущие начисления для этой базы?",
             bg=C_BG, fg=C_TEXT, font=FONT_LABEL).pack(anchor="w", pady=(0,16))

    def choose(mode): result[0] = mode; win.destroy()

    # Кнопка A
    card_a = tk.Frame(body, bg=C_BG_PANEL, relief="solid", bd=1)
    card_a.pack(fill=tk.X, pady=4)
    inner_a = tk.Frame(card_a, bg=C_BG_PANEL); inner_a.pack(fill=tk.X, padx=12, pady=10)
    tk.Label(inner_a, text="📂  В отдельном файле начислений",
             bg=C_BG_PANEL, fg=C_TEXT, font=("Segoe UI", 10, "bold")).pack(anchor="w")
    tk.Label(inner_a,
             text="Стандартный файл с листом «Sheet», колонками MSISDN и «Без НДС месяц»",
             bg=C_BG_PANEL, fg=C_TEXT_HINT, font=FONT_SMALL).pack(anchor="w")
    card_a.bind("<Button-1>", lambda e: choose(MODE_EXTERNAL))
    inner_a.bind("<Button-1>", lambda e: choose(MODE_EXTERNAL))
    for w in inner_a.winfo_children():
        w.bind("<Button-1>", lambda e: choose(MODE_EXTERNAL))
    card_a.configure(cursor="hand2"); inner_a.configure(cursor="hand2")

    # Кнопка B
    card_b = tk.Frame(body, bg="#EFF6FF", relief="solid", bd=1)
    card_b.pack(fill=tk.X, pady=4)
    inner_b = tk.Frame(card_b, bg="#EFF6FF"); inner_b.pack(fill=tk.X, padx=12, pady=10)
    tk.Label(inner_b, text="📊  В этой базе индексации",
             bg="#EFF6FF", fg=C_ACCENT, font=("Segoe UI", 10, "bold")).pack(anchor="w")
    tk.Label(inner_b,
             text="Колонка с текущим начислением находится прямо в файле базы\n"
                  "(например: Кабельная канализация, Радиовещание, Транспортная сеть)",
             bg="#EFF6FF", fg=C_TEXT_HINT, font=FONT_SMALL).pack(anchor="w")
    card_b.bind("<Button-1>", lambda e: choose(MODE_INBASE))
    inner_b.bind("<Button-1>", lambda e: choose(MODE_INBASE))
    for w in inner_b.winfo_children():
        w.bind("<Button-1>", lambda e: choose(MODE_INBASE))
    card_b.configure(cursor="hand2"); inner_b.configure(cursor="hand2")

    _get_file_root().wait_window(win); return result[0]

def select_mrf_window() -> Optional[list[str]]:
    win = make_window("Выбор МРФ", 680, 640, resizable=True); result = [None]
    header_bar(win, "Выберите МРФ для обработки")
    hint = tk.Frame(win, bg=C_BG_PANEL); hint.pack(fill=tk.X)
    tk.Label(hint, text="  Отметьте МРФ, которые нужно обработать. Обработка идёт последовательно.",
             bg=C_BG_PANEL, fg=C_TEXT_HINT, font=FONT_SMALL).pack(anchor="w", pady=6, padx=12)
    separator(win)
    scroll_area = tk.Frame(win, bg=C_BG); scroll_area.pack(fill=tk.BOTH, expand=True)
    cv, sf = scroll_canvas(scroll_area)
    vars_ = {}
    for mrf in sorted(ALL_MRF):
        rf_list = MRF_TO_RF.get(mrf, [])
        card = tk.Frame(sf, bg=C_BG); card.pack(fill=tk.X, padx=12, pady=4)
        top_row = tk.Frame(card, bg=C_BG); top_row.pack(fill=tk.X)
        var = tk.BooleanVar(value=False); vars_[mrf] = var
        tk.Checkbutton(top_row, text=f"  МРФ {fmt_mrf(mrf)}", variable=var,
                       bg=C_BG, fg=C_TEXT, activebackground=C_BG, activeforeground=C_ACCENT,
                       selectcolor=C_BG, font=("Segoe UI", 11, "bold"),
                       relief="flat", bd=0, cursor="hand2", anchor="w").pack(side=tk.LEFT)
        if rf_list:
            tk.Label(card, text="        " + " · ".join(rf_list),
                     bg=C_BG, fg=C_TEXT_HINT, font=FONT_SMALL,
                     wraplength=600, justify="left", anchor="w").pack(fill=tk.X, padx=4, pady=(0,2))
        tk.Frame(card, bg=C_BORDER, height=1).pack(fill=tk.X, pady=(4,0))
    separator(win)
    btn_row = tk.Frame(win, bg=C_BG); btn_row.pack(pady=12, padx=16, fill=tk.X)
    def sel_all():
        for v in vars_.values(): v.set(True)
    def desel_all():
        for v in vars_.values(): v.set(False)
    def ok():
        chosen = [m for m, v in vars_.items() if v.get()]
        if not chosen: messagebox.showwarning("Внимание", "Выберите хотя бы один МРФ!", parent=win); return
        result[0] = chosen; win.destroy()
    flat_button(btn_row, "Начать обработку →", ok, width=20).pack(side=tk.LEFT)
    flat_button(btn_row, "✓ Все", sel_all, style="Secondary.TButton", width=10).pack(side=tk.LEFT, padx=(10,4))
    flat_button(btn_row, "✗ Снять", desel_all, style="Secondary.TButton", width=10).pack(side=tk.LEFT)
    _get_file_root().wait_window(win); return result[0]

def select_column(df_columns: pd.Index, title_text: str, instruction_text: str) -> Optional[str]:
    win = make_window(title_text, 680, 540, resizable=True); result = [None]
    header_bar(win, title_text)
    body = tk.Frame(win, bg=C_BG); body.pack(fill=tk.BOTH, expand=True, padx=16, pady=10)
    tk.Label(body, text=instruction_text, bg=C_BG, fg=C_TEXT_HINT,
             font=FONT_SMALL, wraplength=640, justify="left").pack(anchor="w", pady=(0,8))
    search_row = tk.Frame(body, bg=C_BG); search_row.pack(fill=tk.X, pady=(0,6))
    tk.Label(search_row, text="🔍  Поиск:", bg=C_BG, fg=C_TEXT, font=FONT_LABEL).pack(side=tk.LEFT)
    sv = tk.StringVar()
    se = ttk.Entry(search_row, textvariable=sv, font=FONT_LABEL, width=42)
    se.pack(side=tk.LEFT, padx=(8,0), fill=tk.X, expand=True); se.focus_set()
    lo = tk.Frame(body, bg=C_BORDER, padx=1, pady=1); lo.pack(fill=tk.BOTH, expand=True)
    lf = tk.Frame(lo, bg=C_BG); lf.pack(fill=tk.BOTH, expand=True)
    sb = ttk.Scrollbar(lf); sb.pack(side=tk.RIGHT, fill=tk.Y)
    lb = styled_listbox(lf); lb.pack(side=tk.LEFT, fill=tk.BOTH, expand=True)
    sb.config(command=lb.yview); lb.config(yscrollcommand=sb.set)
    all_cols = list(df_columns)
    for c in all_cols: lb.insert(tk.END, c)
    def update(*_):
        q = sv.get().lower(); lb.delete(0, tk.END)
        for c in all_cols:
            if q in c.lower(): lb.insert(tk.END, c)
    sv.trace("w", update)
    def pick(*_):
        sel = lb.curselection()
        if sel: result[0] = lb.get(sel[0]); win.destroy()
    lb.bind("<Double-Button-1>", pick); lb.bind("<Return>", pick)
    separator(body)
    br = tk.Frame(body, bg=C_BG); br.pack(fill=tk.X, pady=(4,0))
    flat_button(br, "Выбрать", pick, width=14).pack(side=tk.LEFT)
    flat_button(br, "Отмена", win.destroy, style="Secondary.TButton", width=10).pack(side=tk.LEFT, padx=10)
    _get_file_root().wait_window(win); return result[0]

