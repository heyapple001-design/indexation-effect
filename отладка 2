# Единственный скрытый Tk-root для файловых диалогов.
# Создаётся один раз и переиспользуется — предотвращает утечку ресурсов
# при 100+ вызовах select_file/select_save_file за сессию.
_FILE_ROOT: "tk.Tk | None" = None

def _get_file_root() -> "tk.Tk":
    """Возвращает (создавая при необходимости) единый скрытый root для диалогов."""
    global _FILE_ROOT
    if _FILE_ROOT is None:
        _FILE_ROOT = tk.Tk()
        _FILE_ROOT.withdraw()
        _FILE_ROOT.attributes("-topmost", True)
    else:
        # Убеждаемся что окно живо (могло быть уничтожено WaitingWindow)
        try:
            _FILE_ROOT.state()
        except tk.TclError:
            _FILE_ROOT = tk.Tk()
            _FILE_ROOT.withdraw()
            _FILE_ROOT.attributes("-topmost", True)
    return _FILE_ROOT


def select_file(title: str) -> str:
    root = _get_file_root()
    root.lift()
    f = filedialog.askopenfilename(
        title=title, filetypes=[("Excel files", "*.xlsx"), ("All files", "*.*")],
        initialdir=os.path.expanduser("~/Desktop"),
        parent=root)
    return f

def select_save_file(title: str, initialfile: str) -> str:
    root = _get_file_root()
    root.lift()
    f = filedialog.asksaveasfilename(
        title=title, initialfile=initialfile, defaultextension=".xlsx",
        filetypes=[("Excel files", "*.xlsx")],
        initialdir=os.path.expanduser("~/Desktop"),
        parent=root)
    return f

def select_month() -> Optional[str]:
    months = ["январь","февраль","март","апрель","май","июнь",
              "июль","август","сентябрь","октябрь","ноябрь","декабрь"]
    win = make_window("Выбор месяца", 380, 230); result = [None]
    header_bar(win, "Расчёт эффекта индексации")
    body = tk.Frame(win, bg=C_BG); body.pack(fill=tk.BOTH, expand=True, padx=24, pady=16)
    tk.Label(body, text="Выберите отчётный месяц:", bg=C_BG, fg=C_TEXT, font=FONT_LABEL).pack(anchor="w", pady=(0,8))
    var = tk.StringVar(value="апрель")
    ttk.Combobox(body, textvariable=var, values=months, state="readonly",
                 font=FONT_LABEL, width=18).pack(anchor="w", pady=(0,16))
