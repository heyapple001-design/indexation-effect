def unmap_rf(canon_value: Any) -> str:
    """Конвертирует канонический 'ФЭС ...' (или любое написание) в полное
    официальное название филиала. Напр: 'фэс тюменский' →
    'Филиал в Тюменской и Курганской областях'."""
    key = " ".join(str(canon_value).replace("\xa0", " ").strip().lower().split())
    return RF_REVERSE.get(key, canon_value)   # если не нашли — возвращаем как есть

def fmt_title(x: Any) -> Any:
    """Первое слово с заглавной, остальное строчное. Напр: 'ВПН' → 'Впн'."""
    if pd.isna(x) or str(x).strip() == "":
        return x
    s = str(x).strip()
    return s[0].upper() + s[1:].lower()

def fmt_lower(x: Any) -> Any:
    """Всё строчными."""
    if pd.isna(x) or str(x).strip() == "":
        return x
    return str(x).strip().lower()

def fmt_upper(x: Any) -> Any:
    """Всё заглавными (UPPERCASE)."""
    if pd.isna(x) or str(x).strip() == "":
        return x
    return str(x).strip().upper()

def fmt_mrf(x: Any) -> Any:
    """Нормализует название МРФ по эталонному словарю MRF_EXACT."""
    if pd.isna(x) or str(x).strip() == "":
        return x
    key = str(x).strip().lower()
    if key in MRF_EXACT:
        return MRF_EXACT[key]
    return fmt_title(x)   # для неизвестных МРФ — первое с заглавной


def fmt_service(x: Any) -> Any:
    """Форматирует название услуги:
    - Точные совпадения из SERVICE_EXACT → эталонное написание
    - Услуги из UPPERCASE_SERVICES → UPPERCASE (IPTV, VPN, ШПД и др.)
    - Остальные → первое слово с заглавной (fmt_title)
    """
    if pd.isna(x) or str(x).strip() == "":
        return x
    s = str(x).strip()
    # Проверяем точные совпадения (нечувствительно к регистру)
    key = s.lower()
    if key in SERVICE_EXACT:
        return SERVICE_EXACT[key]
    if key in UPPERCASE_SERVICES:
        return s.upper()
    return fmt_title(s)

def fmt_seg(x: Any) -> Any:
    """Форматирует сегмент/подсегмент по правилу:
    - Слова с латиницей/цифрами → UPPERCASE  (B2B, 3К, B2G)
    - Кириллические аббревиатуры → UPPERCASE  (МСП, ККФУ, ДНК, РУ, ФУ)
    - Обычные кириллические слова → первая заглавная  (Прочие, Топ, Средний)
    Примеры: 'прочие 3к' → 'Прочие 3К', 'b2b ккфу' → 'B2B ККФУ'
    """
    import re
    if pd.isna(x) or str(x).strip() == "":
        return x
    s = str(x).strip()
    ABBREVS = {'мсп', 'смп', 'мрф', 'фэс', 'днк', 'ккфу', 'фу', 'ру', 'вп', 'оп', 'нк', 'топ'}
    result = []
    for word in s.split():
        if re.search(r'[a-zA-Z0-9]', word):
            result.append(word.upper())
        elif word.lower() in ABBREVS:
            result.append(word.upper())
        else:
            result.append(word.capitalize())
    return ' '.join(result)

def fmt_pct(x: Any) -> Any:
    """Приводим % к числу 0..1 если значение > 1 (например 5 → 0.05)."""
    try:
        v = float(str(x).replace(",", ".").replace("%", "").strip())
        return v / 100 if v > 1 else v
    except (ValueError, TypeError):
        return x

def fmt_num3(x: Any) -> Any:
    """Число с 3 знаками после запятой."""
    try:
        return round(float(x), 3)
    except (ValueError, TypeError):
        return x

