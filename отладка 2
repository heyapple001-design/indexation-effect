                    if key in report_dict:
                        for ridx in report_dict[key]:
                            df_report.loc[ridx, target_col] = eff
                            matched_indices.append(ridx); updated_count += 1
                        found_any = True

                if not found_any:
                    key_no_svc = (mrf_, rf_, seg_, sub_)
                    existing_no_svc = {(k[1], k[2], k[3], k[4]) for k in report_dict}
                    if key_no_svc in existing_no_svc:
                        for key_full, ridxs in report_dict.items():
                            if (key_full[1], key_full[2], key_full[3], key_full[4]) == key_no_svc:
                                for ridx in ridxs:
                                    df_report.loc[ridx, target_col] = eff
                                    matched_indices.append(ridx); updated_count += 1
                                found_any = True
                                break

                if not found_any:
                    svc_val = list(svcs_check)[0] if svcs_check else ""
                    new_row = _build_new_row(df_report, pr, svc_val, selected_date, target_col, eff, pct_lookup)
