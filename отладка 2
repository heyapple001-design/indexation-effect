def process_one_base(df_base: pd.DataFrame,
                     df_amount: Optional[pd.DataFrame],
                     df_report,
                     base_col,
                     id_col,
                     amount_col,
                     current_col,
                     charges_mode,
                     available_group_cols,
                     target_col,
                     base_name, mrf_name, iteration_num):

    print(f"\n  {'='*55}")
    print(f"  БАЗА #{iteration_num} [{mrf_name}]: {base_name}")
    mode_label = "📂 отдельный файл начислений" if charges_mode == MODE_EXTERNAL else "📊 начисления в базе"
    print(f"  Режим: {mode_label}")
    print(f"  {'='*55}")

    _wait_calc = WaitingWindow("⏳ Идёт расчёт...",
                               "Вычисляется эффект индексации.\nПожалуйста, подождите.")
    t_calc = datetime.now()
    try:
        if charges_mode == MODE_EXTERNAL:
            pivot = calc_pivot_external(df_base, df_amount, base_col,
                                        id_col, amount_col, available_group_cols)
            # Сохраняем исходные данные для отладки
            debug_merged = None
            if charges_mode == MODE_EXTERNAL:
                # Повторяем merge для отладки
                df_base_debug = df_base.copy()
                df_amount_debug = df_amount.copy()
                df_base_debug[base_col] = pd.to_numeric(df_base_debug[base_col], errors='coerce')
                df_amount_debug[amount_col] = pd.to_numeric(df_amount_debug[amount_col], errors='coerce')
                df_base_debug[id_col] = df_base_debug[id_col].astype(str).str.strip().str.replace('.0', '', regex=False)
                df_amount_debug["MSISDN"] = df_amount_debug["MSISDN"].astype(str).str.strip().str.replace('.0', '', regex=False)
                debug_merged = df_base_debug.merge(
                    df_amount_debug[["MSISDN", amount_col]],
                    left_on=id_col, right_on="MSISDN", how='left'
                )
                debug_merged['Эффект_руб'] = debug_merged[amount_col] - debug_merged[base_col]
                debug_merged.loc[debug_merged['Эффект_руб'] < 0, 'Эффект_руб'] = 0
        else:
            pivot = calc_pivot_inbase(df_base, base_col, current_col, available_group_cols)
            debug_merged = None
    finally:
        _wait_calc.close()
    calc_sec = (datetime.now() - t_calc).total_seconds()
    print(f"   Групп: {len(pivot)}, эффект: {pivot['Эффект_тыс'].sum():,.3f} тыс. руб. "
          f"(расчёт: {calc_sec:.1f} сек)")

    if len(pivot) == 0:
        print("   ❌ Пустой pivot — нет данных.")
        return None

    sel = filter_window(df_report, mrf_name=mrf_name)
    if not sel or not sel.get("date") or sel.get("selected") is None:
        print("  Фильтры не выбраны — база пропущена.")
        return None

    selected_date     = sel["date"]
    selected_segments = sel.get("selected") or {}

    svc_col_report = RPT_COL_SERVICE if RPT_COL_SERVICE in df_report.columns else None
    if svc_col_report is None:
        print(f"   ⚠️  В отчёте нет колонки '{RPT_COL_SERVICE}' — фильтр по услуге не применяется")
    selected_services = set()
    for fc, fv in selected_segments.items():
        if fc == "Услуга":
            selected_services = set(fv); break

    # ══════════════════════════════════════════════════════════════
    #  🐞 СУПЕР-ДЕТАЛЬНАЯ ОТЛАДКА для ЧЕЛЯБИНСКОГО ФИЛИАЛА / ТОП
    # ══════════════════════════════════════════════════════════════
    # Ищем Челябинский филиал в данных (смотрим, как он реально называется в PIVOT)
    chelyabinsk_rf_norm = None
    all_rf_in_pivot = sorted(set(
        map_rf(r[BASE_COL_RF]) if BASE_COL_RF in r.index else "" 
        for _, r in pivot.iterrows()
    ))
    
    # Ищем РФ, содержащий "челябинск" (регистронезависимо)
    for rf in all_rf_in_pivot:
        if "челябинск" in rf.lower():
            chelyabinsk_rf_norm = rf
            break
    
    # Если не нашли по подстроке, пробуем точное совпадение
    if chelyabinsk_rf_norm is None:
        chelyabinsk_rf_norm = norm_text(unmap_rf("Челябинский"))
    
    print("\n" + "="*80)
    print(f"🔍 ПОИСК ЧЕЛЯБИНСКОГО ФИЛИАЛА / ТОП")
    print(f"   Найдено в данных: '{chelyabinsk_rf_norm}'")
    print("="*80)

    # ---- ШАГ 1: Все уникальные РФ в PIVOT ----
    print("\n--- ШАГ 1: ВСЕ УНИКАЛЬНЫЕ РФ В PIVOT ---")
    print(f"   Всего РФ: {len(all_rf_in_pivot)}")
    for rf in all_rf_in_pivot[:20]:
        marker = " ✅" if rf == chelyabinsk_rf_norm else ""
        print(f"   - {rf}{marker}")
    if len(all_rf_in_pivot) > 20:
        print(f"   ... и ещё {len(all_rf_in_pivot) - 20}")

    # ---- ШАГ 2: Все строки Челябинского филиала в PIVOT ----
    print("\n--- ШАГ 2: ВСЕ СТРОКИ ЧЕЛЯБИНСКОГО ФИЛИАЛА В PIVOT ---")
    if chelyabinsk_rf_norm:
        pivot_chelyabinsk = pivot[
            pivot[BASE_COL_RF].apply(lambda x: map_rf(x) == chelyabinsk_rf_norm)
        ]
        print(f"   Всего строк: {len(pivot_chelyabinsk)}")
        print(f"   Сумма эффекта: {pivot_chelyabinsk['Эффект_тыс'].sum():.3f} тыс. руб.")
        if len(pivot_chelyabinsk) > 0:
            print("\n   ДЕТАЛЬНЫЙ СПИСОК:")
            for idx, row in pivot_chelyabinsk.iterrows():
                svc = row[BASE_COL_SERVICE] if BASE_COL_SERVICE in row.index else ""
                seg = row[BASE_COL_SEGMENT] if BASE_COL_SEGMENT in row.index else ""
                sub = row[BASE_COL_SUBSEG] if BASE_COL_SUBSEG in row.index else ""
                eff = row['Эффект_тыс']
                print(f"   [{idx}] Услуга='{svc}', Сег='{seg}', Под='{sub}', Эффект={eff:.3f}")
    else:
        print("   ⚠️  Челябинский филиал НЕ НАЙДЕН в данных!")
        pivot_chelyabinsk = pd.DataFrame()  # пустой DataFrame

    # ---- ШАГ 3: Все строки Челябинского филиала с сегментом ТОП ----
    print("\n--- ШАГ 3: ЧЕЛЯБИНСКИЙ ФИЛИАЛ + СЕГМЕНТ ТОП ---")
    if len(pivot_chelyabinsk) > 0:
        # Ищем сегмент "топ" (регистронезависимо)
        pivot_target = pivot_chelyabinsk[
            pivot_chelyabinsk[BASE_COL_SEGMENT].apply(
                lambda x: "топ" in str(x).lower() if pd.notna(x) else False
            )
        ]
        print(f"   Найдено строк: {len(pivot_target)}")
        print(f"   Сумма эффекта: {pivot_target['Эффект_тыс'].sum():.3f} тыс. руб.")
        if len(pivot_target) > 0:
            print("\n   ДЕТАЛЬНЫЙ СПИСОК (каждая группа):")
            total = 0
            for idx, row in pivot_target.iterrows():
                svc = row[BASE_COL_SERVICE] if BASE_COL_SERVICE in row.index else ""
                seg = row[BASE_COL_SEGMENT] if BASE_COL_SEGMENT in row.index else ""
                sub = row[BASE_COL_SUBSEG] if BASE_COL_SUBSEG in row.index else ""
                eff = row['Эффект_тыс']
                total += eff
                print(f"   [{idx}] Услуга='{svc}', Сег='{seg}', Под='{sub}', Эффект={eff:.3f} (накоплено: {total:.3f})")
    else:
        pivot_target = pd.DataFrame()
        print("   ⚠️  Нет данных по Челябинскому филиалу")

    # ---- ШАГ 3.1: ДЕТАЛЬНЫЙ РАЗБОР КАЖДОЙ ГРУППЫ С MSISDN (ВСЕ) ----
    if len(pivot_target) > 0 and debug_merged is not None:
        print("\n--- ШАГ 3.1: ДЕТАЛЬНЫЙ РАЗБОР КАЖДОЙ ГРУППЫ (ВСЕ MSISDN) ---")
        for idx, row in pivot_target.iterrows():
            svc = row[BASE_COL_SERVICE] if BASE_COL_SERVICE in row.index else ""
            mrf = row[BASE_COL_MRF] if BASE_COL_MRF in row.index else ""
            rf = row[BASE_COL_RF] if BASE_COL_RF in row.index else ""
            seg = row[BASE_COL_SEGMENT] if BASE_COL_SEGMENT in row.index else ""
            sub = row[BASE_COL_SUBSEG] if BASE_COL_SUBSEG in row.index else ""
            eff = row['Эффект_тыс']
            
            print(f"\n   📌 ГРУППА [{idx}]: Услуга='{svc}', МРФ='{mrf}', РФ='{rf}', Сег='{seg}', Под='{sub}'")
            print(f"      Итоговый эффект: {eff:.3f} тыс. руб.")
            
            # Находим все MSISDN в этой группе из debug_merged
            mask = (
                (debug_merged[BASE_COL_SERVICE].apply(lambda x: str(x).lower() if pd.notna(x) else "") == str(svc).lower()) &
                (debug_merged[BASE_COL_MRF].apply(lambda x: str(x).lower() if pd.notna(x) else "") == str(mrf).lower()) &
                (debug_merged[BASE_COL_RF].apply(lambda x: str(x).lower() if pd.notna(x) else "") == str(rf).lower()) &
                (debug_merged[BASE_COL_SEGMENT].apply(lambda x: str(x).lower() if pd.notna(x) else "") == str(seg).lower()) &
                (debug_merged[BASE_COL_SUBSEG].apply(lambda x: str(x).lower() if pd.notna(x) else "") == str(sub).lower())
            )
            group_data = debug_merged[mask]
            
            print(f"      Количество MSISDN в группе: {len(group_data)}")
            if len(group_data) > 0:
                print(f"      Сумма 'До индексации': {group_data[base_col].sum():.2f} руб.")
                print(f"      Сумма 'Текущее': {group_data[amount_col].sum():.2f} руб.")
                print(f"      Сумма эффекта (руб): {group_data['Эффект_руб'].sum():.2f} руб.")
                print(f"      Сумма эффекта (тыс): {group_data['Эффект_руб'].sum()/1000:.3f} тыс. руб.")
                
                # Показываем ВСЕ MSISDN с деталями
                print(f"\n      ВСЕ MSISDN (всего {len(group_data)}):")
                print(f"      {'№':<4} {'MSISDN':<15} {'До индексации':<15} {'Текущее':<15} {'Эффект':<15}")
                print(f"      {'-'*4} {'-'*15} {'-'*15} {'-'*15} {'-'*15}")
                for i, (_, g_row) in enumerate(group_data.iterrows(), 1):
