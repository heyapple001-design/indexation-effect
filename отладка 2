def scroll_canvas(parent, bg=None):
    bg = bg or C_BG
    cv = tk.Canvas(parent, bg=bg, highlightthickness=0)
    sb = ttk.Scrollbar(parent, orient="vertical", command=cv.yview)
    sf = tk.Frame(cv, bg=bg)
    sf.bind("<Configure>", lambda e: cv.configure(scrollregion=cv.bbox("all")))
    cv.create_window((0, 0), window=sf, anchor="nw")
    cv.configure(yscrollcommand=sb.set)
    cv.pack(side=tk.LEFT, fill=tk.BOTH, expand=True)
    sb.pack(side=tk.RIGHT, fill=tk.Y)
    def _mw(e): cv.yview_scroll(int(-1*(e.delta/120)), "units")
    for w in (cv, sf):
        w.bind("<MouseWheel>", _mw)
        w.bind("<Button-4>", lambda e: cv.yview_scroll(-1, "units"))
        w.bind("<Button-5>", lambda e: cv.yview_scroll( 1, "units"))
    return cv, sf

