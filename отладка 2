class WaitingWindow:
    """
    Информационное окно «⏳ Пожалуйста, подождите...»

    Реализовано через tk.Toplevel от единственного _FILE_ROOT —
    НЕ создаёт новый Tk(), что устраняет конфликты и зависания.
    """
    def __init__(self, title: str = "⏳ Пожалуйста, подождите",
                 message: str = "Идёт обработка данных...") -> None:
        self._win: Optional[tk.Toplevel] = None
        try:
            parent = _get_file_root()
            win = tk.Toplevel(parent)
            self._win = win
            win.title(title)
            win.resizable(False, False)
            win.attributes("-topmost", True)
            win.configure(bg=C_BG)
            win.protocol("WM_DELETE_WINDOW", lambda: None)

            w_px, h_px = 440, 170
            win.update_idletasks()
            sw = win.winfo_screenwidth()
            sh = win.winfo_screenheight()
            win.geometry(f"{w_px}x{h_px}+{(sw-w_px)//2}+{(sh-h_px)//2}")

            # Шапка
            bar = tk.Frame(win, bg=C_HDR_BG, height=48)
            bar.pack(fill=tk.X); bar.pack_propagate(False)
            tk.Label(bar, text=title, bg=C_HDR_BG, fg=C_HDR_FG,
                     font=FONT_TITLE, anchor="w").pack(side=tk.LEFT, padx=16, pady=8)

            # Тело
            body = tk.Frame(win, bg=C_BG)
            body.pack(fill=tk.BOTH, expand=True, padx=24, pady=12)
            tk.Label(body, text=message, bg=C_BG, fg=C_TEXT,
                     font=FONT_LABEL, wraplength=380, justify="center").pack(expand=True)

            # Анимированные точки
            self._dot_count = 0
            self._anim_lbl = tk.Label(body, text="●○○", bg=C_BG,
                                       fg=C_ACCENT, font=("Segoe UI", 14))
            self._anim_lbl.pack(pady=(4, 0))

            def _animate() -> None:
                if self._win is None: return
                self._dot_count = (self._dot_count + 1) % 4
                dots = "●" * self._dot_count + "○" * (3 - self._dot_count)
                try:
                    self._anim_lbl.config(text=dots)
                    self._win.after(350, _animate)
                except tk.TclError:
                    pass

            win.after(0, _animate)
            win.update()

        except tk.TclError as e:
            print(f"  {title}: {message}")
            self._win = None

    def update(self) -> None:
        """Обновляет отрисовку."""
        if self._win:
            try:
                self._win.update()
            except tk.TclError:
                pass

    def close(self) -> None:
        """Закрывает окно ожидания."""
        if self._win:
            try:
                self._win.destroy()
            except tk.TclError:
                pass
            self._win = None


def make_window(title: str, w: int, h: int, resizable: bool = False) -> tk.Toplevel:
    """Создаёт диалоговое окно как Toplevel от _FILE_ROOT.
    Это предотвращает конфликт нескольких Tk()-экземпляров.
    Вместо mainloop() используйте _get_file_root().wait_window(win) — оно работает
    через wait_window на родительском root.
    """
    parent = _get_file_root()
    root = tk.Toplevel(parent)
    root.title(title)
    root.configure(bg=C_BG)
    root.resizable(resizable, resizable)
    apply_theme(root)
    center(root, w, h)
    topmost(root)
    root.protocol("WM_DELETE_WINDOW", root.destroy)
    return root

