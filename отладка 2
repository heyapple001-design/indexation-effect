class SessionLog:
    """
    Небольшое окно-журнал сессии — показывает какие файлы уже загружены.
    Обновляется по мере работы программы. Всегда поверх других окон.
    """
    def __init__(self) -> None:
        self._win: Optional[tk.Toplevel] = None
        self._text: Optional[tk.Text] = None
        self._lines: list[str] = []

    def show(self, title: str = "📋 Файлы сессии") -> None:
        """Создаёт окно журнала (вызвать один раз при старте)."""
        parent = _get_file_root()
        win = tk.Toplevel(parent)
        self._win = win
        win.title(title)
        win.resizable(True, False)
        win.attributes("-topmost", True)
        win.configure(bg=C_BG)
        win.protocol("WM_DELETE_WINDOW", lambda: None)  # нельзя закрыть вручную

        # Позиционируем в правом верхнем углу
        w_px, h_px = 500, 280
        win.update_idletasks()
        sw = win.winfo_screenwidth()
        win.geometry(f"{w_px}x{h_px}+{sw - w_px - 20}+20")

        # Шапка
        bar = tk.Frame(win, bg=C_HDR_BG, height=40)
        bar.pack(fill=tk.X); bar.pack_propagate(False)
        tk.Label(bar, text=title, bg=C_HDR_BG, fg=C_HDR_FG,
                 font=("Segoe UI", 10, "bold"), anchor="w").pack(
                 side=tk.LEFT, padx=12, pady=8)

        # Текстовое поле
        body = tk.Frame(win, bg=C_BG); body.pack(fill=tk.BOTH, expand=True, padx=8, pady=6)
        self._text = tk.Text(body, wrap=tk.WORD, font=("Segoe UI", 9),
                             bg=C_BG, fg=C_TEXT, relief="flat", bd=0,
                             highlightthickness=0, state=tk.DISABLED, height=12)
        sb = ttk.Scrollbar(body, command=self._text.yview)
        self._text.configure(yscrollcommand=sb.set)
        sb.pack(side=tk.RIGHT, fill=tk.Y)
        self._text.pack(side=tk.LEFT, fill=tk.BOTH, expand=True)

        self._refresh()
        win.lift()
        win.focus_force()
        # После показа снимаем жёсткий topmost — чтобы не перекрывала диалоги
        win.after(500, lambda: win.attributes("-topmost", False) if self._win else None)
        win.update()

    def add(self, label: str, filepath: str) -> None:
        """Добавляет строку: что за файл и его имя."""
        import os
        name = os.path.basename(filepath) if filepath else "—"
        self._lines.append(f"  {label}: {name}")
        self._refresh()

    def add_text(self, text: str) -> None:
        """Добавляет произвольную строку-разделитель или заголовок."""
        self._lines.append(text)
        self._refresh()

    def _refresh(self) -> None:
        if self._text is None: return
        try:
            self._text.config(state=tk.NORMAL)
            self._text.delete("1.0", tk.END)
            self._text.insert(tk.END, "\n".join(self._lines))
            self._text.see(tk.END)
            self._text.config(state=tk.DISABLED)
            if self._win:
                self._win.update()
        except tk.TclError:
            pass

    def close(self) -> None:
        """Закрывает журнал."""
        if self._win:
            try: self._win.destroy()
            except tk.TclError: pass
            self._win = None


# Глобальный журнал сессии
_session_log = SessionLog()


def show_progress(message: str, title: str = "Готово") -> None:
    win = make_window(title, 700, 560, resizable=True)
