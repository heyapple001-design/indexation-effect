    print(f"   ✓ Добавлено новых строк: {added_count}")
    print(f"   ⏱ Сопоставление заняло: {match_sec:.1f} сек")
    return updated_count, added_count, matched_indices, added_indices, \
           not_found_indices, pivot['Эффект_тыс'].sum(), df_report


def _build_new_row(df_report: pd.DataFrame, pivot_row: pd.Series,
                   svc_val: str, selected_date: str, target_col: str,
                   eff_value: float,
                   pct_lookup: Optional[dict] = None) -> dict:
    """Строит словарь новой строки с нормализованными форматами.
    pct_lookup: dict (мрф_norm, рф_norm) → процент индексации из отчёта.
    """
    new_row = {col: None for col in df_report.columns}

    # Услуга — UPPERCASE для спецуслуг, иначе первое с заглавной
    if RPT_COL_SERVICE in new_row:
        new_row[RPT_COL_SERVICE] = fmt_service(svc_val)

    # Дата — datetime-объект (openpyxl запишет как дату, формат DD.MM.YYYY зададим при сохранении)
    if RPT_COL_DATE in new_row:
        try:
            new_row[RPT_COL_DATE] = pd.to_datetime(selected_date, dayfirst=True).date()
        except (ValueError, TypeError, OverflowError):
            new_row[RPT_COL_DATE] = selected_date

    # % индексации:
    # 1) Сначала берём из отчёта (pct_lookup) — по ключу МРФ+РФ из выборки
    # 2) Если не нашли — берём из базы индексации
    if RPT_COL_PCT in new_row:
        pct_val = None
        if pct_lookup:
            mrf_key = norm_text(pivot_row[BASE_COL_MRF]) if BASE_COL_MRF in pivot_row.index else ""
            rf_key  = map_rf(pivot_row[BASE_COL_RF])     if BASE_COL_RF  in pivot_row.index else ""
            pct_val = pct_lookup.get((mrf_key, rf_key))
        if pct_val is None and BASE_COL_PCT in pivot_row.index:
            pct_val = fmt_pct(pivot_row[BASE_COL_PCT])
        if pct_val is not None:
            new_row[RPT_COL_PCT] = pct_val

    # МРФ — нормализованное написание через словарь
    if RPT_COL_MRF in new_row and BASE_COL_MRF in pivot_row.index:
        new_row[RPT_COL_MRF] = fmt_mrf(pivot_row[BASE_COL_MRF])

    # РФ — полное официальное название через обратный маппинг
    # Напр: 'ФЭС Тюменский' → 'Филиал в Тюменской и Курганской областях'
    if RPT_COL_RF in new_row and BASE_COL_RF in pivot_row.index:
        new_row[RPT_COL_RF] = unmap_rf(map_rf(pivot_row[BASE_COL_RF]))

    # Краткий Сегмент — UPPERCASE
    if RPT_COL_SEGMENT in new_row and BASE_COL_SEGMENT in pivot_row.index:
        new_row[RPT_COL_SEGMENT] = fmt_seg(pivot_row[BASE_COL_SEGMENT])

    # Сегмент1 из базы → Сегмент в отчёте
    if RPT_COL_SEGMENT1 in new_row and BASE_COL_SEGMENT1 in pivot_row.index:
        new_row[RPT_COL_SEGMENT1] = fmt_seg(pivot_row[BASE_COL_SEGMENT1])

    # Подсегмент — UPPERCASE
    if RPT_COL_SUBSEG in new_row and BASE_COL_SUBSEG in pivot_row.index:
        new_row[RPT_COL_SUBSEG] = fmt_seg(pivot_row[BASE_COL_SUBSEG])

    # Эффект — число с 3 знаками
    if target_col in new_row:
        new_row[target_col] = fmt_num3(eff_value)

    return new_row

