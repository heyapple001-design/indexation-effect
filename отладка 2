#  РАСЧЁТ ЭФФЕКТА
#  Два режима — возвращают одинаковый pivot DataFrame
# ══════════════════════════════════════════════════════════════

def calc_pivot_external(df_base: pd.DataFrame, df_amount: pd.DataFrame,
                        base_col: str, id_col: str,
                        amount_col: str, group_cols: list[str]) -> pd.DataFrame:
    """
    РЕЖИМ A: начисления в отдельном файле.
    Джоин по MSISDN, эффект = amount_col - base_col.
    """
    df_base   = df_base.copy()
    df_amount = df_amount.copy()

    df_base[base_col]     = pd.to_numeric(df_base[base_col],     errors='coerce')
    df_amount[amount_col] = pd.to_numeric(df_amount[amount_col], errors='coerce')
    df_base[id_col]       = df_base[id_col].astype(str).str.strip().str.replace('.0', '', regex=False)
    df_amount["MSISDN"]   = df_amount["MSISDN"].astype(str).str.strip().str.replace('.0', '', regex=False)

    print("   ⏳ Соединение баз данных по MSISDN, пожалуйста подождите...")
    t = datetime.now()
    merged = df_base.merge(df_amount[["MSISDN", amount_col]],
                           left_on=id_col, right_on="MSISDN", how='left')
    print(f"   ✓ Соединено: {len(merged):,} строк ({(datetime.now()-t).total_seconds():.1f} сек)")

    merged['Эффект_руб'] = merged[amount_col] - merged[base_col]
    merged.loc[merged['Эффект_руб'] < 0, 'Эффект_руб'] = 0
    print(f"   ✓ С положительным эффектом: {(merged['Эффект_руб'] > 0).sum():,}")

    print("   ⏳ Группировка данных...")
    # Доп. колонки которые хотим сохранить в pivot (берём первое значение группы)
    extra_cols = [c for c in [BASE_COL_PCT, BASE_COL_SEGMENT1]
                  if c in merged.columns]
    agg_dict = {'Эффект_руб': 'sum'}
    for c in extra_cols:
        agg_dict[c] = 'first'
    pivot = merged.groupby(group_cols, as_index=False).agg(agg_dict)
    pivot['Эффект_тыс'] = (pivot['Эффект_руб'] / 1000).round(3)
    return pivot


def calc_pivot_inbase(df_base: pd.DataFrame, base_col: str,
                      current_col: str, group_cols: list[str]) -> pd.DataFrame:
    """
    РЕЖИМ B: начисления в той же базе.
    Эффект = current_col - base_col, без джоина.
    """
    df = df_base.copy()
    df[base_col]    = pd.to_numeric(df[base_col],    errors='coerce')
    df[current_col] = pd.to_numeric(df[current_col], errors='coerce')

    print("   ⏳ Расчёт эффекта из колонок базы...")
    df['Эффект_руб'] = df[current_col] - df[base_col]
    df.loc[df['Эффект_руб'] < 0, 'Эффект_руб'] = 0
    print(f"   ✓ Строк в базе: {len(df):,}")
    print(f"   ✓ С положительным эффектом: {(df['Эффект_руб'] > 0).sum():,}")

    print("   ⏳ Группировка данных...")
    extra_cols = [c for c in [BASE_COL_PCT, BASE_COL_SEGMENT1]
                  if c in df.columns]
    agg_dict = {'Эффект_руб': 'sum'}
    for c in extra_cols:
        agg_dict[c] = 'first'
    pivot = df.groupby(group_cols, as_index=False).agg(agg_dict)
    pivot['Эффект_тыс'] = (pivot['Эффект_руб'] / 1000).round(3)
    return pivot

