class BaseWidget(QFrame):
    deleted = pyqtSignal(object)

    def __init__(self, base_num: int, dates: list, mode: str, parent=None):
        super().__init__(parent)
        self.base_num = base_num
        self._dates = dates
        self._mode = mode
        self._last_paths = load_last_paths()
        self._init_ui()

    def _init_ui(self):
        self.setFrameShape(QFrame.StyledPanel)
        self.setStyleSheet(f"BaseWidget{{background:{BG_PANEL};border:1px solid {BORDER};border-radius:4px;}}")

        layout = QVBoxLayout(self)
        layout.setContentsMargins(10, 10, 10, 10)
        layout.setSpacing(6)

        # Заголовок
        header = QHBoxLayout()
        lbl = QLabel(f"<b>База #{self.base_num}</b>")
        lbl.setStyleSheet("font-size:11pt;")
        header.addWidget(lbl)
        header.addStretch()
        self._del_btn = QPushButton("✕ Удалить")
        self._del_btn.setFixedWidth(90)
        self._del_btn.setStyleSheet(
            f"QPushButton{{background:{RED};color:white;border:none;padding:4px 10px;border-radius:2px;}}"
            f"QPushButton:hover{{background:#A11E12;}}")
        self._del_btn.clicked.connect(lambda: self.deleted.emit(self))
        header.addWidget(self._del_btn)
        layout.addLayout(header)

        # Сетка параметров
        grid = QGridLayout()
        grid.setSpacing(6)

        grid.addWidget(QLabel("Файл базы:"), 0, 0)
        self._base_path = QLineEdit()
        self._base_path.setReadOnly(True)
        self._base_path.setPlaceholderText("не выбран")
        grid.addWidget(self._base_path, 0, 1)
        self._base_btn = QPushButton("...")
        self._base_btn.setFixedWidth(40)
        self._base_btn.clicked.connect(self._select_base)
        grid.addWidget(self._base_btn, 0, 2)

        grid.addWidget(QLabel("Дата индексации:"), 1, 0)
        self._date_combo = QComboBox()
        self._date_combo.addItems(self._dates)
        grid.addWidget(self._date_combo, 1, 1, 1, 2)

        grid.addWidget(QLabel("Колонка ДО индексации:"), 2, 0)
        self._base_col_combo = QComboBox()
        grid.addWidget(self._base_col_combo, 2, 1, 1, 2)

        # MSISDN (для external)
        self._msisdn_label = QLabel("Колонка MSISDN:")
        grid.addWidget(self._msisdn_label, 3, 0)
        self._msisdn_combo = QComboBox()
        grid.addWidget(self._msisdn_combo, 3, 1, 1, 2)

        # Текущее начисление (для inbase)
        self._current_label = QLabel("Текущее начисление:")
        grid.addWidget(self._current_label, 4, 0)
        self._current_combo = QComboBox()
        grid.addWidget(self._current_combo, 4, 1, 1, 2)

        layout.addLayout(grid)
        self._apply_mode()

    def _apply_mode(self):
        if self._mode == MODE_EXTERNAL:
            self._msisdn_label.show()
            self._msisdn_combo.show()
            self._current_label.hide()
            self._current_combo.hide()
        else:
            self._msisdn_label.hide()
            self._msisdn_combo.hide()
            self._current_label.show()
            self._current_combo.show()

    def set_mode(self, mode: str):
        self._mode = mode
        self._apply_mode()

    def _select_base(self):
        start_dir = self._last_paths.get("base_dir", os.path.expanduser("~/Desktop"))
        path, _ = QFileDialog.getOpenFileName(
            self, f"База #{self.base_num}", start_dir,
            "Excel files (*.xlsx);;All files (*.*)")
        if not path:
            return
        self._base_path.setText(path)
        self._last_paths["base_dir"] = os.path.dirname(path)
        save_last_paths(self._last_paths)
        self._load_columns(path)

    def _load_columns(self, path: str):
        try:
            df = pd.read_excel(path, sheet_name=SHEET_TABLE2, nrows=5)
            cols = list(df.columns)
        except Exception as e:
            QMessageBox.critical(self, "Ошибка", f"Не могу прочитать базу:\n{e}")
            return

        self._base_col_combo.clear()
        self._base_col_combo.addItems(cols)
        self._msisdn_combo.clear()
        self._msisdn_combo.addItems(cols)
        self._current_combo.clear()
        self._current_combo.addItems(cols)

        # Автовыбор колонки ДО
        for c in cols:
            if "до" in str(c).lower() or "base" in str(c).lower():
                self._base_col_combo.setCurrentText(c)
                break

        # Автовыбор MSISDN
        possible = ["MSISDN", "Уникальный идентификационный номер услуги (ШПД, VPN - логин порта)",
                    "Уникальный идентификационный номер услуги", "MSISDN/Логин"]
        for p in possible:
            if p in cols:
                self._msisdn_combo.setCurrentText(p)
                break

    def get_data(self) -> Optional[dict]:
        base_path = self._base_path.text()
        if not base_path:
            QMessageBox.warning(self, "Внимание", f"База #{self.base_num}: не выбран файл")
            return None
        data = {
            "base_path": base_path,
            "date": self._date_combo.currentText(),
            "base_col": self._base_col_combo.currentText(),
            "charges_mode": self._mode,
            "id_col": None,
            "current_col": None,
            "services": [],
        }
        if self._mode == MODE_EXTERNAL:
            data["id_col"] = self._msisdn_combo.currentText()
        else:
            data["current_col"] = self._current_combo.currentText()
        return data

