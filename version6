# ── SQLite ─────────────────────────────────────────────────────
class TempDB:
    def __init__(self, db_path: str):
        self.path = db_path
        self.conn = sqlite3.connect(db_path, check_same_thread=False)
        self._init_schema()

    def _init_schema(self) -> None:
        self.conn.executescript("""
            PRAGMA journal_mode=WAL;
            PRAGMA synchronous=NORMAL;
            CREATE TABLE IF NOT EXISTS pivot_results (
                session_id TEXT, mrf_name TEXT, base_num INTEGER,
                data_blob BLOB, created_at TEXT DEFAULT (datetime('now'))
            );
            CREATE TABLE IF NOT EXISTS report_updates (
                session_id TEXT, mrf_name TEXT, base_num INTEGER,
                row_idx INTEGER, col_name TEXT, new_value TEXT, fill_type TEXT
            );
            CREATE TABLE IF NOT EXISTS checkpoints (
                session_id TEXT PRIMARY KEY, month TEXT, chosen_mrf TEXT,
                table3_path TEXT, target_col TEXT, completed_bases TEXT,
                updated_at TEXT DEFAULT (datetime('now'))
            );
            CREATE INDEX IF NOT EXISTS idx_pivot_session
                ON pivot_results(session_id, mrf_name, base_num);
            CREATE INDEX IF NOT EXISTS idx_updates_session
                ON report_updates(session_id, mrf_name, base_num);
        """)
        self.conn.commit()

    def save_pivot(self, session_id: str, mrf: str, base_num: int, pivot: pd.DataFrame) -> None:
        blob = pickle.dumps(pivot, protocol=pickle.HIGHEST_PROTOCOL)
        self.conn.execute(
            "INSERT INTO pivot_results(session_id,mrf_name,base_num,data_blob) VALUES(?,?,?,?)",
            (session_id, mrf, base_num, blob))
        self.conn.commit()

    def save_update(self, session_id: str, mrf: str, base_num: int,
                    row_idx: int, col: str, value: Any, fill: str) -> None:
        self.conn.execute(
            "INSERT INTO report_updates(session_id,mrf_name,base_num,row_idx,col_name,new_value,fill_type) "
            "VALUES(?,?,?,?,?,?,?)",
            (session_id, mrf, base_num, row_idx, col, str(value), fill))

    def flush_updates(self) -> None:
        self.conn.commit()

    def load_updates(self, session_id: str) -> list:
        return self.conn.execute(
            "SELECT row_idx,col_name,new_value,fill_type FROM report_updates WHERE session_id=? ORDER BY row_idx",
            (session_id,)).fetchall()

    def save_checkpoint(self, session_id: str, month: str, chosen_mrf: list,
                        table3_path: str, target_col: str, completed: list) -> None:
        self.conn.execute("""
            INSERT INTO checkpoints(session_id,month,chosen_mrf,table3_path,target_col,completed_bases,updated_at)
            VALUES(?,?,?,?,?,?,datetime('now'))
            ON CONFLICT(session_id) DO UPDATE SET
                completed_bases=excluded.completed_bases,
                updated_at=excluded.updated_at
        """, (session_id, month, json.dumps(chosen_mrf, ensure_ascii=False),
              table3_path, target_col, json.dumps(completed, ensure_ascii=False)))
        self.conn.commit()

    def close(self) -> None:
        try:
            self.conn.close()
        except Exception:
            pass

_temp_db: Optional[TempDB] = None
def get_temp_db() -> TempDB:
    global _temp_db
    if _temp_db is None:
        db_path = pathlib.Path(tempfile.gettempdir()) / "indexation_session.db"
        _temp_db = TempDB(str(db_path))
    return _temp_db

# ── WORKER ─────────────────────────────────────────────────────
class CalcWorker(QObject):
    log_msg = pyqtSignal(str)
    progress = pyqtSignal(int, int, str)
    finished = pyqtSignal(dict)
    error = pyqtSignal(str)

    def __init__(self, params: dict):
        super().__init__()
        self.params = params
        self._stopped = False

    def stop(self) -> None:
        self._stopped = True

    def _log(self, msg: str) -> None:
        log.info(msg)
        self.log_msg.emit(msg)

    def _check_memory(self) -> None:
        mb = memory_mb()
        if mb > MEMORY_WARN_MB:
            self._log(f"⚠️ RAM: {mb:.0f} МБ — сборка мусора")
            gc.collect()
            self._log(f"✓ RAM: {memory_mb():.0f} МБ")

    def run(self) -> None:
        try:
            self._run_session()
        except Exception as e:
            log.exception("Ошибка в CalcWorker")
            self.error.emit(str(e))

    def _run_session(self) -> None:
        p = self.params
        session_id = p["session_id"]
        month = p["month"]
        mrf_name = p["mrf_name"]
        table3_path = p["table3_path"]
        target_col = p["target_col"]
        save_folder = p["save_folder"]
        amount_col = f"Без НДС {month}"
        bases = p["bases"]

        db = get_temp_db()
        counts = {"matched": 0, "added": 0, "not_found": 0}

        self._log(f"\n{'='*55}\nСЕССИЯ {session_id}\n{'='*55}")
        self._log(f"Месяц: {month} | МРФ: {mrf_name}")
        self._log(f"Баз в работе: {len(bases)}")

        self._log("\n⏳ Загрузка отчёта...")
        self.progress.emit(0, 100, "Загрузка отчёта")
        t0 = datetime.now()
        df_report = pd.read_excel(table3_path, sheet_name=SHEET_TABLE3)
        self._log(f"   ✓ {len(df_report):,} строк за {(datetime.now()-t0).total_seconds():.1f} сек")
        self._check_memory()

        total = len(bases)
        for base_idx, base_cfg in enumerate(bases, 1):
            if self._stopped:
                break
            base_num = base_idx
            base_path = base_cfg["base_path"]
            charges_mode = base_cfg["charges_mode"]
            base_col = base_cfg["base_col"]
            id_col = base_cfg.get("id_col")
            current_col = base_cfg.get("current_col")
            charges_path = base_cfg.get("charges_path")
            selected_date = base_cfg["date"]
            selected_services = base_cfg.get("services", [])

            base_name = os.path.basename(base_path)
            self._log(f"\n  БАЗА #{base_num}: {base_name}")
            self._log(f"  Режим: {'📂 внешний файл' if charges_mode == MODE_EXTERNAL else '📊 в базе'}")
            self._log(f"  Дата: {selected_date} | Услуга: {', '.join(selected_services)}")
            self.progress.emit(base_idx - 1, total, f"База #{base_num} из {total}")

            self._log("  ⏳ Загрузка базы...")
            t = datetime.now()
            try:
                df_base = pd.read_excel(base_path, sheet_name=SHEET_TABLE2)
            except Exception as e:
                self._log(f"  ❌ Ошибка загрузки базы: {e}")
                continue
            self._log(f"  ✓ {len(df_base):,} строк ({(datetime.now()-t).total_seconds():.1f} сек)")

            df_amount = None
            if charges_mode == MODE_EXTERNAL:
                if not charges_path:
                    self._log("  ❌ Путь к файлу начислений не задан")
                    continue
                self._log(f"  ⏳ Загрузка начислений...")
                t = datetime.now()
                try:
                    df_amount = pd.read_excel(charges_path, sheet_name=SHEET_TABLE1)
                except Exception as e:
                    self._log(f"  ❌ Ошибка загрузки начислений: {e}")
                    continue
                self._log(f"  ✓ {len(df_amount):,} строк ({(datetime.now()-t).total_seconds():.1f} сек)")
                if amount_col not in df_amount.columns:
                    self._log(f"  ❌ Нет колонки '{amount_col}'")
                    continue
                if "MSISDN" not in df_amount.columns:
                    self._log("  ❌ Нет колонки 'MSISDN'")
                    continue

            self._log("  ⏳ Расчёт эффекта...")
            t_calc = datetime.now()
            try:
                gcols = [c for c in [BASE_COL_MRF, BASE_COL_RF,
                                     BASE_COL_SEGMENT, BASE_COL_SUBSEG,
                                     BASE_COL_SEGMENT1] if c in df_base.columns]
                if charges_mode == MODE_EXTERNAL:
                    pivot = _calc_pivot_external(df_base, df_amount,
                                                 base_col, id_col, amount_col, gcols)
                else:
                    pivot = _calc_pivot_inbase(df_base, base_col, current_col, gcols)
            except Exception as e:
                self._log(f"  ❌ Ошибка расчёта: {e}")
                continue
            finally:
                del df_amount, df_base
                gc.collect()

            calc_sec = (datetime.now() - t_calc).total_seconds()
            self._log(f"  ✓ Групп: {len(pivot)}, эффект: {pivot['Эффект_тыс'].sum():,.3f} тыс. руб. ({calc_sec:.1f} сек)")
            self._check_memory()

            db.save_pivot(session_id, mrf_name, base_num, pivot)

            sel = {
                "date": selected_date,
                "segments": {RPT_COL_SERVICE: selected_services} if selected_services else {},
            }

            self._log("  ⏳ Сопоставление с отчётом...")
            t_match = datetime.now()
            upd, add, nf, df_report = _match_pivot_to_report(
                pivot, df_report, sel, target_col, base_col,
                session_id, mrf_name, base_num, db, self._log)

            match_sec = (datetime.now() - t_match).total_seconds()
            self._log(f"  ✓ Записано: {upd} | Добавлено: {add} | Не найдено: {nf} | ⏱ {match_sec:.1f} сек")

            counts["matched"] += upd
            counts["added"] += add
            counts["not_found"] += nf

            del pivot
            gc.collect()

        self._log("\n⏳ Финальная запись отчёта в Excel...")
        self.progress.emit(total, total, "Сохранение результата")

        timestamp = datetime.now().strftime("%Y%m%d_%H%M%S")
        base_name = os.path.splitext(os.path.basename(table3_path))[0]
        save_filename = f"{base_name}_результат_{timestamp}.xlsx"
        save_path = os.path.join(save_folder, save_filename)

        self._apply_updates_and_save(db, session_id, df_report, target_col, save_path)

        stats = {
            "session_id": session_id,
            "month": month,
            "counts": counts,
            "save_path": save_path,
        }
        self.finished.emit(stats)

    def _apply_updates_and_save(self, db: TempDB, session_id: str,
                                df_report: pd.DataFrame,
                                target_col: str, save_path: str) -> None:
        self._log("  ⏳ Применение обновлений из SQLite...")
        updates = db.load_updates(session_id)
        self._log(f"  ✓ Обновлений в БД: {len(updates)}")

        if target_col in df_report.columns:
            df_report[target_col] = df_report[target_col].astype(object)

        matched_rows = []
        added_rows = []
        nf_rows = []

        for row_idx, col_name, new_value, fill_type in updates:
            if row_idx < len(df_report):
                try:
                    val = float(new_value) if new_value not in ("None", "") else None
                except ValueError:
                    val = new_value
                if val is not None:
                    df_report.loc[row_idx, col_name] = val
            if fill_type == "updated":
                matched_rows.append(row_idx)
            elif fill_type == "added":
                added_rows.append(row_idx)
            elif fill_type == "not_found":
                nf_rows.append(row_idx)

        self._log("  ⏳ Нормализация данных...")
        for col_fn in [
            (RPT_COL_SERVICE, fmt_service), (RPT_COL_MRF, fmt_mrf),
            (RPT_COL_RF, fmt_title), (RPT_COL_SEGMENT, fmt_seg),
            (RPT_COL_SUBSEG, fmt_seg), (RPT_COL_SEGMENT1, fmt_seg),
        ]:
            real = find_col(df_report, col_fn[0])
            if real:
                df_report[real] = df_report[real].apply(
                    lambda x: col_fn[1](x) if pd.notna(x) and str(x).strip() else x)

        real_date = find_col(df_report, RPT_COL_DATE)
        if real_date:
            df_report[real_date] = df_report[real_date].apply(
                lambda x: pd.to_datetime(x, dayfirst=True, errors="coerce").date()
                if pd.notna(x) and str(x).strip() else x)

        real_pct = find_col(df_report, RPT_COL_PCT)
        if real_pct:
            df_report[real_pct] = df_report[real_pct].apply(
                lambda x: fmt_pct(x) if pd.notna(x) and str(x).strip() else x)

        real_tgt = find_col(df_report, target_col)
        if real_tgt:
            df_report[real_tgt] = df_report[real_tgt].apply(
                lambda x: fmt_num3(x) if pd.notna(x) and str(x).strip() else x)

        self._log("  ⏳ Запись в Excel...")
        with pd.ExcelWriter(save_path, engine='openpyxl', mode='w') as writer:
            df_report.to_excel(writer, sheet_name=SHEET_TABLE3, index=False)

        self._log("  ⏳ Применение цветовой заливки...")
        wb = load_workbook(save_path)
        ws = wb[SHEET_TABLE3]
        grn = PatternFill(start_color=FILL_UPDATED, end_color=FILL_UPDATED, fill_type='solid')
        blue = PatternFill(start_color=FILL_ADDED, end_color=FILL_ADDED, fill_type='solid')
        yel = PatternFill(start_color=FILL_NOT_FOUND, end_color=FILL_NOT_FOUND, fill_type='solid')
        cols = list(df_report.columns)
        ci_t = (cols.index(target_col) + 1) if target_col in cols else 1

        FMT_MAP = {RPT_COL_DATE: "DD.MM.YYYY", RPT_COL_PCT: "0.00%", target_col: "#,##0.000"}
        TEXT_COLS = [RPT_COL_SERVICE, RPT_COL_MRF, RPT_COL_RF,
                     RPT_COL_SEGMENT, RPT_COL_SUBSEG, RPT_COL_SEGMENT1]
        for rn in range(2, ws.max_row + 1):
            for cname in TEXT_COLS:
                if cname in cols:
                    ws.cell(rn, cols.index(cname) + 1).number_format = "@"
            for cname, fmt in FMT_MAP.items():
                if cname in cols:
                    ws.cell(rn, cols.index(cname) + 1).number_format = fmt

        for ridx in set(matched_rows):
            ws.cell(ridx + 2, ci_t).fill = grn
        for ridx in set(added_rows):
            for c in range(1, len(cols) + 1):
                ws.cell(ridx + 2, c).fill = blue
        for ridx in set(nf_rows):
            ws.cell(ridx + 2, ci_t).fill = yel

        wb.save(save_path)
        self._log(f"  ✓ Сохранено: {os.path.basename(save_path)}")
        self._log(f"     🟢 {len(set(matched_rows))} | 🔵 {len(set(added_rows))} | 🟡 {len(set(nf_rows))}")

# ── РАСЧЁТНЫЕ ФУНКЦИИ ──────────────────────────────────────────
def _calc_pivot_external(df_base: pd.DataFrame, df_amount: pd.DataFrame,
                         base_col: str, id_col: str,
                         amount_col: str, gcols: list) -> pd.DataFrame:
    df_base = df_base.copy()
    df_amount = df_amount.copy()
    df_base[base_col] = pd.to_numeric(df_base[base_col], errors='coerce')
    df_amount[amount_col] = pd.to_numeric(df_amount[amount_col], errors='coerce')
    df_base[id_col] = df_base[id_col].astype(str).str.strip().str.replace('.0', '', regex=False)
    df_amount["MSISDN"] = df_amount["MSISDN"].astype(str).str.strip().str.replace('.0', '', regex=False)
    merged = df_base.merge(df_amount[["MSISDN", amount_col]],
                           left_on=id_col, right_on="MSISDN", how='left')
    del df_base, df_amount
    gc.collect()
    merged['Эффект_руб'] = (merged[amount_col] - merged[base_col]).clip(lower=0)
    extra = [c for c in [BASE_COL_PCT, BASE_COL_SEGMENT1] if c in merged.columns]
    agg = {'Эффект_руб': 'sum', **{c: 'first' for c in extra}}
    pivot = merged.groupby(gcols, as_index=False).agg(agg)
    pivot['Эффект_тыс'] = (pivot['Эффект_руб'] / 1000).round(3)
    del merged
    gc.collect()
    return pivot

def _calc_pivot_inbase(df_base: pd.DataFrame, base_col: str,
                       current_col: str, gcols: list) -> pd.DataFrame:
    df = df_base.copy()
    df[base_col] = pd.to_numeric(df[base_col], errors='coerce')
    df[current_col] = pd.to_numeric(df[current_col], errors='coerce')
    df['Эффект_руб'] = (df[current_col] - df[base_col]).clip(lower=0)
    extra = [c for c in [BASE_COL_PCT, BASE_COL_SEGMENT1] if c in df.columns]
    agg = {'Эффект_руб': 'sum', **{c: 'first' for c in extra}}
    pivot = df.groupby(gcols, as_index=False).agg(agg)
    pivot['Эффект_тыс'] = (pivot['Эффект_руб'] / 1000).round(3)
    del df
    gc.collect()
    return pivot

def _match_pivot_to_report(pivot: pd.DataFrame, df_report: pd.DataFrame,
                           sel: dict, target_col: str, base_col: str,
                           session_id: str, mrf_name: str, base_num: int,
                           db: TempDB, log_fn: Callable) -> tuple:
    selected_date = sel.get("date", "")
    selected_segments = sel.get("segments", {})
    selected_services = set(selected_segments.get(RPT_COL_SERVICE, []))
    svc_col = find_col(df_report, RPT_COL_SERVICE)

    report_dict = defaultdict(list)
    for idx, row in df_report.iterrows():
        rd = norm_date(row[RPT_COL_DATE]) if RPT_COL_DATE in df_report.columns else ""
        if rd != norm_date(selected_date):
            continue
        svc = norm_text(row[svc_col]) if svc_col else ""
        if selected_services and svc not in selected_services:
            continue
        # Используем исправленную функцию map_rf
        mrf_ = norm_text(row[RPT_COL_MRF]) if RPT_COL_MRF in df_report.columns else ""
        rf_ = map_rf(row[RPT_COL_RF]) if RPT_COL_RF in df_report.columns else ""
        seg_ = norm_text(row[RPT_COL_SEGMENT]) if RPT_COL_SEGMENT in df_report.columns else ""
        sub_ = norm_text(row[RPT_COL_SUBSEG]) if RPT_COL_SUBSEG in df_report.columns else ""
        report_dict[(svc, mrf_, rf_, seg_, sub_)].append(idx)

    total_rpt = sum(len(v) for v in report_dict.values())

    pivot_ks = set()
    for _, r in pivot.iterrows():
        pivot_ks.add((
            norm_text(r[BASE_COL_MRF]) if BASE_COL_MRF in r.index else "",
            map_rf(r[BASE_COL_RF]) if BASE_COL_RF in r.index else "",
            norm_text(r[BASE_COL_SEGMENT]) if BASE_COL_SEGMENT in r.index else "",
            norm_text(r[BASE_COL_SUBSEG]) if BASE_COL_SUBSEG in r.index else "",
        ))

    pct_col = find_col(df_report, RPT_COL_PCT)
    pct_lookup = {}
    if pct_col and total_rpt > 0:
        for kf, ridxs in report_dict.items():
            mk, rk = kf[1], kf[2]
            for ridx in ridxs:
                v = df_report.loc[ridx, pct_col]
                if pd.notna(v) and str(v).strip() not in ("", "0", "0.0"):
                    pct_lookup[(mk, rk)] = fmt_pct(v)
                    break

    nf_idxs = []
    if total_rpt > 0:
        if target_col in df_report.columns:
            df_report[target_col] = df_report[target_col].astype(object)
        for kf, ridxs in report_dict.items():
            rmrf, rrf = kf[1], kf[2]
            if (rmrf, rrf, kf[3], kf[4]) not in pivot_ks:
                for ridx in ridxs:
                    try:
                        cur = df_report.loc[ridx, target_col]
                        if pd.isna(cur):
                            df_report.loc[ridx, target_col] = 0
                    except (TypeError, KeyError, IndexError):
                        pass
                    nf_idxs.append(ridx)
                    db.save_update(session_id, mrf_name, base_num,
                                   ridx, target_col, 0, "not_found")

    updated = added_c = 0
    svcs_check = selected_services if selected_services else {k[0] for k in report_dict}
    if total_rpt == 0:
        svcs_check = set()

    for _, pr in pivot.iterrows():
        mrf_ = norm_text(pr[BASE_COL_MRF]) if BASE_COL_MRF in pr.index else ""
        # Используем исправленную функцию map_rf
        rf_ = map_rf(pr[BASE_COL_RF]) if BASE_COL_RF in pr.index else ""
        seg_ = norm_text(pr[BASE_COL_SEGMENT]) if BASE_COL_SEGMENT in pr.index else ""
        sub_ = norm_text(pr[BASE_COL_SUBSEG]) if BASE_COL_SUBSEG in pr.index else ""

        eff = pr['Эффект_тыс']

        if total_rpt > 0:
            sc_list = list(svcs_check) if svcs_check else [None]
            found = False
            for svc in sc_list:
                key = (svc, mrf_, rf_, seg_, sub_)
                if key in report_dict:
                    for ridx in report_dict[key]:
                        df_report.loc[ridx, target_col] = eff
                        db.save_update(session_id, mrf_name, base_num,
                                       ridx, target_col, eff, "updated")
                        updated += 1
                    found = True
            if not found:
                kns = (mrf_, rf_, seg_, sub_)
                ex = {(k[1], k[2], k[3], k[4]) for k in report_dict}
                if kns in ex:
                    for kf, ridxs in report_dict.items():
                        if (kf[1], kf[2], kf[3], kf[4]) == kns:
                            for ridx in ridxs:
                                df_report.loc[ridx, target_col] = eff
                                db.save_update(session_id, mrf_name, base_num,
                                               ridx, target_col, eff, "updated")
                                updated += 1
                            found = True
                            break
            if not found:
                svc_v = list(svcs_check)[0] if svcs_check else ""
                new_row = _build_row(df_report, pr, svc_v, selected_date,
                                     target_col, eff, pct_lookup)
                df_report = pd.concat([df_report, pd.DataFrame([new_row])],
                                      ignore_index=True)
                ridx = len(df_report) - 1
                db.save_update(session_id, mrf_name, base_num,
                               ridx, target_col, eff, "added")
                added_c += 1
        else:
            svc_v = (str(pr[BASE_COL_SERVICE]).strip()
                     if BASE_COL_SERVICE in pr.index and pd.notna(pr[BASE_COL_SERVICE])
                     else (list(selected_services)[0] if selected_services else ""))
            new_row = _build_row(df_report, pr, svc_v, selected_date,
                                 target_col, eff, pct_lookup)
            df_report = pd.concat([df_report, pd.DataFrame([new_row])],
                                  ignore_index=True)
            ridx = len(df_report) - 1
            db.save_update(session_id, mrf_name, base_num,
                           ridx, target_col, eff, "added")
            added_c += 1

    db.flush_updates()
    return updated, added_c, len(nf_idxs), df_report

def _build_row(df_report: pd.DataFrame, pivot_row: pd.Series,
               svc_val: str, selected_date: str, target_col: str,
               eff: float, pct_lookup: Optional[dict]) -> dict:
    row = {col: None for col in df_report.columns}
    if RPT_COL_SERVICE in row:
        row[RPT_COL_SERVICE] = fmt_service(svc_val)
    if RPT_COL_DATE in row:
        try:
            row[RPT_COL_DATE] = pd.to_datetime(selected_date, dayfirst=True).date()
        except (ValueError, TypeError, OverflowError):
            row[RPT_COL_DATE] = selected_date
    if RPT_COL_PCT in row:
        pct = None
        if pct_lookup:
            mk = norm_text(pivot_row[BASE_COL_MRF]) if BASE_COL_MRF in pivot_row.index else ""
            rk = map_rf(pivot_row[BASE_COL_RF]) if BASE_COL_RF in pivot_row.index else ""
            pct = pct_lookup.get((mk, rk))
        if pct is None and BASE_COL_PCT in pivot_row.index:
            pct = fmt_pct(pivot_row[BASE_COL_PCT])
        if pct is not None:
            row[RPT_COL_PCT] = pct
    if RPT_COL_MRF in row and BASE_COL_MRF in pivot_row.index:
        row[RPT_COL_MRF] = fmt_mrf(pivot_row[BASE_COL_MRF])
    if RPT_COL_RF in row and BASE_COL_RF in pivot_row.index:
        # Используем map_rf для нормализации, затем unmap_rf для обратного преобразования
        # Это позволяет сохранить консистентность с маппингом
        rf_canon = map_rf(pivot_row[BASE_COL_RF])
        row[RPT_COL_RF] = unmap_rf(rf_canon) if rf_canon in RF_REVERSE else rf_canon
    if RPT_COL_SEGMENT in row and BASE_COL_SEGMENT in pivot_row.index:
        row[RPT_COL_SEGMENT] = fmt_seg(pivot_row[BASE_COL_SEGMENT])
    if RPT_COL_SEGMENT1 in row and BASE_COL_SEGMENT1 in pivot_row.index:
        row[RPT_COL_SEGMENT1] = fmt_seg(pivot_row[BASE_COL_SEGMENT1])
    if RPT_COL_SUBSEG in row and BASE_COL_SUBSEG in pivot_row.index:
        row[RPT_COL_SUBSEG] = fmt_seg(pivot_row[BASE_COL_SUBSEG])
    if target_col in row:
        row[target_col] = fmt_num3(eff)
    return row

