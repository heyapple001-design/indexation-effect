    def _update_mem(self) -> None:
        mb = int(memory_mb())
        self._mem_lbl.setText(f"RAM: {mb} МБ")
        color = RED if mb > MEMORY_WARN_MB else (
            "#E8A000" if mb > MEMORY_WARN_MB * 0.7 else ACCENT)
        self._mem_lbl.setStyleSheet(f"color:{color};font-size:9pt;")

    def _select_report(self):
        start_dir = self._last_paths.get("report_dir", os.path.expanduser("~/Desktop"))
        path, _ = QFileDialog.getOpenFileName(
            self, "Выберите файл отчёта (Таблица 3)", start_dir,
            "Excel files (*.xlsx);;All files (*.*)")
        if not path:
            return
        self._report_path.setText(path)
        self._last_paths["report_dir"] = os.path.dirname(path)
        self._last_paths["report_path"] = path
        save_last_paths(self._last_paths)
        self._load_report_data(path)

    def _load_report_data(self, path: str):
        """Загружает даты, услуги и колонки из отчёта."""
        self.log(f"⏳ Чтение отчёта: {os.path.basename(path)}")
        self._load_progress.setMaximum(3)
        self._load_progress.setValue(0)
        QApplication.processEvents()

        try:
            # Даты
            df_dates = pd.read_excel(path, sheet_name=SHEET_TABLE3, usecols=[RPT_COL_DATE])
            raw_dates = df_dates[RPT_COL_DATE].dropna().unique()
            self._report_dates = sorted(
                set(norm_date(d) for d in raw_dates if norm_date(d)),
                key=lambda d: pd.to_datetime(d, dayfirst=True, errors="coerce"))
            self._load_progress.setValue(1)
            QApplication.processEvents()

            # Услуги
            df_svc = pd.read_excel(path, sheet_name=SHEET_TABLE3, usecols=[RPT_COL_SERVICE])
            raw_svcs = df_svc[RPT_COL_SERVICE].dropna().unique()
            self._report_services = sorted(set(str(s).strip() for s in raw_svcs if str(s).strip()))
            self._load_progress.setValue(2)
            QApplication.processEvents()

            # Колонки + целевая
            df_head = pd.read_excel(path, sheet_name=SHEET_TABLE3, nrows=0)
            self._report_columns = list(df_head.columns)

            month = self._month_combo.currentText()
            self._target_col = None
            for col in self._report_columns:
                cs = str(col).lower()
                if month in cs and all(kw in cs for kw in TARGET_KEYWORDS):
                    self._target_col = col
                    break

            self._load_progress.setValue(3)
            QApplication.processEvents()

        except Exception as e:
            QMessageBox.critical(self, "Ошибка", f"Не могу прочитать отчёт:\n{e}")
            self._report_dates = []
            self._report_services = []
            return

        # Заполняем dropdown услуг
        self._service_combo.clear()
        self._service_combo.addItems(self._report_services)
        self._service_combo.setEnabled(True)

        # Обновляем даты во всех существующих базах
        for bw in self._bases:
            bw._dates = self._report_dates
            current = bw._date_combo.currentText()
            bw._date_combo.clear()
            bw._date_combo.addItems(self._report_dates)
            if current in self._report_dates:
                bw._date_combo.setCurrentText(current)

        msg = f"✓ Отчёт загружен: {len(self._report_dates)} дат, {len(self._report_services)} услуг"
        if self._target_col:
            msg += f"\n  Целевая колонка: {self._target_col}"
        else:
            msg += f"\n  ⚠️ Целевая колонка для '{month}' не найдена"
        self.log(msg)

    def _on_mrf_changed(self, mrf: str):
        """При смене МРФ — перерисовываем чекбоксы РФ."""
        # Очищаем старые
        for cb in self._rf_checkboxes:
            self._rf_layout.removeWidget(cb)
            cb.deleteLater()
        self._rf_checkboxes.clear()

        if not mrf:
            return

        # Получаем список РФ для этого МРФ
        rf_list = MRF_TO_RF.get(mrf, [])
        if not rf_list:
            lbl = QLabel(f"<i>Для МРФ {mrf} не найдены региональные филиалы</i>")
            lbl.setStyleSheet(f"color:{HINT};")
            self._rf_layout.addWidget(lbl)
            self._rf_checkboxes.append(lbl)
            return

        # Все галочки включены по умолчанию
        for rf in rf_list:
            cb = QCheckBox(rf)
            cb.setChecked(True)
            self._rf_layout.addWidget(cb)
            self._rf_checkboxes.append(cb)

    def _on_mode_changed(self):
        if self._mode_external.isChecked():
            self._charges_widget.show()
        else:
            self._charges_widget.hide()
        # Обновляем режим во всех базах
        mode = MODE_EXTERNAL if self._mode_external.isChecked() else MODE_INBASE
        for bw in self._bases:
            bw.set_mode(mode)

    def _select_charges(self):
        start_dir = self._last_paths.get("charges_dir", os.path.expanduser("~/Desktop"))
        path, _ = QFileDialog.getOpenFileName(
            self, "Файл начислений", start_dir,
            "Excel files (*.xlsx);;All files (*.*)")
        if not path:
            return
        self._charges_path.setText(path)
        self._last_paths["charges_dir"] = os.path.dirname(path)
        self._last_paths["charges_path"] = path
        save_last_paths(self._last_paths)

    def _add_base(self):
        if not self._report_dates:
            QMessageBox.warning(self, "Внимание",
                                "Сначала выберите файл отчёта — из него берутся даты.")
            return

        self._base_counter += 1
        mode = MODE_EXTERNAL if self._mode_external.isChecked() else MODE_INBASE
        bw = BaseWidget(self._base_counter, self._report_dates, mode)
        bw.deleted.connect(self._remove_base)
        self._bases.append(bw)
        self._bases_layout.addWidget(bw)
        self._base_count_lbl.setText(f"Баз добавлено: {len(self._bases)}")

    def _remove_base(self, bw: BaseWidget):
        if bw in self._bases:
            self._bases.remove(bw)
            self._bases_layout.removeWidget(bw)
            bw.deleteLater()
            self._base_count_lbl.setText(f"Баз добавлено: {len(self._bases)}")

    def _select_save_folder(self):
        start_dir = self._last_paths.get("save_folder", os.path.expanduser("~/Desktop"))
        folder = QFileDialog.getExistingDirectory(self, "Папка для сохранения", start_dir)
        if not folder:
            return
        self._save_folder.setText(folder)
        self._last_paths["save_folder"] = folder
        save_last_paths(self._last_paths)

    def log(self, msg: str) -> None:
        self._console.append(msg)
        # Автопрокрутка
        sb = self._console.verticalScrollBar()
        sb.setValue(sb.maximum())

    def _start_calc(self):
        """Валидация и запуск расчёта."""
        # Валидация
        report_path = self._report_path.text()
        if not report_path or not os.path.exists(report_path):
            QMessageBox.warning(self, "Внимание", "Выберите файл отчёта.")
            return

        if not self._target_col:
            QMessageBox.warning(self, "Внимание",
                                f"Целевая колонка для месяца '{self._month_combo.currentText()}' не найдена.")
            return

        service = self._service_combo.currentText()
        if not service:
            QMessageBox.warning(self, "Внимание", "Выберите услугу.")
            return

        mrf = self._mrf_combo.currentText()
        if not mrf:
            QMessageBox.warning(self, "Внимание", "Выберите МРФ.")
            return

        if not self._bases:
            QMessageBox.warning(self, "Внимание", "Добавьте хотя бы одну базу.")
            return

        save_folder = self._save_folder.text()
        if not save_folder or not os.path.isdir(save_folder):
            QMessageBox.warning(self, "Внимание", "Выберите папку для сохранения.")
            return

        mode = MODE_EXTERNAL if self._mode_external.isChecked() else MODE_INBASE
        charges_path = self._charges_path.text() if mode == MODE_EXTERNAL else None
        if mode == MODE_EXTERNAL and (not charges_path or not os.path.exists(charges_path)):
            QMessageBox.warning(self, "Внимание", "Выберите файл начислений.")
            return

        # Собираем параметры баз
        bases = []
        for bw in self._bases:
            data = bw.get_data()
            if data is None:
                return
            data["charges_mode"] = mode
            data["charges_path"] = charges_path
            data["services"] = [norm_text(service)]
            bases.append(data)

        # Подтверждение
        msg = (f"Запустить расчёт?\n\n"
               f"Месяц: {self._month_combo.currentText()}\n"
               f"МРФ: {mrf}\n"
               f"Услуга: {service}\n"
               f"Режим: {'внешний файл' if mode == MODE_EXTERNAL else 'в базе'}\n"
               f"Баз: {len(bases)}\n"
               f"Сохранение: {save_folder}")
        if QMessageBox.question(self, "Подтверждение", msg,
                                QMessageBox.Yes | QMessageBox.No) != QMessageBox.Yes:
            return

        params = {
            "session_id": datetime.now().strftime("%Y%m%d_%H%M%S"),
            "month": self._month_combo.currentText(),
            "mrf_name": mrf,
            "table3_path": report_path,
            "target_col": self._target_col,
            "save_folder": save_folder,
            "bases": bases,
        }

        self._run_worker(params)

    def _run_worker(self, params: dict):
        self._run_btn.setEnabled(False)
        self._stop_btn.setEnabled(True)
        self._calc_progress.setMaximum(max(len(params["bases"]), 1))
        self._calc_progress.setValue(0)
        self._console.clear()

        self._thread = QThread()
        self._worker = CalcWorker(params)
        self._worker.moveToThread(self._thread)

        self._thread.started.connect(self._worker.run)
        self._worker.log_msg.connect(self.log)
        self._worker.progress.connect(self._on_progress)
        self._worker.finished.connect(self._on_finished)
        self._worker.error.connect(self._on_error)

        self._thread.start()

    def _stop_calc(self):
        if self._worker:
            self._worker.stop()
            self.log("\n⚠️ Остановка после текущей операции...")

    def _on_progress(self, cur: int, total: int, desc: str):
        self._calc_progress.setMaximum(total)
        self._calc_progress.setValue(cur)
        self._calc_progress.setFormat(f"{desc} ({cur}/{total})")

    def _on_finished(self, stats: dict):
        self._cleanup_thread()
        c = stats["counts"]
        save_path = stats.get("save_path", "")
        self.log(f"\n{'='*55}\nГОТОВО\n{'='*55}")
        self.log(f"🟢 Записано: {c['matched']} | 🔵 Добавлено: {c['added']} | 🟡 Не найдено: {c['not_found']}")
        if save_path:
            self.log(f"📁 Файл: {save_path}")
        self._update_mem()
        QMessageBox.information(self, "Готово",
                                f"Расчёт завершён!\n\n"
                                f"🟢 Записано:    {c['matched']}\n"
                                f"🔵 Добавлено:   {c['added']}\n"
                                f"🟡 Не найдено:  {c['not_found']}\n\n"
                                f"📁 {save_path}")

    def _on_error(self, msg: str):
        self._cleanup_thread()
        self.log(f"\n❌ ОШИБКА: {msg}")
        QMessageBox.critical(self, "Ошибка", f"Произошла ошибка:\n{msg}")

    def _cleanup_thread(self):
        self._run_btn.setEnabled(True)
        self._stop_btn.setEnabled(False)
        if self._thread:
            self._thread.quit()
            self._thread.wait(3000)
            self._thread = None
        self._worker = None
        gc.collect()

# ── ТОЧКА ВХОДА ────────────────────────────────────────────────
def main() -> None:
    if not PYQT_AVAILABLE:
        print("❌ PyQt5 не установлен.")
        return

    # Защита от повторного QApplication в IDLE
    app = QApplication.instance()
    owns_app = False
    if app is None:
        app = QApplication(sys.argv)
        owns_app = True
    app.setStyle("Fusion")
    app.setStyleSheet(STYLESHEET)

    window = MainWindow()

    if owns_app:
        # Запуск из командной строки / PyCharm
        try:
            sys.exit(app.exec_())
        except KeyboardInterrupt:
            print("\nПрограмма остановлена.")
            sys.exit(0)
    else:
        # IDLE — просто показываем окно, exec_ не вызываем
        # (IDLE уже крутит свой event loop)
        window.show()
        print("✓ Окно открыто. В IDLE закройте окно для завершения.")

if __name__ == "__main__":
    main()
