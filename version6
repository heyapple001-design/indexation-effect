def find_col(df: pd.DataFrame, name: str) -> Optional[str]:
    nl = name.strip().lower()
    return next((c for c in df.columns if str(c).strip().lower() == nl), None)

def norm_text(x: Any) -> str:
    if pd.isna(x): return ""
    return " ".join(str(x).replace("\xa0", " ").strip().lower().split())

def norm_date(x: Any) -> str:
    if x is None: return ""
    try:
        if pd.isna(x): return ""
    except TypeError:
        pass
    dt = pd.to_datetime(x, errors="coerce", dayfirst=True)
    if pd.isna(dt): return str(x).strip()
    return dt.strftime("%d.%m.%Y")

def map_rf(v: Any) -> str:
    """
    Преобразует название филиала в канонический формат (ФЭС ...).
    Использует RF_MAPPING из mappings.json.
    
    Примеры:
        "Калининградский филиал" -> "ФЭС Калининградский"
        "фэс калининградский" -> "ФЭС Калининградский"
        "калининградский" -> "ФЭС Калининградский"
    """
    if pd.isna(v) or str(v).strip() == "":
        return ""
    
    s = str(v).strip()
    s_lower = s.lower()
    
    # 1. Точное совпадение
    if s in RF_MAPPING:
        return RF_MAPPING[s]
    
    if s_lower in RF_MAPPING:
        return RF_MAPPING[s_lower]
    
    # 2. Частичное совпадение (для вариантов без слова "филиал")
    for key, value in RF_MAPPING.items():
        key_lower = key.lower()
        if s_lower in key_lower or key_lower in s_lower:
            return value
    
    # 3. Проверка: если строка уже начинается с "ФЭС", оставляем как есть с правильным форматированием
    if s_lower.startswith("фэс"):
        return fmt_title(s)
    
    # 4. Если ничего не подошло, возвращаем исходную строку с нормализацией
    return norm_text(s)

def unmap_rf(canon: Any) -> str:
    """Обратное преобразование: из канонического формата в исходное название филиала."""
    if pd.isna(canon) or str(canon).strip() == "":
        return ""
    return RF_REVERSE.get(norm_text(canon), str(canon))

def fmt_title(x: Any) -> Any:
    if pd.isna(x) or str(x).strip() == "": return x
    s = str(x).strip()
    return s[0].upper() + s[1:].lower()

def fmt_mrf(x: Any) -> Any:
    if pd.isna(x) or str(x).strip() == "": return x
    return MRF_EXACT.get(str(x).strip().lower(), fmt_title(x))

def fmt_service(x: Any) -> Any:
    if pd.isna(x) or str(x).strip() == "": return x
    s = str(x).strip()
    key = s.lower()
    if key in SERVICE_EXACT: return SERVICE_EXACT[key]
    if key in UPPERCASE_SERVICES: return s.upper()
    return fmt_title(s)

def fmt_seg(x: Any) -> Any:
    if pd.isna(x) or str(x).strip() == "": return x
    ABBREVS = {'мсп', 'смп', 'мрф', 'фэс', 'днк', 'ккфу', 'фу', 'ру', 'вп', 'оп', 'нк', 'топ'}
    result = []
    for w in str(x).strip().split():
        if re.search(r'[a-zA-Z0-9]', w):
            result.append(w.upper())
        elif w.lower() in ABBREVS:
            result.append(w.upper())
        else:
            result.append(w.capitalize())
    return ' '.join(result)

def fmt_pct(x: Any) -> Any:
    try:
        v = float(str(x).replace(",", ".").replace("%", "").strip())
        return v / 100 if v > 1 else v
    except (ValueError, TypeError):
        return x

def fmt_num3(x: Any) -> Any:
    try:
        return round(float(x), 3)
    except (ValueError, TypeError):
        return x

def memory_mb() -> float:
    return psutil.Process().memory_info().rss / 1024 / 1024

